{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
</style>
<form class="layui-form" action="" method="post">
	<div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<label class="layui-form-label">产品编码</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="sn"  value=""  placeholder="为空时系统自动生成" autocomplete="off" class="layui-input">
				</div>
				<label class="layui-form-label">产品名称</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="name" lay-verify="required" value=""  placeholder="请输入产品名称,不可为空" autocomplete="off" class="layui-input">
				</div>				
				<label class="layui-form-label">产品分类</label>
				<div class="layui-input-inline">
					<select name="cid" lay-verify="required">
						{foreach $category as $key=>$vo}
						<option value="{$vo['id']}">{$vo['name']}</option>
						{/foreach}
					</select>
				</div>
			</div>			
			<div class="layui-form-item">
				<label class="layui-form-label">型号</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="255" name="model" lay-verify="required" value=""  placeholder="请输入产品型号,不可为空" autocomplete="off" class="layui-input">
				</div>
				<label class="layui-form-label">款式</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="255" name="specs"  value=""  placeholder="请输入产品款式,可为空" autocomplete="off" class="layui-input">
				</div>				
				<label class="layui-form-label">单位</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="unit"  placeholder="请输入" autocomplete="off" class="layui-input">
				</div>				
			</div>				
			<div class="layui-form-item">
				<label class="layui-form-label">备注</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="255" name="remark"  placeholder="请输入" autocomplete="off" class="layui-input">
				</div>	
				<label class="layui-form-label">状态</label>
				<div class="layui-input-inline">
					<input type="radio" name="status" value="1" title="启用" checked>
					<input type="radio" name="status" value="0" title="禁用" >
				</div>	
				<label class="layui-form-label"><span class="asterisk">*</span>域属</label>
				<div class="layui-input-inline">
					{foreach $region_type as $key=>$vo}
					<input type="radio" name="region_type" value="{$key}" title="{$vo}" {if $key == 1}checked{/if} lay-filter="region_type" >
					{/foreach}
				</div>					
			</div>	
			<div class="layui-form-item">
				<label class="layui-form-label">版本号</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="version" lay-verify="" value=""  placeholder="" autocomplete="off" class="layui-input">
				</div>
				<label class="layui-form-label">UDI码</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="udi"  value=""  placeholder="" autocomplete="off" class="layui-input">
				</div>				
				<label class="layui-form-label">标识码</label>
				<div class="layui-input-inline">
					<input type="text" maxlength="100" name="id_code"  value=""  placeholder="" autocomplete="off" class="layui-input">
				</div>			
			</div>			
			<div class="layui-form-item">
				<label class="layui-form-label">图片</label>
				<div class="layui-input-block">
					{:$form->optPhoto('photo')}
				</div>
			</div>	
			<div class="layui-form-item">
				<label class="layui-form-label">QC品检作业指导书</label>
				<div class="layui-input-block">
					{:$form->files('qc_file')}
				</div>
			</div>	
			<div class="layui-form-item">
				<label class="layui-form-label">生产作业指导书</label>
				<div class="layui-input-block">
					{:$form->files('produce_file')}
				</div>
			</div>	
			<div class="layui-form-item">
				<label class="layui-form-label">编号/版本</label>
				<div class="layui-input-block">
					{:$form->files('num_version')}
				</div>
			</div>			
		</div>
	</div>
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
			<button type="reset" class="layui-btn layui-btn-primary layui-btn-sm"><i class="layui-icon layui-icon-refresh"></i>重置</button>
		</div>
	</div>
</form>
{/block}