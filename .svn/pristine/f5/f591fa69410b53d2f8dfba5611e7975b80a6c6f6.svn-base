{extend name="base" /}
{block name="body"}
<style>
.layui-elem-quote {
	margin-bottom:0;
}
.layui-table-view .layui-table[lay-size="sm"] .layui-select-title .layui-input {
	height: 28px;
	margin-top: -8px;
}
.layui-table-view .layui-table[lay-size="sm"] .layui-form-select dl dt,.layui-table-view .layui-form-select dl dd {
	line-height: 28px;
}
.layui-table-view .layui-table[lay-size="sm"] .layui-form-select dl {
	top: 28px;
}
.layui-table-view .layui-table .layui-select-title .layui-input {
	height: 32px;
	margin-top: -3px;
}
.layui-table-view .layui-table .layui-form-select dl dt,.layui-table-view .layui-form-select dl dd {
	line-height: 32px;
}
.layui-table-view .layui-table .layui-form-select dl {
	top: 32px;
}
.layui-table-view .layui-table[lay-size="lg"] .layui-select-title .layui-input {
	height: 38px;
	margin-top: 0;
}
.layui-table-view .layui-table[lay-size="lg"] .layui-form-select dl dt,.layui-table-view .layui-form-select dl dd {
	line-height: 38px;
}
.layui-table-view .layui-table[lay-size="lg"] .layui-form-select dl {
	top: 38px;
}
.layui-table tr td[data-field="bill_type"] .layui-table-cell{	overflow:visible;}.type{display:none;}</style><div class="layui-row layui-col-space10">	<div class="layui-col-md6" id="cccc">		<div class="layui-card">			<div class="layui-card-body">				<blockquote class="layui-elem-quote">					1、方案信息					<form class="layui-form" action="" style="display: inline-block;margin:0 0 0 50px;">						<div class="layui-input-inline"><input type="text" name="keyword" placeholder="方案名称/方案编码" class="layui-input"></div>						<div class="layui-input-inline"><button type="button" class="pear-btn pear-btn-primary pear-btn-sm" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button></div>					</form>				</blockquote>				<table id="dataTable" lay-filter="dataTable"></table>			</div>		</div>	</div>	<div class="layui-col-md6">		<div class="layui-card empty">			<div class="layui-card-body">				<svg  style="margin-top: 50px;margin-left: 220px;margin-bottom: 80px;" width="184" height="152"					 viewBox="0 0 184 152" xmlns="http://www.w3.org/2000/svg">						<g fill="none" fillRule="evenodd">							<g transform="translate(24 31.67)">
								<ellipse fillOpacity=".8" fill="#F5F5F7" cx="67.797" cy="106.89" rx="67.797" ry="12.668"></ellipse>
								<path d="M122.034 69.674L98.109 40.229c-1.148-1.386-2.826-2.225-4.593-2.225h-51.44c-1.766 0-3.444.839-4.592 2.225L13.56 69.674v15.383h108.475V69.674z" fill="#AEB8C2"></path>
								<path d="M101.537 86.214L80.63 61.102c-1.001-1.207-2.507-1.867-4.048-1.867H31.724c-1.54 0-3.047.66-4.048 1.867L6.769 86.214v13.792h94.768V86.214z" fill="url(#linearGradient-1)" transform="translate(13.56)"></path>
								<path d="M33.83 0h67.933a4 4 0 0 1 4 4v93.344a4 4 0 0 1-4 4H33.83a4 4 0 0 1-4-4V4a4 4 0 0 1 4-4z" fill="#F5F5F7"></path>
								<path d="M42.678 9.953h50.237a2 2 0 0 1 2 2V36.91a2 2 0 0 1-2 2H42.678a2 2 0 0 1-2-2V11.953a2 2 0 0 1 2-2zM42.94 49.767h49.713a2.262 2.262 0 1 1 0 4.524H42.94a2.262 2.262 0 0 1 0-4.524zM42.94 61.53h49.713a2.262 2.262 0 1 1 0 4.525H42.94a2.262 2.262 0 0 1 0-4.525zM121.813 105.032c-.775 3.071-3.497 5.36-6.735 5.36H20.515c-3.238 0-5.96-2.29-6.734-5.36a7.309 7.309 0 0 1-.222-1.79V69.675h26.318c2.907 0 5.25 2.448 5.25 5.42v.04c0 2.971 2.37 5.37 5.277 5.37h34.785c2.907 0 5.277-2.421 5.277-5.393V75.1c0-2.972 2.343-5.426 5.25-5.426h26.318v33.569c0 .617-.077 1.216-.221 1.789z" fill="#DCE0E6"></path>
							</g>							<path d="M149.121 33.292l-6.83 2.65a1 1 0 0 1-1.317-1.23l1.937-6.207c-2.589-2.944-4.109-6.534-4.109-10.408C138.802 8.102 148.92 0 161.402 0 173.881 0 184 8.102 184 18.097c0 9.995-10.118 18.097-22.599 18.097-4.528 0-8.744-1.066-12.28-2.902z" fill="#DCE0E6"></path>
							<g transform="translate(149.65 15.383)" fill="#FFF">
								<ellipse cx="20.654" cy="3.167" rx="2.849" ry="2.815"></ellipse>
								<path d="M5.698 5.63H0L2.898.704zM9.259.704h4.985V5.63H9.259z"></path>
							</g>
						</g>
				</svg>
			</div>
		</div>
		<div class="layui-card type type1">
			<div class="layui-card-body">
				<blockquote class="layui-elem-quote">
					2、改配新增部件 / 零件
					<form class="layui-form" action="" style="display: inline-block;margin:0 0 0 50px;">
						<div class="layui-input-inline"><input type="text" name="keyword" placeholder="产品名称/产品编码" class="layui-input"></div>
						<div class="layui-input-inline"><button type="button" class="pear-btn pear-btn-primary pear-btn-sm" lay-submit lay-filter="queryBom1"><i class="layui-icon layui-icon-search"></i>查询</button></div>					</form>
				</blockquote>
				<table id="bom1Table" lay-filter="bom1Table"></table>
			</div>
		</div>
		<div class="layui-card type type1">
			<div class="layui-card-body">
				<blockquote class="layui-elem-quote">
					3、改配需删除的部件 / 零件
					<form class="layui-form" action="" style="display: inline-block;margin:0 0 0 50px;">
						<div class="layui-input-inline"><input type="text" name="keyword" placeholder="产品名称/产品编码" class="layui-input"></div>
						<div class="layui-input-inline"><button type="button" class="pear-btn pear-btn-primary pear-btn-sm" lay-submit lay-filter="queryBom2"><i class="layui-icon layui-icon-search"></i>查询</button></div>					</form>
				</blockquote>
				<table id="bom2Table" lay-filter="bom2Table"></table>
			</div>
		</div>
		<div class="layui-card type type2">
			<div class="layui-card-body">
				<blockquote class="layui-elem-quote">
					2、方案包含部件 / 零件
					<form class="layui-form" action="" style="display: inline-block;margin:0 0 0 50px;">
						<div class="layui-input-inline"><input type="text" name="keyword" placeholder="产品名称/产品编码" class="layui-input"></div>
						<div class="layui-input-inline"><button type="button" class="pear-btn pear-btn-primary pear-btn-sm" lay-submit lay-filter="queryBom3"><i class="layui-icon layui-icon-search"></i>查询</button></div>					</form>
				</blockquote>
				<table id="bom3Table" lay-filter="bom3Table"></table>
			</div>
		</div>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-success  pear-btn-sm" lay-event="import"><i class="layui-icon layui-icon-upload"></i>导入</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除</button>
	<button class="pear-btn pear-btn-sm" lay-event="export"><i class="layui-icon  layui-icon-export"></i>导出</button>
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="copy"><i class="layui-icon layui-icon-templeate-1"></i></button>
	<!--<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>-->
</script>
<script type="text/html" id="photo">
	<button lay-event="photo" class="pear-btn pear-btn-primary pear-btn-xs" ><i class="layui-icon layui-icon-link"></i></button>
</script>
<script type="text/html" id="bomtoolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>添加物料</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除物料</button>
</script>
<script type="text/html" id="color_follow">
	<input type="checkbox" name="color_follow" value="{{d.id}}" lay-skin="switch" lay-text="是|否" lay-filter="color_follow" {{# if(d.color_follow==1){ }} checked {{# } }}>
</script>
<script type="text/html" id="can_replace">
	<input type="checkbox" name="can_replace" value="{{d.id}}" lay-skin="switch" lay-text="是|否" lay-filter="can_replace" {{# if(d.can_replace==1){ }} checked {{# } }}>
</script>
{/block}
{block name="script"}
<script>	var bill_type = {:json_encode($bill_type)} ;	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;
		let project_id = 0;
		var h = ($(window).height() - 553)-2 ;
		if(h<=250){
			h= 250;
		}
		table.render({
			elem: '#dataTable',
			url: '{:url('list')}',
			limit:90,
			page: true,		
			cols: [[
				{type: 'checkbox'},
				{field: 'code',title: '方案编号',sort: true,align: 'center',unresize: false,width: {:get_col_width('code',150)}, hide: getTableFieldIsHide('dataTable','code')},				{field: 'name',title: '方案名称',sort: true,align: 'left',unresize: false,width: {:get_col_width('name',250)}, hide: getTableFieldIsHide('dataTable','name')},				{field: 'cid',title: '方案分类',sort: true,align: 'center',unresize: false,width: {:get_col_width('category',120)},templet: function(d){return d.category;}, hide: getTableFieldIsHide('dataTable','cid')},				{field: 'type_desc',title: '方案功能',align: 'center',unresize: false,width: {:get_col_width('type_desc',100)}, hide: getTableFieldIsHide('dataTable','type_desc')},				{field: 'status_desc',title: '状态',align: 'center',unresize: false,width: {:get_col_width('status_desc',100)}, hide: getTableFieldIsHide('dataTable','status_desc')},				{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 100,fixed: 'right'}			]],
			cellMinWidth: 100,
			height: 'full-140',
			//skin: 'line',
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});
		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});
		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'remove') {				layerConfirm('确定要删除该方案?','{:url('remove')}',{ids:[obj.data['id']]},function(res){					obj.del();
				})
			} else if (obj.event === 'edit') {
				openLayer('修改方案','{:url('edit')}?id='+obj.data['id'],'80%','90%');
			}else if (obj.event === 'copy') {
				layerConfirm('确定要复制该方案?','{:url('copy')}',{id:obj.data['id']},function(res){
					table.reload('dataTable');
				})
			}
		});
		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增方案','{:url('add')}','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些方案','{:url('remove')}');
			} else if (obj.event === 'import') {
				openLayer('导入','{:url('import')}','80%','90%',function () {
					table.reload('dataTable');
				});
			} else if (obj.event === 'export') {
				//var data = form.val('searchForm');
				exportData('{:url('export')}');
			}
		});
		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		table.on('row(dataTable)',function (obj) {
			$(".empty").hide();
			$(".type").hide();
			$('.type'+obj.data['type']).show();
			project_id = obj.data['id'];
			if(obj.data['type'] == 1){
				window.renderData1()
				window.renderData2()
			}else{
				window.renderData3()
			}		})	
		form.on('submit(queryBom1)', function(data) {
			table.reload('bom1Table', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});	
		window.renderData1 = function() {
			table.render({
				elem: '#bom1Table',
				url: "{:url('erp.ProjectBom/list')}?project_id="+project_id+"&data_type=2",				page: true,				limit:90,				height: h,
				cols: [[					{type: 'checkbox'},
					{field: 'sn',title: '物料编码',sort: true,align: 'center',unresize: false,width: {:get_col_width('sn1',150)},templet: function(d){return d.material?d.material.sn:'';}, hide: getTableFieldIsHide('bom1Table','sn')},					{field: 'name',title: '物料名称',sort: true,align: 'left',unresize: false,width: {:get_col_width('name1',250)},templet: function(d){return d.material?d.material.name:'';}, hide: getTableFieldIsHide('bom1Table','name')},					{field: 'num',title: '数量', edit: 'text',align: 'center',unresize: false,width: {:get_col_width('num1',120)},templet: function(d){return d.num;}, hide: getTableFieldIsHide('bom1Table','num')},					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit1',100)},templet: function(d){return d.material?d.material.unit:'';}, hide: getTableFieldIsHide('bom1Table','unit')},					{field: 'type_desc',title: '物料属性',sort: true,align: 'center',unresize: false,width: {:get_col_width('type_desc1',100)},templet: function(d){return d.material?d.material.type_desc:'';}, hide: getTableFieldIsHide('bom1Table','type_desc')},					{field: 'bill_type',title: '类型',align: 'left',unresize: false,width: {:get_col_width('bill_type1',150)},templet: function(d){return getBillTypeSelect(d);}, hide: getTableFieldIsHide('bom1Table','bill_type')},					{field: 'color_follow',title: '颜色是否跟随产品',align: 'left',unresize: true,width: 150,templet: '#color_follow', hide: getTableFieldIsHide('bom1Table','color_follow')}				]],
				toolbar: '#bomtoolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter'],
				done:function(res, curr, count){
					form.render('select'); 
				}
			});
		}
		table.on('toolbar(bom1Table)', function(obj) {
			if (obj.event === 'add') {
				openLayer('添加物料','{:url('erp.ProjectBom/add')}?project_id='+project_id+'&table=bom1Table&data_type=2','80%','90%');			}else if (obj.event === 'refresh') {				table.reload('bom1Table');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些物料','{:url('erp.ProjectBom/remove')}');
			}
		});
		table.on('edit(bom1Table)', function(obj){
			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{id:obj.data.id,num:obj.value})
		});		
		form.on('submit(queryBom2)', function(data) {
			table.reload('bom2Table', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});	
		window.renderData2 = function() {
			table.render({
				elem: '#bom2Table',
				url: "{:url('erp.ProjectBom/list')}?project_id="+project_id+"&data_type=4",
				page: true,
				limit:90,
				height: h,
				cols: [[
					{type: 'checkbox'},
					{field: 'sn',title: '物料编码',sort: true,align: 'center',unresize: false,width: {:get_col_width('sn2',0)},templet: function(d){return d.material?d.material.sn:'';}, hide: getTableFieldIsHide('bom2Table','sn')},					{field: 'name',title: '物料名称',sort: true,align: 'left',unresize: false,width: {:get_col_width('name2',0)},templet: function(d){return d.material?d.material.name:'';}, hide: getTableFieldIsHide('bom2Table','name')},					{field: 'num',title: '数量', edit: 'text',align: 'center',unresize: false,width: {:get_col_width('num2',120)},templet: function(d){return d.num;}, hide: getTableFieldIsHide('bom2Table','num')},					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit2',100)},templet: function(d){return d.material?d.material.unit:'';}, hide: getTableFieldIsHide('bom2Table','unit')},				]],				toolbar: '#bomtoolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter'],
				done:function(res, curr, count){
					form.render('select'); 
				}
			});
		}
		table.on('toolbar(bom2Table)', function(obj) {
			if (obj.event === 'add') {
				openLayer('添加物料','{:url('erp.ProjectBom/add')}?project_id='+project_id+'&table=bom2Table&data_type=4','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('bom2Table');
			} else if (obj.event === 'batchRemove') {				tableAction(obj.config.id,'确定要删除这些物料','{:url('erp.ProjectBom/remove')}');			}		});
		table.on('edit(bom2Table)', function(obj){			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{id:obj.data.id,num:obj.value})		});
		form.on('submit(queryBom3)', function(data) {			table.reload('bom3Table', {				where: data.field,				page:{curr: 1}			})			return false;
		});
		window.renderData3 = function() {
			table.render({
				elem: '#bom3Table',
				url: "{:url('erp.ProjectBom/list')}?project_id="+project_id+"&data_type=3",
				page: true,
				limit:90,
				height: h,
				cols: [[
					{type: 'checkbox'},
					{field: 'sn',title: '物料编码',sort: true,align: 'center',unresize: false,width: {:get_col_width('sn3',150)},templet: function(d){return d.material?d.material.sn:'';}, hide: getTableFieldIsHide('bom3Table','sn')},					{field: 'name',title: '物料名称',sort: true,align: 'left',unresize: false,width: {:get_col_width('name3',250)},templet: function(d){return d.material?d.material.name:'';}, hide: getTableFieldIsHide('bom3Table','name')},					{field: 'num',title: '数量', edit: 'text',align: 'center',unresize: false,width: {:get_col_width('num3',120)},templet: function(d){return d.num;}, hide: getTableFieldIsHide('bom3Table','num')},					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit3',100)},templet: function(d){return d.material?d.material.unit:'';}, hide: getTableFieldIsHide('bom3Table','unit')},					{field: 'type_desc',title: '物料属性',sort: true,align: 'center',unresize: false,width: {:get_col_width('type_desc3',100)},templet: function(d){return d.material?d.material.type_desc:'';}, hide: getTableFieldIsHide('bom3Table','type_desc')},					{field: 'bill_type',title: '类型',sort: true,align: 'left',unresize: false,width: {:get_col_width('bill_type3',150)},templet: function(d){return getBillTypeSelect(d);}, hide: getTableFieldIsHide('bom3Table','bill_type')},					{field: 'color_follow',title: '颜色是否跟随产品',align: 'left',unresize: true,width: 150,templet: '#color_follow', hide: getTableFieldIsHide('bom3Table','color_follow')}				]],
				toolbar: '#bomtoolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',					icon: 'layui-icon-refresh',
				}, 'filter'],				done:function(res, curr, count){
					form.render('select'); 				}
			});
		}
		table.on('toolbar(bom3Table)', function(obj) {
			if (obj.event === 'add') {
				openLayer('添加物料','{:url('erp.ProjectBom/add')}?project_id='+project_id+'&table=bom3Table&data_type=3','80%','90%');			}else if (obj.event === 'refresh') {
				table.reload('bom3Table');			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些物料','{:url('erp.ProjectBom/remove')}');			}
		});
		table.on('edit(bom3Table)', function(obj){
			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{id:obj.data.id,num:obj.value})		});			form.on('switch(color_follow)', function(data) {			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{color_follow:data.elem.checked?1:0,id:this.value})		});		form.on('switch(can_replace)', function(data) {			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{can_replace:data.elem.checked?1:0,id:this.value})		});				form.on('select(bill_type)', function (data) {			ajaxActionCall('{:url('erp.ProjectBom/edit')}',{bill_type:data.value,id:$(data.elem).data("id")})        });
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
				}
			});
		});
		table.on('colResized(bom1Table)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'1',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
				}			});		});		table.on('colResized(bom2Table)', function(obj){			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'2',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
				}
			});
		});
		table.on('colResized(bom3Table)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'3',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
				}
			});
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		table.on('colToggled(bom1Table)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		table.on('colToggled(bom2Table)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		table.on('colToggled(bom3Table)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		function getBillTypeSelect(d){
			var html = '<select lay-filter="bill_type" data-id="'+d.id+'" name="bill_type"  lay-skin="select"><option value="0" >无</option>'; 
			layui.each(bill_type, function(index, item){
				html += '<option value="'+item.id+'" '+(d.bill_type==item.id ? 'selected':'')+'>'+item.name+'</option>';			});
			html += '</select>';
			return html;
		}
	})
</script>{/block}


