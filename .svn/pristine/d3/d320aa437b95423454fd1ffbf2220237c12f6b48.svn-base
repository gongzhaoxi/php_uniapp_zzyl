{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<form class="layui-form" action="" id="searchForm">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="物料名称" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="sn" placeholder="物料编码" class="layui-input">	
				</div>
				<div class="layui-form-item layui-inline">
					<input type="text" name="remark" placeholder="物料备注" class="layui-input">	
				</div>		
				<div class="layui-form-item layui-inline">
					<select name="status" >
						<option value="">状态</option>
						<option value="1" selected>启用</option>
						<option value="0">禁用</option>	
					</select>
				</div>				
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
				</div>
			</div>
		</form>
	</div>
</div>

<div class="layui-row layui-col-space10">
	<div class="layui-col-md6">
		<div class="layui-card">
			<div class="layui-card-body">
				<blockquote class="layui-elem-quote">部件信息</blockquote>
				<table id="dataTable" lay-filter="dataTable"></table>
			</div>
		</div>
	</div>
	<div class="layui-col-md6">
		<div class="layui-card">
			<div class="layui-card-body">
				<blockquote class="layui-elem-quote">关联零件信息</blockquote>
				<svg class="empty" style="margin-top: 50px;margin-left: 220px;margin-bottom: 80px;" width="184" height="152"
				 viewBox="0 0 184 152" xmlns="http://www.w3.org/2000/svg">
					<g fill="none" fillRule="evenodd">
						<g transform="translate(24 31.67)">
							<ellipse fillOpacity=".8" fill="#F5F5F7" cx="67.797" cy="106.89" rx="67.797" ry="12.668"></ellipse>
							<path d="M122.034 69.674L98.109 40.229c-1.148-1.386-2.826-2.225-4.593-2.225h-51.44c-1.766 0-3.444.839-4.592 2.225L13.56 69.674v15.383h108.475V69.674z"
							 fill="#AEB8C2"></path>
							<path d="M101.537 86.214L80.63 61.102c-1.001-1.207-2.507-1.867-4.048-1.867H31.724c-1.54 0-3.047.66-4.048 1.867L6.769 86.214v13.792h94.768V86.214z"
							 fill="url(#linearGradient-1)" transform="translate(13.56)"></path>
							<path d="M33.83 0h67.933a4 4 0 0 1 4 4v93.344a4 4 0 0 1-4 4H33.83a4 4 0 0 1-4-4V4a4 4 0 0 1 4-4z" fill="#F5F5F7"></path>
							<path d="M42.678 9.953h50.237a2 2 0 0 1 2 2V36.91a2 2 0 0 1-2 2H42.678a2 2 0 0 1-2-2V11.953a2 2 0 0 1 2-2zM42.94 49.767h49.713a2.262 2.262 0 1 1 0 4.524H42.94a2.262 2.262 0 0 1 0-4.524zM42.94 61.53h49.713a2.262 2.262 0 1 1 0 4.525H42.94a2.262 2.262 0 0 1 0-4.525zM121.813 105.032c-.775 3.071-3.497 5.36-6.735 5.36H20.515c-3.238 0-5.96-2.29-6.734-5.36a7.309 7.309 0 0 1-.222-1.79V69.675h26.318c2.907 0 5.25 2.448 5.25 5.42v.04c0 2.971 2.37 5.37 5.277 5.37h34.785c2.907 0 5.277-2.421 5.277-5.393V75.1c0-2.972 2.343-5.426 5.25-5.426h26.318v33.569c0 .617-.077 1.216-.221 1.789z"
							 fill="#DCE0E6"></path>
						</g>
						<path d="M149.121 33.292l-6.83 2.65a1 1 0 0 1-1.317-1.23l1.937-6.207c-2.589-2.944-4.109-6.534-4.109-10.408C138.802 8.102 148.92 0 161.402 0 173.881 0 184 8.102 184 18.097c0 9.995-10.118 18.097-22.599 18.097-4.528 0-8.744-1.066-12.28-2.902z"
						 fill="#DCE0E6"></path>
						<g transform="translate(149.65 15.383)" fill="#FFF">
							<ellipse cx="20.654" cy="3.167" rx="2.849" ry="2.815"></ellipse>
							<path d="M5.698 5.63H0L2.898.704zM9.259.704h4.985V5.63H9.259z"></path>
						</g>
					</g>
				</svg>
				<table id="bomTable" lay-filter="bomTable"></table>
			</div>
		</div>
	</div>
</div>



<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-success pear-btn-sm" lay-event="import"><i class="layui-icon layui-icon-upload"></i>导入</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除</button>
	<button class="pear-btn  pear-btn-sm" lay-event="export"><i class="layui-icon layui-icon-export"></i>导出</button>
	<!--
	<button class="pear-btn pear-btn-sm" lay-event="recycle"><i class="layui-icon  layui-icon-close-fill"></i>回收站</button>-->
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<!--
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>-->
</script>
<script type="text/html" id="photo">
{{#  if(d.final_pic && d.final_pic.length > 0){ }}
<a onclick="layerPhotos('{{d.final_pic.join(',')}}','{{ d.id }}')" href="javascript:;"><img src="{{ d.final_pic[0] }}" /> </a>
{{#  } }}
</script>
<script type="text/html" id="bomtoolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>添加零件</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除零件</button>
	<button class="pear-btn pear-btn-success pear-btn-sm" lay-event="import"><i class="layui-icon layui-icon-upload"></i>导入</button>
</script>
<script type="text/html" id="color_follow">
	<input type="checkbox" name="color_follow" value="{{d.id}}" lay-skin="switch" lay-text="是|否" lay-filter="color_follow" {{# if(d.color_follow==1){ }} checked {{# } }}>
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;
		let material_id;

		table.render({
			elem: '#dataTable',
			url: '{:url('component')}?status=1',
			page: true,
			limit:90,
			cols: [[
				{type: 'checkbox'},
				{field: 'sn',title: '物料编码', sort: true,align: 'center',unresize: false,width: {:get_col_width('sn',150)}, hide: getTableFieldIsHide('dataTable','sn')},
				{field: 'name',title: '物料名称', sort: true,align: 'left',unresize: false,width: {:get_col_width('name',250)}, hide: getTableFieldIsHide('dataTable','name')},
				{field: 'cid',title: '物料分类', sort: true,align: 'center',unresize: false,width: {:get_col_width('category_name',120)},templet: function(d){return d.category_name;}, hide: getTableFieldIsHide('dataTable','cid')},
				{field: 'safety_stock',title: '安全库存',align: 'center',unresize: false,width: {:get_col_width('safety_stock')}, hide: getTableFieldIsHide('dataTable','safety_stock')},
				{field: 'min_stock',title: '最低库存',align: 'center',unresize: false,width: {:get_col_width('min_stock',100)}, hide: getTableFieldIsHide('dataTable','min_stock')},
				{field: 'max_stock',title: '最高库存',align: 'center',unresize: false,width: {:get_col_width('max_stock',100)}, hide: getTableFieldIsHide('dataTable','max_stock')},
				{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit',100)}, hide: getTableFieldIsHide('dataTable','unit')},
				{field: 'remark',title: '备注', sort: true,align: 'left',unresize: false,width: {:get_col_width('remark',100)}, hide: getTableFieldIsHide('dataTable','remark')},
				{field: 'photo',title: '图片',align: 'center',unresize: false,width: {:get_col_width('photo',100)},templet: '#photo', hide: getTableFieldIsHide('dataTable','photo')},
				{field: 'status_desc',title: '状态',align: 'center',unresize: false,width: {:get_col_width('status_desc',100)}, hide: getTableFieldIsHide('dataTable','status_desc')},
				{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 80,fixed: 'right'}
			]],
			cellMinWidth: 100,
			height: 'full-240',
			//skin: 'line',
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'remove') {
				layerConfirm('确定要删除该物料?','{:url('remove')}',{ids:[obj.data['id']]},function(res){
					obj.del();
				})
			} else if (obj.event === 'edit') {
				openLayer('修改物料','{:url('componentEdit')}?id='+obj.data['id'],'80%','90%');
			} else if (obj.event === 'photo') {
				layerPhotos(obj.data['photo_link'],obj.data['id'])
			}
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增物料','{:url('componentAdd')}','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些物料','{:url('remove')}',2);
			} else if (obj.event === 'recycle') {
				openLayer('回收站','{:url('recycle')}?type={$type}','80%','90%',function () {
					table.reload('dataTable');
				});
			}else if (obj.event === 'import') {
				openLayer('导入物料','{:url('componentImport')}','90%','90%');
			}else if (obj.event === 'export') {				
				const link = document.createElement("a");
				link.href = '{:url('componentExport')}?'+$("#searchForm").serialize();
				link.click();
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		
		table.on('row(dataTable)',function (obj) {
			window.renderData(obj.data['id'])
		})		
		
		window.renderData = function(id) {
			$(".empty").hide();
			material_id = id
			table.render({
				elem: '#bomTable',
				url: "{:url('erp.MaterialBom/list')}?material_id="+material_id,
				page: true,
				limit:20,
				height: 'full-240',
				cols: [[
					{type: 'checkbox'},
					{field: 'sn',title: '物料编码', sort: true,align: 'center',unresize: false,width: {:get_col_width('sn2',150)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.sn:'';}, hide: getTableFieldIsHide('bomTable','sn')},
					{field: 'name',title: '物料名称', sort: true,align: 'left',unresize: false,width: {:get_col_width('name2',250)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.name:'';}, hide: getTableFieldIsHide('bomTable','name')},
					{field: 'category_name',title: '物料分类', sort: true,align: 'center',unresize: false,width: {:get_col_width('category_name2',120)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.category_name:'';}, hide: getTableFieldIsHide('bomTable','category_name')},
					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.unit:'';}, hide: getTableFieldIsHide('bomTable','unit')},
					{field: 'processing_type',title: '加工类型', sort: true,align: 'center',unresize: false,width: {:get_col_width('processing_type2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.processing_type:'';}, hide: getTableFieldIsHide('bomTable','processing_type')},
					{field: 'material',title: '材料',align: 'center',unresize: false,width: {:get_col_width('material2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.material:'';}, hide: getTableFieldIsHide('bomTable','material')},
					{field: 'surface',title: '表面',align: 'center',unresize: false,width: {:get_col_width('surface2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.surface:'';}, hide: getTableFieldIsHide('bomTable','surface')},
					{field: 'color',title: '颜色', sort: true,align: 'center',unresize: false,width: {:get_col_width('color2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.color:'';}, hide: getTableFieldIsHide('bomTable','color')},
					{field: 'remark',title: '备注', sort: true,align: 'left',unresize: false,width: {:get_col_width('remark2',100)},templet: function(d){return d.relatedMaterial?d.relatedMaterial.remark:'';}, hide: getTableFieldIsHide('bomTable','remark')},
					{field: 'num',title: '数量', edit: 'text',align: 'center',unresize: false,width: {:get_col_width('num2',120)},templet: function(d){return d.num;}, hide: getTableFieldIsHide('bomTable','num')},
					{field: 'color_follow',title: '颜色是否跟随产品',align: 'left',unresize: false,width: {:get_col_width('color_follow2',150)},templet: '#color_follow', hide: getTableFieldIsHide('bomTable','color_follow')}
				]],
				//skin: 'line',
				toolbar: '#bomtoolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter']
			});
		}
		
		
		table.on('toolbar(bomTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('添加零件','{:url('erp.MaterialBom/add')}?table=bomTable&material_id='+material_id,'80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('bomTable');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些零件','{:url('erp.MaterialBom/remove')}');
			}else if (obj.event === 'import') {
				openLayer('导入零件','{:url('erp.MaterialBom/import')}','90%','90%');
			}
		});
		
		form.on('switch(color_follow)', function(data) {
			ajaxActionCall('{:url('erp.MaterialBom/edit')}',{color_follow:data.elem.checked?1:0,id:this.value})
		});
		
		
		table.on('edit(bomTable)', function(obj){
			ajaxActionCall('{:url('erp.MaterialBom/edit')}',{id:obj.data.id,num:obj.value})
		});
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
		table.on('colResized(bomTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'2',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		table.on('colToggled(bomtoolbar)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		
		
	})
</script>
{/block}


