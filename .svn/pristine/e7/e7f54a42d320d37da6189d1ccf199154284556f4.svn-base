{extend name="layout" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<div class="layui-tab layui-tab-brief">
			<ul class="layui-tab-title">
				<a href="{:url('index')}?data_type=1"><li {if $data_type == 1}class="layui-this"{/if}>零件指导书</li></a>
				<a href="{:url('index')}?data_type=2"><li {if $data_type == 2}class="layui-this"{/if}>部件指导书</li></a>
				<a href="{:url('index')}?data_type=3"><li {if $data_type == 3}class="layui-this"{/if}>出厂指导书</li></a>
			</ul>
		</div>		
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<form class="layui-form" action="">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="名称" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="code" placeholder="编码" class="layui-input">	
				</div>				
				<div class="layui-form-item layui-inline">
					<button class="layui-btn layui-btn-md" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
				</div>
			</div>
		</form>	
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="attachment">
	{{#  if(d.is_image){ }}
		<a onclick="layerPhotos(this)" data-href="{{ d.attachment }}" target="_blank" >文件查看</a>
	{{#  }else{ }}
		<a onclick="openLayer('{{ d.name }}','{{ d.attachment }}','80%','80%')" target="_blank" >文件查看</a>
	{{#  } }}
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('index')}?data_type={$data_type}',
			page: true,
			limit:90,
			height:'full-230',
			cols: [[
				{field: 'code',title: '编码',align: 'center',width: {:get_col_width('code')}},
				{field: 'name',title: '名称',align: 'center',width: {:get_col_width('name')}},
				{if $data_type != 3}{field: 'material_category',title: '类型',align: 'center',width: {:get_col_width('material_category')}},{/if}	
				{field: 'version',title: '版本',align: 'center',width: {:get_col_width('version')}},
				{field: 'create_time',title: '创建时间',align: 'center',width: {:get_col_width('create_time',170)}},
				//{field: 'status_desc',title: '状态',align: 'center',width: {:get_col_width('status_desc',100)}},
				{field: 'attachment',title: '操作',align: 'center',width: {:get_col_width('attachment',100)},templet: '#attachment'},
			]],
			cellMinWidth: 100,
			//skin: 'line',
			toolbar: false,
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
	})
</script>
{/block}


