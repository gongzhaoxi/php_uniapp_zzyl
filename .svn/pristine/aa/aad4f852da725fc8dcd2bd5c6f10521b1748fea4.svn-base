{extend name="base" /}
{block name="body"}
{include file="erp/public/warehouse" /}
<style>
.left .layui-inline{width:100px;}
.layui-table-cell {position:relative;}
.layui-table-cell .layui-badge{position:absolute;right:0;top:0;}
</style>
<div class="layui-row layui-col-space10">
	<div class="layui-col-md4">
		<div class="layui-card left">
			<div class="layui-card-body">
				<form class="layui-form" action="">
					<div class="layui-form-item">
						<div class="layui-form-item layui-inline">
							<input type="text" name="batch_number" placeholder="所属入库单编号" class="layui-input">					
						</div>					
						<div class="layui-form-item layui-inline">
							<select name="status">
								<option value="">状态</option>
								{foreach $status as $key=>$vo}
								<option value="{$key}" {if $default_status == $key}selected{/if}>{$vo}</option>
								{/foreach}
							</select>
						</div>						
						<div class="layui-form-item layui-inline" style="width:auto;">
							<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
						</div>
					</div>
				</form>
			</div>
		</div>
		<div class="layui-card">
			<div class="layui-card-body">
				<table id="dataTable" lay-filter="dataTable"></table>
			</div>
		</div>
	</div>
	<div class="layui-col-md8">
		<div class="layui-card">
			<div class="layui-card-body">
				<form class="layui-form" action="" id="searchForm">
					<div class="layui-form-item">
						<div class="layui-form-item layui-inline">
							<input type="text" name="keyword" placeholder="物料编码/名称" class="layui-input">					
						</div>	
						<div class="layui-form-item layui-inline">
							<select name="cid" lay-search>
								<option value="">物料类型</option>
								{foreach $category as $key=>$vo}
								<option value="{$vo['id']}">{$vo['name']}</option>
								{/foreach}
							</select>
						</div>	
						<div class="layui-form-item layui-inline" style="width:200px;">
							<select name="status" xm-select="status" xm-select-height="36px" >
								<option value="">状态</option>
								{foreach $material_status as $key=>$vo}
								<option value="{$key}" {if 1 == $key || 2 == $key}selected{/if}>{$vo}</option>
								{/foreach}
							</select>
						</div>							
						<div class="layui-form-item layui-inline">
							<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="materialQuery"><i class="layui-icon layui-icon-search"></i>查询</button>
							<!-- <button class="pear-btn pear-btn-warming pear-btn-sm" lay-submit lay-filter="print1"><i class="layui-icon layui-icon-file"></i>打印退料单</button> -->
							<button class="pear-btn pear-btn-warming pear-btn-sm" lay-submit lay-filter="print2"><i class="layui-icon layui-icon-table"></i>打印入库单</button>
						</div>
					</div>
				</form>
			</div>
		</div>
		<div class="layui-card">
			<div class="layui-card-body">
				<div class="empty" style="margin-top: 50px;margin-left: 220px;margin-bottom: 80px;" width="184" height="152">
					请点击左边“行”，选择入库单编号，查看明细！
				</div>
				<table id="materialTable" lay-filter="materialTable"></table>
			</div>
		</div>
	</div>
</div>

<script type="text/html" id="materialToolbar">
	<!--<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="export"><i class="layui-icon layui-icon-download-circle"></i>导出</button>-->
	<button class="pear-btn pear-btn-warming pear-btn-sm notice" lay-event="notice"><i class="layui-icon layui-icon-form"></i>发起质检</button>
	<!--<button class="pear-btn pear-btn-warming pear-btn-sm" lay-event="check"><i class="layui-icon layui-icon-form"></i>品检审核</button>-->
	<button class="pear-btn pear-btn-success pear-btn-sm" lay-event="save"><i class="layui-icon layui-icon-edit"></i>保存并增加库存</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="cancel"><i class="layui-icon layui-icon-delete"></i>整批不合格</button>
	<!--<button class="pear-btn  pear-btn-sm" lay-event="return"><i class="layui-icon layui-icon-release"></i>退货</button>-->
	<button class="pear-btn pear-btn-primary  pear-btn-sm" plain="" lay-event="print"><i class="layui-icon layui-icon-print"></i>打印生产退料单</button>
</script>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="cancel">此单作废</button>
	<!--<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="edit">修改</button>-->
	<!--<button class="pear-btn  pear-btn-sm" lay-event="prior">优先</button>-->
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
</script>
<script type="text/html" id="materialTableOptions">
	<div class="layui-btn-group">

		<button class="layui-btn layui-btn-xs" lay-event="report">报告</button>
		<button class="layui-btn  layui-bg-orange layui-btn-xs" lay-event="code">标签</button>
	</div>
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;
		let material_stock_id;
		var order_sn = '';
		var receiving_date = '';

		table.render({
			elem: '#dataTable',
			url: '{:url('back')}?material_type={$material_type}?&status={$default_status}',
			page: true,
			height: 'full-300',
			scrollPos:'fixed',
			cols: [[
				{type: 'radio',unresize: true},
				{field: 'stock_date',title: '入库日期',align: 'center',unresize: false,width: {:get_col_width('stock_date'.$material_type,150)},templet: function(d){return d.tips?(''+d.stock_date+'<span class="layui-badge">已质检</span>'):d.stock_date;}, hide: getTableFieldIsHide('dataTable','stock_date')},
				//{field: 'order_sn',title: '入库单编号',align: 'center',unresize: false,width: {:get_col_width('order_sn'.$material_type,150)}, hide: getTableFieldIsHide('dataTable','order_sn')},
				{field: 'batch_number',title: '所属入库单编号',align: 'center',unresize: false,width: {:get_col_width('batch_number'.$material_type,150)}, hide: getTableFieldIsHide('dataTable','batch_number')},
				{field: 'create_admin',title: '创建人',align: 'center',unresize: false,width: {:get_col_width('create_admin'.$material_type,100)}, hide: getTableFieldIsHide('dataTable','create_admin')},
				{field: 'remark',title: '备注',align: 'center',unresize: false,width: {:get_col_width('remark'.$material_type,150)}, hide: getTableFieldIsHide('dataTable','remark')},
				//{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 60}
			]],
			limit:100,
			limits:[100,200,300,400,500],
			cellMinWidth: 60,
			toolbar: '#toolbar',
			defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
			}, 'filter'],
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'cancel') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				if (checkStatus.data[0].can_cancel == false) {
					layer.msg(checkStatus.data[0].order_sn+'已作废或已结算');
					return false;
				}
				layerConfirm('确认作废?','{:url('cancel')}',{id:checkStatus.data[0]['id']},function(res){
					table.reload('materialTable');
					table.reloadData('dataTable');
					getWarehouseStat();
				})
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			}else if (obj.event === 'finish') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				if (checkStatus.data[0].can_finish == false) {
					layer.msg(checkStatus.data[0].order_sn+'已作废或已结算');
					return false;
				}
				layerConfirm('确认结算?','{:url('settle')}',{id:checkStatus.data[0]['id']},function(res){
					table.reload('materialTable');
					table.reloadData('dataTable');
					getWarehouseStat();
				})
			}else if (obj.event === 'edit') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				if (checkStatus.data[0].can_edit == false) {
					layer.msg(checkStatus.data[0].order_sn+'禁止修改');
					return false;
				}
				openLayer('修改','{:url('edit')}?id='+checkStatus.data[0]['id'],'80%','90%');
			}else if (obj.event === 'prior') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				layerConfirm('确认设为优先?','{:url('prior')}',{id:checkStatus.data[0]['id']},function(res){
					table.reload('materialTable');
					table.reloadData('dataTable');
					getWarehouseStat();
				})
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});


		form.on('submit(materialQuery)', function(data) {
			if(!material_stock_id){
				layui.layer.msg('请先选择入库单');
				return false;
			}
			table.reload('materialTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});		
		
		form.on('submit(print1)', function(data) {
			if(!material_stock_id){
				layui.layer.msg('请先选择入库单');
				return false;
			}
			toPrintPage(2,{id:material_stock_id});
			return false;
		});	
		
		form.on('submit(print2)', function(data) {
			if(!material_stock_id){
				layui.layer.msg('请先选择入库单');
				return false;
			}
			toPrintPage(1,{id:material_stock_id});
			return false;
		});		
		
		table.on('row(dataTable)',function (obj) {
			window.renderData(obj.data)
		})		
		
		window.renderData = function(order) {
			$(".empty").hide();
			material_stock_id = order.id
			order_sn = order.order_sn;
			receiving_date = order.stock_date;
			table.render({
				elem: '#materialTable',
				url: "{:url('material')}?"+$('#searchForm').serialize()+"&material_stock_id="+material_stock_id,
				page: true,
				height: 'full-300',
				limit:100,
				limits:[100,200,300,400,500],
				cols: [[
					{type: 'checkbox'},
					{field: 'sn',title: '物料编码',align: 'center',unresize: false,width: {:get_col_width('sn'.$material_type.'2',150)},templet: function(d){return d.material?d.material.sn:'';}, hide: getTableFieldIsHide('materialTable','sn')},
					{field: 'check_status_desc',title: '质检状态',align: 'center',unresize: false,width: {:get_col_width('check_status_desc'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','check_status_desc')},
					{field: 'name',title: '物料名称',align: 'left',unresize: false,width: {:get_col_width('name'.$material_type.'2',250)},templet: function(d){return d.material?d.material.name:'';}, hide: getTableFieldIsHide('materialTable','name')},
					{field: 'stock',title: '现有库存量',align: 'center',unresize: false,width: {:get_col_width('stock'.$material_type.'2',100)},templet: function(d){return d.stock?d.stock:0;}, hide: getTableFieldIsHide('materialTable','stock')},
					{field: 'warehouse',title: '仓位',align: 'center',unresize: false,width: {:get_col_width('warehouse'.$material_type.'2',100)},templet: function(d){return d.warehouse?d.warehouse.name:'';}, hide: getTableFieldIsHide('materialTable','warehouse')},
					{field: 'stock_num',title: '总需入库量',align: 'center',unresize: false,width: {:get_col_width('stock_num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','stock_num')},
					{field: 'stocked_num',title: '已入库量',align: 'center',unresize: false,width: {:get_col_width('stocked_num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','stocked_num')},
					{field: 'quality_num',title: '待入库量',align: 'center',unresize: false,width: {:get_col_width('quality_num'.$material_type.'2',120)}, hide: getTableFieldIsHide('materialTable','quality_num')},
					{field: 'qualities_num',title: '已检正品量',align: 'center',unresize: false,width: {:get_col_width('qualities_num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','qualities_num')},
					{field: 'defective_num',title: '已检次品量',align: 'center',unresize: false,width: {:get_col_width('defective_num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','defective_num')},
					//{field: 'num',title: '本次正品量',align: 'center',unresize: false,width: {:get_col_width('num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','num')},
					//{field: 'test_num',title: '本次次品量',align: 'center',unresize: false,width: {:get_col_width('test_num'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','test_num')},
					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit'.$material_type.'2',100)},templet: function(d){return d.material?d.material.unit:'';}, hide: getTableFieldIsHide('materialTable','unit')},
					{field: 'category_name',title: '物料分类',align: 'center',unresize: false,width: {:get_col_width('category_name'.$material_type.'2',120)},templet: function(d){return d.material?d.material.category_name:'';}, hide: getTableFieldIsHide('materialTable','category_name')},
					{field: 'material',title: '材料',align: 'center',unresize: false,width: {:get_col_width('material'.$material_type.'2',100)},templet: function(d){return d.material?d.material.material:'';}, hide: getTableFieldIsHide('materialTable','material')},
					{field: 'surface',title: '表面',align: 'center',unresize: false,width: {:get_col_width('surface'.$material_type.'2',100)},templet: function(d){return d.material?d.material.surface:'';}, hide: getTableFieldIsHide('materialTable','surface')},
					{field: 'color',title: '颜色',align: 'center',unresize: false,width: {:get_col_width('color'.$material_type.'2',100)},templet: function(d){return d.material?d.material.color:'';}, hide: getTableFieldIsHide('materialTable','color')},
					{field: 'remark',title: '备注',align: 'center',unresize: false,width: {:get_col_width('remark'.$material_type.'2',120)}, hide: getTableFieldIsHide('materialTable','remark')},
					{field: 'status_desc',title: '状态',align: 'center',unresize: false,width: {:get_col_width('status_desc'.$material_type.'2',100)}, hide: getTableFieldIsHide('materialTable','status_desc')},
					{title: '操作',toolbar: '#materialTableOptions',align: 'center',unresize: true,width: 120}
				]],
				toolbar: '#materialToolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter'],
				done: function(res, curr, count){
					if(count>0 && res['data'][0]['need_check'] == 1){
						$('.layui-table-tool .notice').show();
					}else{
						$('.layui-table-tool .notice').hide();
					}		
				},
			});
		}
		
		
		// 单元格普通编辑事件
		table.on('edit(materialTable)', function(obj){	
			var reg = /^([0-9]*)$/
			var check_result = true;
			if(reg.test(obj.value)) {
				var num =  parseInt(obj.data.stock_num) - parseInt(obj.data.quality_num) - parseInt(obj.data.stocked_num);
				if(parseInt(obj.value) > num){
					layer.msg('最大数量为:'+num);
					check_result = false;
				}
			}else{
				layer.msg('请输入大于0的正整数')
				check_result = false;
			}
			if(check_result == false){
				obj.td.find('.layui-table-cell').html(obj.oldValue);
				obj.td.find('.layui-table-cell .layui-input').val(obj.oldValue);
				var update = {};
				update[obj.field] = obj.oldValue;
				obj.update(update);
			}else{
				console.log(obj);
				
				if(obj.field == 'num'){
					var update = {};
					update['test_num'] = parseInt(obj.data.stock_num) - parseInt(obj.data.quality_num) - parseInt(obj.data.stocked_num) - parseInt(obj.value)  ;
					obj.update(update);
				}
				if(obj.field == 'test_num'){
					var update = {};
					update['num'] = parseInt(obj.data.stock_num) - parseInt(obj.data.quality_num) - parseInt(obj.data.stocked_num) - parseInt(obj.value)  ;
					obj.update(update);
				}
			}
		});		
		
		
		table.on('toolbar(materialTable)', function(obj) {
			if (obj.event === 'export') {
				var index = layui.layer.load(1);
				let column 	= [{text:'物料编码',key:'material.sn'},{text:'物料名称',key:'material.name'},{text:'现有库存量',key:'material.stock'},{text:'总需入库量',key:'stock_num'},{text:'已入库量',key:'stocked_num'},{text:'待入库量',key:'quality_num'},{text:'单位',key:'material.unit'},{text:'物料分类',key:'material.category_name'},{text:'材料',key:'material.material'},{text:'表面',key:'material.surface'},{text:'颜色',key:'material.color'}];
				$.ajax({
					type : "get",
					url : "{:url('material')}?limit=10000&material_stock_id="+material_stock_id,
					data: $('#searchForm').serialize(),
					success : function(data) {
						layui.layer.close(index);
						if (data.count > 0) {
							jsonToExcel(column, [column], data.data, order_sn+'入库物料')
						}else{
							layui.layer.msg('暂无数据');
						}
					}
				});
			
			}else if (obj.event === 'cancel') {
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				var id = [];
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_cancel == true) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].material.sn+'已作废或已全部入库');
						return false;
					}
				}
				
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				layerConfirm('确认作废？','{:url('cancel')}',{'id':material_stock_id,'ids':id},function(){
					table.reload('materialTable');
					table.reloadData('dataTable');
				})
			}else if (obj.event === 'refresh') {
				table.reload('materialTable');
			}else if (obj.event === 'print') {
				if(!material_stock_id){
					layui.layer.msg('请先选择入库单');
					return false;
				}
				/*
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				var ids = [];
				for(var i in checkStatus.data) {
					ids.push(checkStatus.data[i].id);
				}
				*/
				toPrintPage(81,{id:material_stock_id});
				return false;
			}else if (obj.event === 'save') {			
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				var id = [];
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_enter == true) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].material.sn+'未品检或已全部入库或已作废');
						return false;
					}
				}
				
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				layerConfirm('确认保存并增加库存？','{:url('confirm')}',{'id':material_stock_id,'ids':id},function(){
					table.reload('materialTable');
					table.reloadData('dataTable');
					getWarehouseStat();
				})
			}else if (obj.event === 'check') {			
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				var id = [];
				var num = {};
				var test_num = {};			
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_check == true) {
						id.push(checkStatus.data[i].id);
						num[checkStatus.data[i].id] = checkStatus.data[i].num
						test_num[checkStatus.data[i].id] = checkStatus.data[i].test_num
					}else{
						layer.msg(checkStatus.data[i].material.sn+'已全部品检或已作废');
						return false;
					}
				}
				
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				layerConfirm('确认品检审核？','{:url('check')}',{'id':material_stock_id,'ids':id,num:num,defective:test_num},function(){
					table.reload('materialTable');
				})
			}else if (obj.event === 'return') {	
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				var id = [];
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].quality_num > 0) {
						layer.msg(checkStatus.data[i].material.sn+'请先保存入库再退货');
						return false;
					}else if (checkStatus.data[i].defective_num > 0) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].material.sn+'已检次品量为0');
						return false;
					}
				}
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				layerConfirm('确认退货？','{:url('refund')}',{'id':material_stock_id,'ids':id},function(){
					table.reload('materialTable');
					table.reloadData('dataTable');
				})
			}else if (obj.event === 'notice') {			
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				var id = [];			
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_notice == true) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].material.sn+'已发起质检');
						return false;
					}
				}
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				/*
				layerConfirm('确认发起质检？','{:url('notice')}',{'ids':id},function(){
					table.reload('materialTable');
				})
				*/
				
				openLayer('确认发起质检','{:url('notice')}?receiving_date='+receiving_date+'&ids='+id.join(','),'80%','90%');
			}
			
			
		});
		
		
		table.on('tool(materialTable)', function(obj) {
			if (obj.event === 'report') {
				openLayer('检验报告','{:url('erp.MaterialEnterMaterial/report')}?id='+obj.data['id'],'80%','90%');
			} else if (obj.event === 'code') {
				openLayer('标签编码列表','{:url('erp.MaterialEnterMaterial/code')}?id='+obj.data['id'],'80%','90%');
			}
		});			
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'{$material_type}',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
		table.on('colResized(materialTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'{$material_type}2',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		table.on('colToggled(materialTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
	})
</script>
{/block}


