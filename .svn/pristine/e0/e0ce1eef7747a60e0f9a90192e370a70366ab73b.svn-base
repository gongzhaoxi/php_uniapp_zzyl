{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<div class="layui-tab layui-tab-brief">
			<ul class="layui-tab-title">
				<a href="{:url('outsourcing')}"><li >委外入库查询</li>></a>
				<li class="layui-this">出库损耗对比</li
			</ul>
		</div>
		<form class="layui-form" action=""  lay-filter="searchForm" id="searchForm">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="order_date" value="{:date('Y-m-d',strtotime('-15 day'))} 至 {:date('Y-m-d')}"  placeholder="采购日期" class="layui-input rangedate">	
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="order_sn" placeholder="采购单编号" class="layui-input">	
				</div>
				<div class="layui-form-item layui-inline">
					<select name="supplier_id" lay-search>
						<option value="">供应商</option>
						{foreach $supplier as $key=>$vo}
						<option value="{$vo['id']}">{$vo['name']}</option>
						{/foreach}
					</select>
				</div>
				<div class="layui-form-item layui-inline">
					<select name="follow_admin_id" lay-search>
						<option value="">跟进人</option>
						{foreach $admins as $key=>$vo}
						<option value="{$vo['id']}" >{$vo['username']}</option>
						{/foreach}
					</select>
				</div>	
				<div class="layui-form-item layui-inline">
					<select name="process_id">
						<option value="">委外工序</option>
						{foreach $process as $key=>$vo}
						<option value="{$vo['id']}" >{$vo['name']}</option>
						{/foreach}
					</select>
				</div>					
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">

	<button class="pear-btn pear-btn-success pear-btn-xs" lay-event="export">导出</button>
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('outsourcingLoss')}?status=1&order_date={:date('Y-m-d',strtotime('-15 day'))} 至 {:date('Y-m-d')}&type=3',
			page: true,
			height:'full-200',
			totalRow:true,
			cols: [[
				{type: 'checkbox',totalRow: '合计'},
				{field: 'order_sn',title: '采购单编号',align: 'center',width: {:get_col_width('order_sn',150)}},
				{field: 'supplier_name',title: '供应商',align: 'center',width: {:get_col_width('supplier_name',120)}},
				{field: 'process_name',title: '委外工序',align: 'center',width: {:get_col_width('process_name',120)}},
				{field: 'order_date',title: '采购日期',align: 'center',width: {:get_col_width('order_date',120)}},
				{field: 'follow_admin_username',title: '采购跟进人',align: 'center',width: {:get_col_width('follow_admin_username',100)}},
				{field: 'order_material_sn',title: '物料编码',align: 'center',width: {:get_col_width('order_material_sn')}},
				{field: 'order_material_name',title: '物料名称',align: 'center',width: {:get_col_width('order_material_name')}},
				{field: 'apply_num',totalRow: '{{= d.TOTAL_ROW.apply_num }}',title: '采购量',align: 'center',width: {:get_col_width('apply_num',100)}},
				{field: 'warehous_num',totalRow: '{{= d.TOTAL_ROW.warehous_num }}',title: '总入库数量',align: 'center',width: {:get_col_width('warehous_num',100)}},
				{field: 'order_material_unit',title: '单位',align: 'center',width: {:get_col_width('order_material_unit',100)}},
				{field: 'out_order_sn',title: '关联出库单号',align: 'center',width: {:get_col_width('out_order_sn',120)}},			
				{field: 'out_material_sn',title: '出库物料编号',align: 'center',width: {:get_col_width('out_material_sn',120)}},
				{field: 'out_material_name',title: '出库物料名称',align: 'center',width: {:get_col_width('out_material_name',100)}},
				{field: 'num',title: '用量',align: 'center',width: {:get_col_width('num',100)}},
				{field: 'theory_num',totalRow: '{{= d.TOTAL_ROW.theory_num }}',title: '理论用量',align: 'center',width: {:get_col_width('theory_num',100)}},
				{field: 'stock_num',totalRow: '{{= d.TOTAL_ROW.stock_num }}',title: '出库数量',align: 'center',width: {:get_col_width('stock_num',120)}},
				{field: 'out_material_unit',title: '单位',align: 'center',width: {:get_col_width('out_material_unit',140)}},
				{field: 'loss_rate',totalRow: '{{= d.TOTAL_ROW.loss_rate }}',title: '损耗率',align: 'center',width: {:get_col_width('loss_rate',100)}},
			]],
			cellMinWidth: 100,
			//skin: 'line',
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'print') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				var ids = [];
				for(var i in checkStatus.data) {
					ids.push(checkStatus.data[i].enter_material_id);
				}
				toPrintPage(1,{id:ids.join(',')});
			}else if (obj.event === 'export') {
				var data = form.val('searchForm');
				exportData('{:url('outsourcingLossExport')}',data);
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
	})
</script>
{/block}


