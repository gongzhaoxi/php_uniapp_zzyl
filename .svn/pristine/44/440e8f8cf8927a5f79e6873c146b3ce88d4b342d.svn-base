{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<form class="layui-form" action="" id="searchForm">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="code" placeholder="组织码" class="layui-input">
				</div>			
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="名称" class="layui-input">
				</div>
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-success pear-btn-sm" lay-event="import"><i class="layui-icon layui-icon-upload"></i>导入</button>
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>
</script>
{/block}
{block name="script"}
<script>
	var cur_date = '{:date('Y-m-d')}';
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('list')}',
			page: true,
			limit:90,
			height:'full-170',			
			cols: [[
				{field: 'id',title: 'ID', sort: true, align: 'center',unresize: true,width: 80, hide: getTableFieldIsHide('dataTable','id')},
				{field: 'code',title: '组织码', sort: true,align: 'center',unresize: true,width: 100, hide: getTableFieldIsHide('dataTable','code')},
				{field: 'name',title: '名称',align: 'center',unresize: true, hide: getTableFieldIsHide('dataTable','name')},
				{field: 'tel',title: '联系电话',align: 'center',unresize: true,width: 120, hide: getTableFieldIsHide('dataTable','tel')},
				{field: 'contact',title: '联系人',align: 'center',unresize: true,width: 100, hide: getTableFieldIsHide('dataTable','contact')},
				{field: 'address',title: '地址',align: 'center',unresize: true, hide: getTableFieldIsHide('dataTable','address')},
				{field: 'quality_date',title: '质量协议到期日',unresize: true,align: 'center',width: 150,templet: function(d){return d.quality_date&&d.quality_date<=cur_date?('<span style="color:red">'+d.quality_date+'</span>'):d.quality_date;}, hide: getTableFieldIsHide('dataTable','quality_date')}, 
				{field: 'contract_date',title: '质量协议到期日',unresize: true,align: 'center',width: 150,templet: function(d){return d.contract_date&&d.contract_date<=cur_date?('<span style="color:red">'+d.contract_date+'</span>'):d.contract_date;}, hide: getTableFieldIsHide('dataTable','contract_date')}, 
				{field: 'status_desc',title: '状态',align: 'center',unresize: true,width: 80, hide: getTableFieldIsHide('dataTable','status_desc')},
				{field: 'create_time',title: '添加时间',unresize: true,align: 'center',width: 170, hide: getTableFieldIsHide('dataTable','create_time')}, 
				{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 120}
			]],
			cellMinWidth: 100,

			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter', 'print', 'exports']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'remove') {
				layerConfirm('确定要删除该供应商?','{:url('remove')}',{ids:[obj.data['id']]},function(res){
					obj.del();
				})
			} else if (obj.event === 'edit') {
				openLayer('修改供应商','{:url('edit')}?id='+obj.data['id'],'80%','90%');
			}
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增供应商','{:url('add')}','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些供应商','{:url('remove')}');
			} else if (obj.event === 'recycle') {
				openLayer('回收站','{:url('recycle')}','90%','90%',function () {
					table.reload('dataTable');
				});
			}else if (obj.event === 'import') {
				openLayer('导入','{:url('import')}','90%','90%');
			}
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
	})
</script>
{/block}


