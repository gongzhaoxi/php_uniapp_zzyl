{extend name="base" /}
{block name="body"}
<style>
.left .layui-inline{width:100px;}
.layui-table-cell {padding: 6px 5px;}
</style>
<div class="layui-row layui-col-space10">
	<div class="layui-col-md5">
		<div class="layui-card left">
			<div class="layui-card-body">
				<form class="layui-form" action="">
					<div class="layui-form-item">
						<div class="layui-form-item layui-inline">
							<input type="text" name="order_sn" placeholder="采购单编号" class="layui-input">					
						</div>
						<div class="layui-form-item layui-inline">
							<select name="supplier_id" lay-search="">
								<option value="">供应商</option>
								{foreach $supplier as $key=>$vo}
								<option value="{$vo['id']}">{$vo['name']}</option>
								{/foreach}
							</select>				
						</div>						
						<div class="layui-form-item layui-inline">
							<select name="follow_admin_id">
								<option value="">跟进人</option>
								{foreach $admins as $key=>$vo}
								<option value="{$vo['id']}" {if $_admin['id'] == $vo['id']}selected{/if}>{$vo['username']}</option>
								{/foreach}
							</select>
						</div>						
						<div class="layui-form-item layui-inline" style="width:auto;">
							<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
						</div>
					</div>
				</form>
			</div>
		</div>
		<div class="layui-card">
			<div class="layui-card-body">
				<table id="dataTable" lay-filter="dataTable"></table>
			</div>
		</div>
	</div>
	<div class="layui-col-md7">
		<div class="layui-card">
			<div class="layui-card-body">
				<form class="layui-form" action="" id="searchForm">
					<div class="layui-form-item">
						<div class="layui-form-item layui-inline">
							<input type="text" name="keyword" placeholder="物料编码/名称" class="layui-input">					
						</div>							
						<div class="layui-form-item layui-inline">
							<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="materialQuery"><i class="layui-icon layui-icon-search"></i>查询</button>
						</div>
					</div>
				</form>
			</div>
		</div>
		<div class="layui-card">
			<div class="layui-card-body">
				<div class="empty" style="margin-top: 50px;margin-left: 220px;margin-bottom: 80px;" width="184" height="152">
					请点击左边“行”，选择入库单编号，查看明细！
				</div>
				<table id="materialTable" lay-filter="materialTable"></table>
			</div>
		</div>
	</div>
</div>
<script type="text/html" id="toolbar">

</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="cancel">核消</button>
</script>
<script type="text/html" id="toolbarMaterial">
	<button class="pear-btn pear-btn-primary pear-btn-sm"  lay-event="warehous"><i class="layui-icon layui-icon-template-1"></i>委外入库</button>
	<button class="pear-btn pear-btn-success pear-btn-sm"  lay-event="apply"><i class="layui-icon layui-icon-add-1"></i>再次委外</button>	
</script>
<script type="text/html" id="optionsMaterial">
	{{#  if(d.can_remove){ }}<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="cancel">核消</button>{{#  } }}
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;
		let order_id;
		var order_sn = '';

		table.render({
			elem: '#dataTable',
			url: '{:url('outsourcingFollow')}?follow_admin_id={$_admin['id']}',
			page: true,
			height: 'full-170',
			cols: [[
				//{type: 'checkbox',unresize: true},
				{field: 'order_sn',title: '采购单编号',align: 'center',unresize: false,width: {:get_col_width('order_sn',150)}},
				{field: 'supplier_name',title: '供应商',align: 'center',unresize: false,width: {:get_col_width('supplier_name',100)},},
				{field: 'process_name',title: '委外工序',align: 'center',unresize: false,width: {:get_col_width('process_name',100)},},
				{field: 'order_date',title: '采购日期',align: 'center',unresize: false,width: {:get_col_width('order_date',150)}},
				{field: 'overdue_reason',title: '超期原因',align: 'center',unresize: false,width: {:get_col_width('overdue_reason',100)},edit:true},
				{field: 'follow_admin_username',title: '采购跟进人',align: 'center',unresize: false,width: {:get_col_width('follow_admin_name',100)},},
				{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 80,fixed: 'right'}
			]],
			limit:100,
			limits:[100,200,300,400,500],
			cellMinWidth: 60,
			toolbar: '#toolbar',
			defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
			}, 'filter'],
		});

		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'cancel') {
				layerConfirm('是否作废所选的采购单项，作废后将不能恢复，是否继续？?','{:url('cancel')}',{id:obj.data['id']},function(res){
					table.reload('materialTable');
					table.reload('dataTable');
				})
			}else if (obj.event === 'feedback') {
				openLayer('反馈','{:url('feedback')}?id='+obj.data['id'],'80%','90%');
			}
		});	

		table.on('edit(dataTable)', function(obj){
			var field = obj.field; 
			var value = obj.value ;
			var oldValue = obj.oldValue;
			
			var res = $.ajax({
				url: '{:url('editOverdueReason')}',
				type: 'POST',
				data: {id:obj.data.id,'overdue_reason':value},
				dataType: 'json',
				async: false
			});

			layer.msg(res.responseJSON.msg);
			
			if(res.responseJSON.code != 200){
				return obj.reedit();
			}
		});	

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'print') {
				var checkStatus = table.checkStatus('dataTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				var ids = [];
				for(var i in checkStatus.data) {
					ids.push(checkStatus.data[i].id);
				}
				toPrintPage(71,{id:ids.join(',')});
				return false;
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});

		table.on('row(dataTable)',function (obj) {
			window.renderData(obj.data)
		})		
		
		window.renderData = function(order) {
			$(".empty").hide();
			order_id = order.id
			order_sn = order.order_sn;
			table.render({
				elem: '#materialTable',
				url: "{:url('outsourcingData')}?"+$('#searchForm').serialize()+"&no_warehous=1&order_id="+order_id,
				page: true,
				height: 'full-170',
				limit:100,
				limits:[100,200,300,400,500],
				cols: [[
					{type: 'checkbox'},
					{field: 'sn',title: '物料编码',align: 'center',unresize: false,width: {:get_col_width('sn'.'2',150)}},
					{field: 'name',title: '物料名称',align: 'left',unresize: false,width: {:get_col_width('name'.'2',250)}},
					{field: 'apply_num',title: '采购量',align: 'center',unresize: false,width: {:get_col_width('apply_num'.'2',100)}},
					{field: 'warehous_num',title: '已回厂数',align: 'center',unresize: false,width: {:get_col_width('warehous_num'.'2',100)}},
					{field: 're_apply_num',title: '再委外数',align: 'center',unresize: false,width: {:get_col_width('re_apply_num'.'2',100)}},
					{field: 'no_warehous_num',title: '在途数',align: 'center',unresize: false,width: {:get_col_width('no_warehous_num'.'2',100)}},
					{field: 'unit',title: '单位',align: 'center',unresize: false,width: {:get_col_width('unit'.'2',100)}},
					{field: 'material',title: '材料',align: 'center',unresize: false,width: {:get_col_width('material'.'2',100)}},
					{field: 'surface',title: '表面',align: 'center',unresize: false,width: {:get_col_width('surface'.'2',100)}},
					{field: 'color',title: '颜色',align: 'center',unresize: false,width: {:get_col_width('color'.'2',100)}},
					{field: 'delivery_date',title: '要求交货日期',align: 'center',unresize: false,width: {:get_col_width('delivery_date'.'2',120)}},
					{field: 'over_day',title: '超期天数',align: 'center',unresize: false,width: {:get_col_width('over_day'.'2',120)}},
					{title: '操作',toolbar: '#optionsMaterial',align: 'center',unresize: true,width: 80,fixed: 'right'}
				]],
				toolbar: '#toolbarMaterial',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter'],
			});
		}
		

		table.on('toolbar(materialTable)', function(obj) {
			if (obj.event === 'warehous') {
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				var id = [];
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_warehous == true) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].sn+'已全部回厂');
						return false;
					}
				}
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				openLayer('委外入库','{:url('warehous')}?warehous_type=3&ids='+id.join(',')+'&supplier_id='+checkStatus.data[0].supplier_id,'90%','90%');
			}else if (obj.event === 'apply') {
				var checkStatus = table.checkStatus('materialTable');
				if(checkStatus.data.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				
				var id = [];
				for(var i in checkStatus.data) {
					if (checkStatus.data[i].can_warehous == true) {
						id.push(checkStatus.data[i].id);
					}else{
						layer.msg(checkStatus.data[i].sn+'已全部回厂');
						return false;
					}
				}
				if(id.length == 0){
					layer.msg('请选择要操作的内容');
					return false;
				}
				openLayer('再次委外','{:url('outsourcingReapply')}?ids='+id.join(',')+'&supplier_id='+checkStatus.data[0].supplier_id+'&process_id='+checkStatus.data[0].process_id,'90%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('materialTable');
			}
		});
		

		form.on('submit(materialQuery)', function(data) {
			if(!order_id){
				layui.layer.msg('请先选择入库单');
				return false;
			}
			table.reload('materialTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});			
		
		table.on('tool(materialTable)', function(obj) {
			if (obj.event === 'cancel') {
				layerConfirm('是否作废所选的采购单项，作废后将不能恢复，是否继续?','{:url('dataCancel')}',{id:obj.data['id']},function(res){
					table.reload('materialTable');
					table.reload('dataTable');
				})
			}
		});			
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
		table.on('colResized(materialTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field+'2',width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
	})
</script>
{/block}


