--
-- Table structure for table `erp_process`
--

DROP TABLE IF EXISTS `erp_process`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_process` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(100) NOT NULL DEFAULT '' COMMENT '工艺组名称',
  `sn` varchar(50) NOT NULL DEFAULT '' COMMENT '工艺组编码',
  `create_time` int(11) NOT NULL DEFAULT '0',
  `update_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1',
  `sort` int(11) unsigned NOT NULL DEFAULT '50',
  `user_id` text COMMENT '岗位员工id',
  `is_default` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '等于1：前端不能删除',
