--
-- Table structure for table `erp_order_product_bom`
--

DROP TABLE IF EXISTS `erp_order_product_bom`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_product_bom` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单id',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单产品id',
  `product_bom_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT 'erp_product_bom表id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '关联的物料id',
  `material` text,
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT NULL COMMENT '删除时间',
  `bill_type` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '清单类型',
  `num` int(11) unsigned NOT NULL DEFAULT '1' COMMENT '物料数量',
  `type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '1标配2换配3加配4技术添加',
  `replace_product_bom_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '替换的物料erp_product_bom的id，已废弃',
  `replace_material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '已废弃',
  `replace_material` text COMMENT '已废弃',
  `actually_product_bom_id` int(11) NOT NULL DEFAULT '0' COMMENT '实际使用的erp_product_bom表的id，已废弃',
  `actually_material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '已废弃',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=1032 DEFAULT CHARSET=utf8mb4 COMMENT='02-订单产品bom明细表';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_order_product_bom`
--

LOCK TABLES `erp_order_product_bom` WRITE;
/*!40000 ALTER TABLE `erp_order_product_bom` DISABLE KEYS */;
