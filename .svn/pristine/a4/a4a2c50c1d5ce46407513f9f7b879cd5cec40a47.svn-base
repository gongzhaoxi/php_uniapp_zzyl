--
-- Table structure for table `erp_order_aftersale`
--

DROP TABLE IF EXISTS `erp_order_aftersale`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_aftersale` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) NOT NULL COMMENT '订单id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `material_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料数量',
  `material_name` varchar(255) NOT NULL DEFAULT '' COMMENT '物料名称',
  `material_type` tinyint(1) NOT NULL DEFAULT '1' COMMENT '物料类型',
  `material_sn` varchar(255) NOT NULL DEFAULT '' COMMENT '物料编码',
  `material_category` varchar(100) NOT NULL DEFAULT '' COMMENT '物料分类名称',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(11) DEFAULT NULL COMMENT '删除时间',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `pass_down_time` int(10) unsigned NOT NULL DEFAULT '0',
  `order_sn` varchar(100) NOT NULL DEFAULT '',
  `produce_status` tinyint(3) unsigned NOT NULL DEFAULT '10',
  `order_shipping_id` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8mb4 COMMENT='02-订单产品明细表';
/*!40101 SET character_set_client = @saved_cs_client */;

