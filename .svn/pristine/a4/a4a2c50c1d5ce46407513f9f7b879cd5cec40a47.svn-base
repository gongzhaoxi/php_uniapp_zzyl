  `status` tinyint(1) unsigned NOT NULL DEFAULT '1',
  `code` varchar(100) NOT NULL DEFAULT '' COMMENT '供应链组织码',
  `file` text COMMENT '资质证明',
  `token` varchar(100) NOT NULL DEFAULT '',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=84 DEFAULT CHARSET=utf8 COMMENT='00-供货商表';
