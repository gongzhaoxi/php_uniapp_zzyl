DROP TABLE IF EXISTS `erp_product_stat`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_product_stat` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '本月库存',
  `month` varchar(30) NOT NULL DEFAULT '' COMMENT '年月',
  `last_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '上月库存',
  `warehouse_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '本月入仓',
  `sale_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '本月销售',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `num_foreign` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '本月库存(国外)',
  `last_num_foreign` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '上月库存(国外)',
  `warehouse_num_foreign` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '本月入仓(国外)',
  `sale_num_foreign` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '本月销售(国外)',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='成品库存统计';
/*!40101 SET character_set_client = @saved_cs_client */;

