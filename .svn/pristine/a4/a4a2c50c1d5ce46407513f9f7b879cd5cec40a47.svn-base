--
-- Table structure for table `erp_material_enter_material`
--

DROP TABLE IF EXISTS `erp_material_enter_material`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_enter_material` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `material_stock_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT 'erp_material_stock表id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `stock_num` int(11) NOT NULL DEFAULT '0' COMMENT '入库数量',
  `quality_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '未入库正品数量',
  `stocked_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '已入库数量',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `inspection` text COMMENT '品检记录',
  `defective_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '次品数量',
  `qualities_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '已检正品数量',
  `can_out_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '可出库数量',
  `freeze_out_stock` int(11) NOT NULL DEFAULT '0' COMMENT '冻结可出库数量',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '仓位id',
  `check_status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '质检状态',
  `is_prior` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否优先',
  `enter_batch_number` varchar(100) NOT NULL DEFAULT '' COMMENT '入库批次号',
  `purchase_order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '采购单id',
  `purchase_order_data_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '采购单详情id',
  `check_username` varchar(100) NOT NULL DEFAULT '' COMMENT 'QC检验人',
  `check_date` varchar(100) NOT NULL DEFAULT '' COMMENT 'QC检验日期',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=334 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-入库单明细';
/*!40101 SET character_set_client = @saved_cs_client */;

