--
-- Table structure for table `erp_project_bom`
--

DROP TABLE IF EXISTS `erp_project_bom`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_project_bom` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '关联的物料id',
  `color_follow` tinyint(1) NOT NULL DEFAULT '0' COMMENT '颜色是否跟随产品',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT NULL COMMENT '删除时间',
  `bill_type` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '清单类型',
  `can_replace` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '可换配',
  `num` int(11) unsigned NOT NULL DEFAULT '1' COMMENT '物料数量',
  `data_type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '1关联物料2换配物料3加配物料',
  `project_id` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=1431 DEFAULT CHARSET=utf8mb4 COMMENT='01-方案Bom对照表';
/*!40101 SET character_set_client = @saved_cs_client */;

