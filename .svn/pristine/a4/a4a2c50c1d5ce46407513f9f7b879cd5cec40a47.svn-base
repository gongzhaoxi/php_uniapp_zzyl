  `enter_order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '入库单号',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '仓位',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=7 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-盘点物料详情';
