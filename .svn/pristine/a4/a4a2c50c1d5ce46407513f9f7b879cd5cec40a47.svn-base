--
-- Table structure for table `erp_purchase_order_data`
--

DROP TABLE IF EXISTS `erp_purchase_order_data`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_purchase_order_data` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '申购单id',
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `data_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `apply_num` int(11) NOT NULL DEFAULT '0' COMMENT '采购数量',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '状态',
  `delivery_date` varchar(30) NOT NULL DEFAULT '' COMMENT '要求交货日期',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `type` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '1物料2成品',
  `apply_ids` text COMMENT '申购ids',
  `warehous_num` int(11) NOT NULL DEFAULT '0' COMMENT '已回厂数',
  `warehous_date` varchar(30) NOT NULL DEFAULT '' COMMENT '入库日期',
  `warehous_overdue` varchar(255) NOT NULL DEFAULT '' COMMENT '入库时超期天数',
  `material_price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '物料单价',
  `process_id` int(11) unsigned NOT NULL DEFAULT '0',
  `re_apply_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '再委外数',
  `system_id` tinyint(3) NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=159 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='07-采购单明细';
/*!40101 SET character_set_client = @saved_cs_client */;

