--
-- Table structure for table `erp_order_produce`
--

DROP TABLE IF EXISTS `erp_order_produce`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_produce` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单id',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单产品id',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT NULL COMMENT '删除时间',
  `produce_sn` varchar(255) NOT NULL DEFAULT '' COMMENT '排产产品编码',
  `produce_status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '排产状态',
  `check_status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '排查状态',
  `queue_num` smallint(5) unsigned NOT NULL DEFAULT '1' COMMENT '同产品下第几台',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `check_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '排查时间',
  `produce_date` varchar(30) NOT NULL DEFAULT '' COMMENT '下达的排产日期',
  `finish_date` varchar(30) NOT NULL DEFAULT '' COMMENT '完成日期',
  `process_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '当前处于哪个流程',
  `error_time` int(11) unsigned NOT NULL DEFAULT '0',
  `order_shipping_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '发货单id',
  `order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '排产单号',
  `pass_down_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '下达生产的时间',
  `produce_type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '加工方式',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `approve_status` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '审批状态',
  `finish_username` varchar(50) NOT NULL DEFAULT '' COMMENT '完工/入库人',
  `cancel_produce` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否取消生产',
  `report` text COMMENT '产品检测报告',
  `udi` varchar(100) NOT NULL DEFAULT '' COMMENT 'UDI码',
  `version` varchar(100) NOT NULL DEFAULT '' COMMENT '版本号',
  PRIMARY KEY (`id`) USING BTREE,
  KEY `produce_sn` (`produce_sn`(191)) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=22 DEFAULT CHARSET=utf8mb4 COMMENT='03-排产产品表';
