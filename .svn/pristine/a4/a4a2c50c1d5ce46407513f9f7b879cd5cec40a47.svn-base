DROP TABLE IF EXISTS `erp_material_warehouse`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_warehouse` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0',
  `update_time` int(11) unsigned NOT NULL DEFAULT '0',
  `material_id` int(11) NOT NULL DEFAULT '0' COMMENT '物料id',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '仓库id',
  `stock` int(11) NOT NULL DEFAULT '0' COMMENT '库存数量',
  `freeze_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '冻结库存',
  `safety_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '安全库存',
  `min_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '最低库存',
  `max_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '最高库存',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=270 DEFAULT CHARSET=utf8 ROW_FORMAT=COMPACT COMMENT='物料仓库的库存';
