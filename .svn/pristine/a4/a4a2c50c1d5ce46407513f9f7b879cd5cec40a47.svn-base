--
-- Table structure for table `erp_order_produce_bom`
--

DROP TABLE IF EXISTS `erp_order_produce_bom`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_produce_bom` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单id',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单产品id',
  `order_produce_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '排产产品id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '关联的物料id',
  `material_color` varchar(100) NOT NULL DEFAULT '' COMMENT '物料颜色',
  `material_type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '物料类型',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `num` int(11) unsigned NOT NULL DEFAULT '1' COMMENT '需求数量',
  `lack_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '欠缺数量',
  `type` tinyint(3) NOT NULL DEFAULT '1' COMMENT '1为部件或零件2为拆出来的零件',
  `sn` varchar(50) NOT NULL DEFAULT '' COMMENT '唯一码',
  `order_product_bom_id` int(11) unsigned NOT NULL DEFAULT '0',
  `use_num` int(11) NOT NULL DEFAULT '0' COMMENT '默认为需求数量减缺货数量，物料出库审核后扣减',
  `out_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '已出库数量',
  `bill_type` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=11703 DEFAULT CHARSET=utf8mb4 COMMENT='03-排产产品拆解bom表';
/*!40101 SET character_set_client = @saved_cs_client */;

