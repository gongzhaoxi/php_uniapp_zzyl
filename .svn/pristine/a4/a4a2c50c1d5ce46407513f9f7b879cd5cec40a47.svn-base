--
-- Table structure for table `erp_material_allocate_material`
--

DROP TABLE IF EXISTS `erp_material_allocate_material`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_allocate_material` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `material_stock_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT 'erp_material_stock表id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `stock_num` int(11) NOT NULL DEFAULT '0' COMMENT '调拨数量',
  `signed_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '已签收数量',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `enter_material_id` varchar(100) NOT NULL DEFAULT '' COMMENT 'erp_material_enter_material表id',
  `enter_order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '入库单号',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `signed_date` varchar(30) NOT NULL DEFAULT '' COMMENT '签收日期',
  `signed_username` varchar(50) NOT NULL DEFAULT '' COMMENT '签收人',
  `returned_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '退回数量',
  `returned_status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '退库状态',
  `enter_batch_number` varchar(100) NOT NULL DEFAULT '' COMMENT '入库批次号',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=14 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-出库调拨单明细';
/*!40101 SET character_set_client = @saved_cs_client */;

