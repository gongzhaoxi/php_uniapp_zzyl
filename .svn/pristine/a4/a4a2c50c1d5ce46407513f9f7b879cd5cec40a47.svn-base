DROP TABLE IF EXISTS `erp_notice`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_notice` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `admin_id` int(11) NOT NULL DEFAULT '0' COMMENT '管理员id',
  `create_time` int(11) NOT NULL DEFAULT '0' COMMENT '创建时间',
  `viewed_admin_id` text COMMENT '已查看的管理员',
  `notice_admin_id` text COMMENT '接收人',
  `content` text,
  `hits` int(11) NOT NULL DEFAULT '0',
  `file` text COMMENT '附件',
  `auditing_admin_id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '审批人',
  `auditing_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '审批时间',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '0待审批1已审批2驳回',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='公告';
