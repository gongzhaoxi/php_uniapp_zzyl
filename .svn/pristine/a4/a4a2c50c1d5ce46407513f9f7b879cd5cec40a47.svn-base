DROP TABLE IF EXISTS `erp_material_plan`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_plan` (
  `id` int(10) NOT NULL AUTO_INCREMENT COMMENT '订单id',
  `plan_sn` varchar(20) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT '排产批次号',
  `start_date` varchar(50) NOT NULL DEFAULT '' COMMENT '下达日期',
  `type` tinyint(3) unsigned DEFAULT '1' COMMENT '来源类型',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '订单状态',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `create_time` int(10) unsigned DEFAULT NULL COMMENT '下单时间',
  `update_time` int(10) unsigned DEFAULT NULL COMMENT '更新时间',
  `admin` varchar(100) NOT NULL DEFAULT '',
  `num` int(11) unsigned NOT NULL DEFAULT '0',
  `finish_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '入库完成',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `assembled_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '装配完成',
  `inspect_num` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '检验完成',
  `code` text COMMENT '标签',
  `error_time` int(10) unsigned NOT NULL DEFAULT '0',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=2 DEFAULT CHARSET=utf8 COMMENT='部件库存计划表';
/*!40101 SET character_set_client = @saved_cs_client */;

