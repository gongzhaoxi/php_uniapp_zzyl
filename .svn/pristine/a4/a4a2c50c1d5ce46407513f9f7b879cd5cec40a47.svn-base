DROP TABLE IF EXISTS `erp_product_stock`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_product_stock` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单id',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单产品id',
  `order_produce_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '排产产品id',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `is_out_warehouse` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否出仓',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '审核状态',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `type` tinyint(3) NOT NULL DEFAULT '10' COMMENT '数据来源',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '仓库id',
  `stock_date` varchar(30) NOT NULL DEFAULT '' COMMENT '入库日期',
  `purchase_date` varchar(30) NOT NULL DEFAULT '' COMMENT '采购日期',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `username` varchar(30) NOT NULL DEFAULT '' COMMENT '完工/入库人',
  `order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '入库单号',
  `is_returned` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否已退货入库',
  `is_re_produce` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否被再生产',
  `from_product_stock_id` int(11) unsigned NOT NULL DEFAULT '0',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8mb4 COMMENT='产品库存表';
