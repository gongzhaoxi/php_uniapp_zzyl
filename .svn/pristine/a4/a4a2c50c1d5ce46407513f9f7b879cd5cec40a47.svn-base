--
-- Table structure for table `erp_user`
--

DROP TABLE IF EXISTS `erp_user`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_user` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `sn` varchar(50) NOT NULL DEFAULT '' COMMENT '识别码',
  `name` varchar(32) NOT NULL DEFAULT '' COMMENT '姓名',
  `mobile` varchar(32) NOT NULL DEFAULT '' COMMENT '用户电话',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1',
  `login_ip` varchar(30) NOT NULL DEFAULT '' COMMENT '最后登录IP',
  `login_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '最后登录时间',
  `create_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `title` varchar(50) NOT NULL DEFAULT '' COMMENT '职称',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '工位仓默认出库仓位',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `permission` varchar(255) NOT NULL DEFAULT '' COMMENT '权限',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=28 DEFAULT CHARSET=utf8mb4 COMMENT='00-车间手机登陆用户表';
/*!40101 SET character_set_client = @saved_cs_client */;

