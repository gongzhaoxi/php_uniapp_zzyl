DROP TABLE IF EXISTS `erp_order_log`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_log` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) NOT NULL COMMENT '订单id',
  `log` varchar(255) NOT NULL DEFAULT '' COMMENT '日志内容',
  `data_id` int(11) unsigned NOT NULL DEFAULT '0',
  `data_type` varchar(100) NOT NULL DEFAULT '',
  `operator` varchar(255) NOT NULL DEFAULT '' COMMENT '操作者',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(11) DEFAULT NULL COMMENT '删除时间',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=131 DEFAULT CHARSET=utf8mb4 COMMENT='Z-订单日志表';
/*!40101 SET character_set_client = @saved_cs_client */;

