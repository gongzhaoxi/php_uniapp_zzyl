  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `data_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `apply_num` int(11) NOT NULL DEFAULT '0' COMMENT '申购数量',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '状态',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `delivery_date` varchar(30) NOT NULL DEFAULT '' COMMENT '要求交货日期',
  `apply_date` varchar(30) NOT NULL DEFAULT '' COMMENT '申请日期',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `data_type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '数据类型',
  `username` varchar(50) NOT NULL DEFAULT '' COMMENT '申购人',
  `type` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '1物料2成品',
  `process_id` int(11) unsigned NOT NULL DEFAULT '0',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=176 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='07-采购申请表';
/*!40101 SET character_set_client = @saved_cs_client */;

