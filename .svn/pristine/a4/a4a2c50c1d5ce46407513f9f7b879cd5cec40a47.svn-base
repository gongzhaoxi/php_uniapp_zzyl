DROP TABLE IF EXISTS `erp_product_project`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_product_project` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `name` varchar(100) NOT NULL DEFAULT '' COMMENT '方案名称',
  `code` varchar(100) NOT NULL DEFAULT '' COMMENT '方案编号',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT NULL COMMENT '删除时间',
  `cid` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '方案分类',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '方案功能',
  `erp_project_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '方案id',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=1356 DEFAULT CHARSET=utf8mb4 COMMENT='01-产品配置方案表';
