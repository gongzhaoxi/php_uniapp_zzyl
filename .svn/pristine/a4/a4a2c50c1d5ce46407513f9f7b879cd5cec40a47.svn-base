--
-- Table structure for table `erp_order_shipping`
--

DROP TABLE IF EXISTS `erp_order_shipping`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_shipping` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单id',
  `order_product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '订单产品id',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT NULL COMMENT '删除时间',
  `shipping_sn` varchar(255) NOT NULL DEFAULT '' COMMENT '发货单号',
  `shipping_status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '发货状态',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `num` int(11) NOT NULL DEFAULT '0' COMMENT '数量',
  `shipping_num` varchar(100) NOT NULL DEFAULT '' COMMENT '物流单号',
  `shipping_photo` varchar(1000) NOT NULL DEFAULT '' COMMENT '物流单据图片',
  `max_count` int(11) unsigned NOT NULL DEFAULT '0',
  `out_warehouse_time` varchar(30) NOT NULL DEFAULT '' COMMENT '出仓日期',
  `address` varchar(255) NOT NULL DEFAULT '' COMMENT '本次收货地址/人',
  `shipping_date` varchar(30) NOT NULL DEFAULT '' COMMENT '本次发货日期',
  `order_produce_id` varchar(1000) NOT NULL DEFAULT '' COMMENT 'erp_order_produce的id，逗号分隔',
  `admin` varchar(100) NOT NULL DEFAULT '' COMMENT '创建人',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `approve_status` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '审批状态',
  `data_type` tinyint(1) unsigned NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8mb4 COMMENT='06_成品发货单列表';
