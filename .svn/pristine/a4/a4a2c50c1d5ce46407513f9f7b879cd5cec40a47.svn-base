--
-- Table structure for table `erp_follow`
--

DROP TABLE IF EXISTS `erp_follow`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_follow` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `cid` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '随工单用途分类',
  `name` varchar(255) CHARACTER SET utf8mb4 NOT NULL DEFAULT '' COMMENT '随工单名称',
  `code` varchar(255) NOT NULL DEFAULT '' COMMENT '随工单编码',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL,
  `iso` varchar(255) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT 'ISO文件档案号',
  `according` varchar(255) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT '生产依据',
  `remark` varchar(255) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT '备注',
  `address` varchar(255) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT '生产地点',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=2 DEFAULT CHARSET=utf8 COMMENT='随工单';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_follow`
--

LOCK TABLES `erp_follow` WRITE;
/*!40000 ALTER TABLE `erp_follow` DISABLE KEYS */;
INSERT INTO `erp_follow` VALUES (1,124,'椅架随工单','A-001',1715132201,1715132201,NULL,'ZA4-S01-001 A/2','本公司发布的《牙椅综合治疗机生产过程作业指导书》','','置安公司牙科综合治疗机配件班',1,1);
/*!40000 ALTER TABLE `erp_follow` ENABLE KEYS */;
UNLOCK TABLES;

--
-- Table structure for table `erp_follow_item`
--

DROP TABLE IF EXISTS `erp_follow_item`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_follow_item` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `follow_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '随工单id',
  `image` varchar(255) CHARACTER SET utf8mb4 NOT NULL DEFAULT '' COMMENT '图片',
  `title` varchar(255) NOT NULL DEFAULT '' COMMENT '标题',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL,
  `type` tinyint(1) unsigned DEFAULT '1' COMMENT '类型1产品2工序',
  `checked` tinyint(1) unsigned DEFAULT '0' COMMENT '默认选中',
  `is_num` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否带编号组件',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=21 DEFAULT CHARSET=utf8 COMMENT='随工单';
/*!40101 SET character_set_client = @saved_cs_client */;

