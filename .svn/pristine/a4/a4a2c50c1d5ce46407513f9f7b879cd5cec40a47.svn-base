--
-- Table structure for table `erp_supplier_process_bom`
--

DROP TABLE IF EXISTS `erp_supplier_process_bom`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_supplier_process_bom` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '委外物料id',
  `related_material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '出库坯料id',
  `process_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '委外工序',
  `create_time` int(10) NOT NULL COMMENT '创建时间',
  `update_time` int(10) DEFAULT NULL COMMENT '修改时间',
  `delete_time` int(10) DEFAULT '0' COMMENT '删除时间',
  `num` decimal(10,3) unsigned NOT NULL DEFAULT '0.000' COMMENT '用量',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `material_unit` varchar(30) NOT NULL DEFAULT '' COMMENT '委外物料单位',
  `related_material_unit` varchar(30) NOT NULL DEFAULT '' COMMENT '出库坯料单位',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='委外BOM用量';
/*!40101 SET character_set_client = @saved_cs_client */;

