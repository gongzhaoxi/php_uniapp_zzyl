--
-- Table structure for table `erp_order`
--

DROP TABLE IF EXISTS `erp_order`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order` (
  `id` int(10) NOT NULL AUTO_INCREMENT COMMENT '订单id',
  `order_sn` varchar(20) CHARACTER SET utf8mb4 DEFAULT '' COMMENT '订单编号',
  `customer_id` int(11) unsigned DEFAULT '0' COMMENT '客户id',
  `customer_name` varchar(255) NOT NULL DEFAULT '' COMMENT '客户名称/订货单位',
  `region_type` tinyint(3) unsigned DEFAULT '1' COMMENT '订单性质',
  `is_special` tinyint(1) unsigned DEFAULT '0' COMMENT '特殊订单',
  `order_status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '订单状态',
  `contacts` varchar(100) CHARACTER SET utf8mb4 NOT NULL DEFAULT '' COMMENT '联系人',
  `address` varchar(255) CHARACTER SET utf8mb4 NOT NULL DEFAULT '' COMMENT '收货地址/国家',
  `address_short` varchar(255) NOT NULL DEFAULT '' COMMENT '收货地址/国家(英)',
  `phone` varchar(100) CHARACTER SET utf8mb4 NOT NULL DEFAULT '' COMMENT '联系电话',
  `shipping_type` tinyint(1) unsigned DEFAULT '1' COMMENT '发货类型',
  `order_amount` decimal(10,2) DEFAULT '0.00' COMMENT '订单金额',
  `order_product_num` int(10) DEFAULT '0' COMMENT '订单商品数量',
  `shipping_status` tinyint(3) unsigned DEFAULT '10' COMMENT '发货状态',
  `shipping_time` int(10) unsigned DEFAULT '0' COMMENT '最后新发货时间',
  `customer_remark` varchar(255) CHARACTER SET utf8mb4 DEFAULT NULL COMMENT '要求',
  `cancel_time` int(10) DEFAULT NULL COMMENT '订单取消时间',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `create_time` int(10) unsigned DEFAULT NULL COMMENT '下单时间',
  `update_time` int(10) unsigned DEFAULT NULL COMMENT '更新时间',
  `attach_values` text CHARACTER SET utf8mb4 COMMENT '附带的值(赠送时机，赠送积分成长值什么的)Json格式',
  `salesman_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '销售员ID',
  `salesman_name` varchar(100) NOT NULL DEFAULT '' COMMENT '销售员名称',
  `delivery_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '交货日期',
  `produce_status` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '生产状态',
  `order_remark` varchar(255) NOT NULL DEFAULT '' COMMENT '订单备注',
  `cabinet_num` varchar(255) NOT NULL DEFAULT '' COMMENT '装柜号',
  `technical_parameter` varchar(255) NOT NULL DEFAULT '' COMMENT '技术参数',
  `motor_code` varchar(255) NOT NULL DEFAULT '' COMMENT '电机编码',
  `delivery_remark` varchar(255) NOT NULL DEFAULT '' COMMENT '交货要求',
  `technician_approve` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '技术审批状态',
  `salesman_approve` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '销售审批状态',
  `order_type` tinyint(3) unsigned NOT NULL DEFAULT '10' COMMENT '订单类型',
  `data_type` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '数据类型1为销售订单2为售后订单',
  `sale_order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '关联销售单号',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `region` varchar(255) NOT NULL DEFAULT '' COMMENT '区域',
  `region_name` varchar(255) NOT NULL DEFAULT '' COMMENT '区域名称',
  PRIMARY KEY (`id`) USING BTREE,
  UNIQUE KEY `order_sn` (`order_sn`) USING BTREE,
  KEY `customer_id` (`customer_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=29 DEFAULT CHARSET=utf8 COMMENT='02-订单单头总表';
/*!40101 SET character_set_client = @saved_cs_client */;

