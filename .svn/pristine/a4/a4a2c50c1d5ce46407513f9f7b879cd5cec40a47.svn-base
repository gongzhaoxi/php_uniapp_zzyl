--
-- Table structure for table `erp_material_change`
--

DROP TABLE IF EXISTS `erp_material_change`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_change` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `stock_num` int(11) NOT NULL DEFAULT '0' COMMENT '变动数量',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `before_num` int(11) NOT NULL DEFAULT '0' COMMENT '可用库存变动前数量',
  `after_num` int(10) NOT NULL DEFAULT '0' COMMENT '可用库存变动后数量',
  `material_stock_id` int(11) unsigned NOT NULL DEFAULT '0',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `enter_order_sn` varchar(100) NOT NULL DEFAULT '',
  `before_freeze_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '冻结库存更新前数量',
  `after_freeze_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '冻结库存更新后数量',
  `stock_type` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '1为可用库存2为冻结库存',
  `create_admin` varchar(100) NOT NULL DEFAULT '' COMMENT '创建人',
  `warehouse_id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '仓位id',
  `enter_batch_number` varchar(100) NOT NULL DEFAULT '' COMMENT '入库批次号',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=326 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-物料库存变动记录';
/*!40101 SET character_set_client = @saved_cs_client */;

