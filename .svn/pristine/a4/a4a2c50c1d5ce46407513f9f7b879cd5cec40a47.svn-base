--
-- Table structure for table `erp_material_stock_feedback`
--

DROP TABLE IF EXISTS `erp_material_stock_feedback`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_stock_feedback` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `stock_id` int(11) NOT NULL COMMENT '订单id',
  `content` varchar(255) NOT NULL DEFAULT '' COMMENT '反馈内容',
  `type` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '1为平台2为供应商',
  `operator` varchar(255) NOT NULL DEFAULT '' COMMENT '反馈人',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='供应商反馈表';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_material_stock_feedback`
--

LOCK TABLES `erp_material_stock_feedback` WRITE;
/*!40000 ALTER TABLE `erp_material_stock_feedback` DISABLE KEYS */;
/*!40000 ALTER TABLE `erp_material_stock_feedback` ENABLE KEYS */;
UNLOCK TABLES;

--
-- Table structure for table `erp_material_stock_record`
--

DROP TABLE IF EXISTS `erp_material_stock_record`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_stock_record` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `material_stock_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT 'erp_material_stock出入库表头id',
  `data_id` int(11) unsigned NOT NULL DEFAULT '0',
  `data_type` varchar(50) NOT NULL DEFAULT '',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `stock_num` int(11) NOT NULL DEFAULT '0' COMMENT '出库数量',
  `times` int(11) unsigned NOT NULL DEFAULT '1' COMMENT '第几次出库',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=291 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-进出账记录明细';
/*!40101 SET character_set_client = @saved_cs_client */;

