DROP TABLE IF EXISTS `erp_purchase_order_out`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_purchase_order_out` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` int(11) NOT NULL COMMENT '采购单id',
  `order_data_id` int(11) unsigned NOT NULL DEFAULT '0',
  `out_material_id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '出库物料id',
  `num` decimal(10,3) unsigned NOT NULL DEFAULT '0.000' COMMENT '用量',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `theory_num` decimal(10,3) unsigned NOT NULL DEFAULT '0.000' COMMENT '理论用量',
  `stock_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '出库数量',
  `loss_rate` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '损耗率',
  `order_material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '委外物料id',
  `out_order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '关联出库单号',
  `out_material_unit` varchar(30) NOT NULL DEFAULT '' COMMENT '出库坯料单位',
  `order_material_unit` varchar(30) NOT NULL DEFAULT '' COMMENT '委外物料单位',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='委外出库物料';
/*!40101 SET character_set_client = @saved_cs_client */;

