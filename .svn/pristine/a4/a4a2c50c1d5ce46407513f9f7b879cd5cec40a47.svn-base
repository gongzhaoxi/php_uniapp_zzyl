--
-- Table structure for table `erp_material_payout`
--

DROP TABLE IF EXISTS `erp_material_payout`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_payout` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `create_time` int(11) NOT NULL DEFAULT '0',
  `update_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '0',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `num` int(11) NOT NULL DEFAULT '0' COMMENT '数量',
  `total_price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '总金额',
  `price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '单价',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `username` varchar(100) NOT NULL COMMENT '制单操作人',
  `data_type` tinyint(3) unsigned NOT NULL DEFAULT '1',
  `data_id` int(11) unsigned NOT NULL DEFAULT '0',
  `order_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '出入库单号',
  `order_date` varchar(30) NOT NULL DEFAULT '' COMMENT '单据日期',
  `supplier_process` varchar(100) NOT NULL DEFAULT '' COMMENT '委外工序',
  `discount_amount` decimal(10,2) NOT NULL DEFAULT '0.00' COMMENT '折让(优惠)',
  `purchase_order_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '采购单编号',
  `pay_amount` decimal(10,2) NOT NULL DEFAULT '0.00' COMMENT '应款金额',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=29 DEFAULT CHARSET=utf8mb4 ROW_FORMAT=DYNAMIC COMMENT='物料付款金额';
/*!40101 SET character_set_client = @saved_cs_client */;

