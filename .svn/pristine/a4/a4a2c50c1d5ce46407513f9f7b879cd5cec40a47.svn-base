--
-- Table structure for table `erp_purchase_order`
--

DROP TABLE IF EXISTS `erp_purchase_order`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_purchase_order` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `delete_time` int(10) unsigned DEFAULT NULL,
  `status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '状态',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `order_date` varchar(30) NOT NULL DEFAULT '' COMMENT '采购日期',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `follow_admin_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '采购跟进人',
  `type` tinyint(2) unsigned NOT NULL DEFAULT '1' COMMENT '1物料2成品',
  `order_sn` varchar(50) NOT NULL DEFAULT '' COMMENT '采购单号',
  `apply_ids` text COMMENT '申购id',
  `create_admin` varchar(30) NOT NULL DEFAULT '' COMMENT '创建人',
  `delivery_date` varchar(30) NOT NULL DEFAULT '' COMMENT '要求交货日期',
  `supplier_status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '供应商处理状态',
  `overdue_reason` varchar(255) NOT NULL DEFAULT '' COMMENT '超期原因',
  `follow_admin_username` varchar(100) NOT NULL DEFAULT '' COMMENT '跟进人名称',
  `process_name` varchar(100) NOT NULL DEFAULT '' COMMENT '委外工序',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=32 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='07-采购单单头表';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_purchase_order`
--

