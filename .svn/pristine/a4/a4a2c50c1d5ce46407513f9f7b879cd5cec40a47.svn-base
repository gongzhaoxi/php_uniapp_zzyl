--
-- Table structure for table `erp_material`
--

DROP TABLE IF EXISTS `erp_material`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '物料id',
  `cid` int(11) NOT NULL COMMENT '物料分类',
  `sn` varchar(150) NOT NULL DEFAULT '' COMMENT '物料编号',
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '物料名称',
  `stock` int(11) NOT NULL DEFAULT '0' COMMENT '库存数量',
  `freeze_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '冻结中的库存数量',
  `safety_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '安全库存',
  `min_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '最低库存',
  `max_stock` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '最高库存',
  `unit` varchar(255) NOT NULL DEFAULT '' COMMENT '单位',
  `processing_type` varchar(255) NOT NULL DEFAULT '' COMMENT '加工类型',
  `material` varchar(255) DEFAULT '' COMMENT '材料',
  `surface` varchar(255) NOT NULL DEFAULT '' COMMENT '表面',
  `color` varchar(100) NOT NULL DEFAULT '' COMMENT '颜色',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(11) DEFAULT NULL COMMENT '删除时间',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `photo` varchar(255) NOT NULL DEFAULT '' COMMENT '图片',
  `warehouse_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '仓位id',
  `type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '物料分型1零件2部件',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `produce_type` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '生产物料类别',
  `remak2` varchar(255) DEFAULT NULL COMMENT '临时-创建记录备注用',
  `tree_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料树目录id',
  `is_update` tinyint(1) unsigned NOT NULL DEFAULT '0',
  `qc_file` text COMMENT 'QC品检作业指导书',
  `produce_file` text COMMENT '生产作业指导书',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `generality` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '通用性',
  `supplier_id` text COMMENT '供应商',
  `processing_way` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '加工方式',
  `quality_testing_area` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '质检区域',
  `qc_code` varchar(255) NOT NULL DEFAULT '' COMMENT 'QC作业指导书编号和图号',
  PRIMARY KEY (`id`) USING BTREE,
  UNIQUE KEY `sn` (`sn`)
) ENGINE=InnoDB AUTO_INCREMENT=1983 DEFAULT CHARSET=utf8mb4 COMMENT='01-零件&组件物料表';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_material`
--

LOCK TABLES `erp_material` WRITE;
/*!40000 ALTER TABLE `erp_material` DISABLE KEYS */;
