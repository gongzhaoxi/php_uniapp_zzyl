--
-- Table structure for table `erp_supplier_process`
--

DROP TABLE IF EXISTS `erp_supplier_process`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_supplier_process` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(100) NOT NULL DEFAULT '' COMMENT '工艺组名称',
  `sn` varchar(50) NOT NULL DEFAULT '' COMMENT '工艺组编码',
  `create_time` int(11) NOT NULL DEFAULT '0',
  `update_time` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '更新时间',
  `delete_time` int(10) unsigned DEFAULT NULL COMMENT '删除时间',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1',
  `sort` int(11) unsigned NOT NULL DEFAULT '50',
  `supplier_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '供应商id',
  `unit` varchar(30) NOT NULL DEFAULT '' COMMENT '单位',
  `effective_date` varchar(30) NOT NULL DEFAULT '' COMMENT '生效日期',
  `last_price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '上次单价',
  `price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '本次单价',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 ROW_FORMAT=DYNAMIC COMMENT='委外工艺';
/*!40101 SET character_set_client = @saved_cs_client */;

