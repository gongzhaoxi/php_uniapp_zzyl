--
-- Table structure for table `erp_order_produce_error`
--

DROP TABLE IF EXISTS `erp_order_produce_error`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_produce_error` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_produce_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '排产产品id',
  `process_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '流程id',
  `process_name` varchar(100) NOT NULL DEFAULT '' COMMENT '流程名称',
  `create_time` datetime DEFAULT NULL COMMENT '创建时间',
  `error` varchar(255) NOT NULL DEFAULT '' COMMENT '报缺原因/不良说明',
  `photo` varchar(1000) NOT NULL DEFAULT '' COMMENT '附图(检验不良)',
  `type` varchar(20) NOT NULL DEFAULT '' COMMENT '类型',
  `user_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '员工id',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '状态',
  `confirm_date` varchar(50) NOT NULL DEFAULT '' COMMENT '处理日期',
  `username` varchar(100) NOT NULL DEFAULT '' COMMENT '员工名称',
  `material_sn` varchar(100) NOT NULL DEFAULT '' COMMENT '物料编码(缺料中)',
  `material_name` varchar(100) NOT NULL DEFAULT '' COMMENT '物料名称(缺料中)',
  `lack_num` varchar(50) NOT NULL DEFAULT '' COMMENT '报缺数量(缺料中)',
  `check_type` varchar(100) NOT NULL DEFAULT '' COMMENT '检验类型(检验不良)',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=2 DEFAULT CHARSET=utf8mb4 COMMENT='05-报工记录与异常';
/*!40101 SET character_set_client = @saved_cs_client */;

--
-- Dumping data for table `erp_order_produce_error`
--

LOCK TABLES `erp_order_produce_error` WRITE;
