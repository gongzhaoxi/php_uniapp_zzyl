--
-- Table structure for table `erp_order_product`
--

DROP TABLE IF EXISTS `erp_order_product`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_order_product` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '物料id',
  `order_id` int(11) NOT NULL COMMENT '订单id',
  `color` varchar(255) NOT NULL DEFAULT '' COMMENT '颜色',
  `product_sn` varchar(50) NOT NULL DEFAULT '' COMMENT '产品编号',
  `product_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品id',
  `product_num` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '产品数量',
  `product_name` varchar(255) NOT NULL DEFAULT '' COMMENT '产品名称',
  `product_model` varchar(255) NOT NULL DEFAULT '' COMMENT '型号',
  `product_specs` varchar(255) NOT NULL DEFAULT '' COMMENT '款式',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(11) DEFAULT NULL COMMENT '删除时间',
  `status` tinyint(1) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `product_snap` text COMMENT '下单时产品快照',
  `currency` varchar(50) NOT NULL DEFAULT '' COMMENT '币种',
  `exchange_rates` varchar(50) NOT NULL COMMENT '汇率',
  `tax_rate` varchar(50) NOT NULL DEFAULT '' COMMENT '税率',
  `product_price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '单价',
  `total_price` decimal(10,2) unsigned NOT NULL DEFAULT '0.00' COMMENT '产品总价',
  `add_project` varchar(1000) NOT NULL DEFAULT '' COMMENT '加配方案',
  `change_project` varchar(1000) NOT NULL DEFAULT '' COMMENT '改配方案',
  `replace_info` text COMMENT '换标配',
  `product_unit` varchar(50) NOT NULL DEFAULT '',
  `remark` varchar(255) NOT NULL DEFAULT '' COMMENT '备注',
  `project_price` text COMMENT '方案价格',
  `product_stock_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '退库产品库存id',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  `is_pause` tinyint(1) unsigned NOT NULL DEFAULT '0' COMMENT '是否暂停',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=37 DEFAULT CHARSET=utf8mb4 COMMENT='02-订单产品明细表';
/*!40101 SET character_set_client = @saved_cs_client */;

