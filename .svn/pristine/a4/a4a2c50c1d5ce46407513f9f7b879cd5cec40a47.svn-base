--
-- Table structure for table `erp_material_enter_material_report`
--

DROP TABLE IF EXISTS `erp_material_enter_material_report`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!40101 SET character_set_client = utf8 */;
CREATE TABLE `erp_material_enter_material_report` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `create_time` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建时间',
  `update_time` int(11) unsigned DEFAULT '0',
  `material_stock_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT 'erp_material_stock表id',
  `material_enter_material_id` int(11) unsigned NOT NULL DEFAULT '0',
  `material_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '物料id',
  `status` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '状态',
  `code` varchar(255) NOT NULL DEFAULT '' COMMENT '报告编号',
  `effective_date` varchar(255) NOT NULL COMMENT '生效日期',
  `consignee` varchar(255) NOT NULL DEFAULT '' COMMENT '收货人',
  `receiving_date` varchar(255) NOT NULL DEFAULT '' COMMENT '收货日期',
  `inspection_by` varchar(255) NOT NULL DEFAULT '' COMMENT '送检人',
  `inspection_date` varchar(255) NOT NULL DEFAULT '' COMMENT '送检日期',
  `material_category` varchar(255) NOT NULL DEFAULT '' COMMENT '物资类别',
  `inspection_method` varchar(255) NOT NULL DEFAULT '' COMMENT '检验方法',
  `sampling_plan` varchar(255) NOT NULL DEFAULT '' COMMENT '抽样方案',
  `aql` varchar(255) NOT NULL DEFAULT '' COMMENT '接收质量限AQL',
  `inspection_quantity` varchar(255) NOT NULL DEFAULT '' COMMENT '全检数量',
  `sampling_quantity_appearance` varchar(255) NOT NULL DEFAULT '' COMMENT '外观抽样数',
  `sampling_quantity_size` varchar(255) NOT NULL DEFAULT '' COMMENT '尺寸与功能抽样数',
  `sampling_level_appearance` varchar(255) NOT NULL DEFAULT '' COMMENT '抽样水平外观',
  `sampling_level_size` varchar(255) NOT NULL DEFAULT '' COMMENT '抽样水平尺寸与功能',
  `inspection_basis` varchar(255) NOT NULL DEFAULT '' COMMENT '检验依据',
  `inspection_items` varchar(255) NOT NULL DEFAULT '' COMMENT '检验项目',
  `unqualified_description` varchar(255) NOT NULL DEFAULT '' COMMENT '不合格描述',
  `instrument_number` varchar(255) NOT NULL DEFAULT '' COMMENT '检验仪器编号',
  `ng_item` varchar(255) NOT NULL DEFAULT '' COMMENT 'NG项目',
  `ng_num` varchar(255) NOT NULL DEFAULT '' COMMENT 'NG数量',
  `pass_num` varchar(255) NOT NULL DEFAULT '' COMMENT 'OK 数量',
  `pass_rate` varchar(255) NOT NULL DEFAULT '' COMMENT '合格率',
  `inspection_result` varchar(255) NOT NULL DEFAULT '' COMMENT '检验判定结果',
  `inspector_date` varchar(255) NOT NULL DEFAULT '' COMMENT '检验员/日期',
  `approval_date` varchar(255) NOT NULL DEFAULT '' COMMENT '审批/日期',
  `handling_suggestion` varchar(255) NOT NULL DEFAULT '' COMMENT '处理意见',
  `handling_sn1` varchar(255) NOT NULL DEFAULT '' COMMENT '供应商发出来料品质异常联络单',
  `handling_sn2` varchar(255) NOT NULL DEFAULT '' COMMENT '供应商发出来料品质异常联络单',
  `handling_date` varchar(255) NOT NULL DEFAULT '' COMMENT '质管主管/日期',
  `handling_sn3` varchar(255) NOT NULL DEFAULT '',
  `unqualified_num` varchar(255) NOT NULL DEFAULT '' COMMENT '不合格总数',
  `inspector_sign` varchar(255) NOT NULL DEFAULT '' COMMENT '检验员检验员',
  `approval_sign` varchar(255) NOT NULL DEFAULT '' COMMENT '审批检验员',
  `handling_sign` varchar(255) NOT NULL DEFAULT '' COMMENT '质管主管签字',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=332 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='04-入库单明细';
/*!40101 SET character_set_client = @saved_cs_client */;

