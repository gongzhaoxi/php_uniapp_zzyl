  `sn` varchar(100) NOT NULL DEFAULT '' COMMENT '客户编码',
  `name` varchar(100) NOT NULL DEFAULT '' COMMENT '客户名称/订货单位',
  `contacts` varchar(100) NOT NULL DEFAULT '' COMMENT '联系人',
  `phone` varchar(100) NOT NULL DEFAULT '' COMMENT '联系电话',
  `address` varchar(255) NOT NULL DEFAULT '' COMMENT '收货地址/国家',
  `address_en` varchar(255) NOT NULL DEFAULT '' COMMENT '收货地址/国家(英)',
  `region_type` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '域属',
  `status` tinyint(1) NOT NULL DEFAULT '1' COMMENT '状态:1-启用.0-停用',
  `create_time` int(11) DEFAULT NULL COMMENT '创建时间',
  `update_time` int(11) DEFAULT NULL COMMENT '更新时间',
  `delete_time` int(11) DEFAULT NULL COMMENT '删除时间',
  `admin_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '创建人',
  `region` varchar(255) NOT NULL DEFAULT '' COMMENT '区域',
  `invoice_title` varchar(255) NOT NULL DEFAULT '' COMMENT '发票抬头',
  `invoice_code` varchar(255) NOT NULL DEFAULT '' COMMENT '税号',
  `salesman_id` int(11) unsigned NOT NULL DEFAULT '0' COMMENT '所属业务员',
  `system_id` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '系统id',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=191 DEFAULT CHARSET=utf8mb4 COMMENT='文章表';
/*!40101 SET character_set_client = @saved_cs_client */;

