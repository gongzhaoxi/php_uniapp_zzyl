								<td>{$vo['product_specs']}</td>
								<td>
									<div class="layui-row wage-con">
										{if !empty($vo['wage'])}
										{foreach $vo['wage'] as $v}
										<div class="layui-col-xs3 wage" id="wage{$v['process_id']}">
											<div class="layui-row">
												<div class="layui-col-xs5">
													<input type="hidden"  value="{$v['order_produce_id']}" class="order_produce_id">
													<input type="hidden"  value="{$v['process_id']}" class="process_id">
													<input type="hidden"  value="{$v['product_id']}" class="product_id">
													<div class="name"> {$v['process_name']}</div>
												</div>
												<div class="layui-col-xs3">
													<input type="text"  value="{$v['price']}" lay-verify="required" placeholder="请输入" autocomplete="off" class="layui-input price">
												</div>
												<div class="layui-col-xs4">
													<div class="layui-btn-group">
