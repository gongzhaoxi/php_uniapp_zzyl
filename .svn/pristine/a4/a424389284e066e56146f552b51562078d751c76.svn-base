							</thead>
							<tbody>
								{php}$iii=1;{/php}
								{volist name="model['total_material']" id="vo"}
								{if $vo['type'] == 1}
								<tr >
									<td><input type="checkbox" name="material_ids[]" value="{$vo['id']}"  data-ids="{$vo['id']}" title="{$iii}" class="checkbox-filter checkbox-filter2"></td>
									<td>{$vo['sn']}</td>
									<td>{$vo['name']}</td>
									<td>{$vo['stock']}</td>
									<td>{$vo['unit']}</td>
									<td>{$model['dict_data'][$vo['produce_type']]|default=''}</td>
									<td>{$vo['stuff']|default=''}</td>
									<td>{$vo['surface']}</td>
									<td>{$vo['color']}</td>
									<td>{$vo['remark']}</td>
								</tr>
								{php}$iii++;{/php}
								{/if}
								{/volist}
							</tbody>
						</table>
					</div>
