</form>
<div id="production-timeline">
	<div class="layui-card">
		<div class="layui-card-body">
			<ul class="layui-timeline production-timeline">
				{foreach $production as $key=>$vo}
				<li class="layui-timeline-item">
					<i class="layui-icon layui-timeline-axis">&#xe63f;</i>
					<div class="layui-timeline-content layui-text">
						<h3 class="layui-timeline-title">日期：{$vo['produce_date']}  </h3>
						<ul>
							<li>当天产量值：<span class="count">{$vo['produce_num']} 台</span>当天排产总量：<span class="count">{:count($vo['produce'])} 台</span></li>
							<li>当天排产产品(编码)：</li>
						</ul>
						<p>{:implode('、',$vo['produce'])}</p>
					</div>
				</li>
				{/foreach}
			</ul>
		</div>
	</div>
</div>
<div id="production-form">
	<div class="layui-card">
		<div class="layui-card-body">
			<form class="layui-form" action="{:url('setDefaultProduction')}" method="post" data-reload="7" data-callback="reloadLocation" data-noshowmsg="1">
				<div class="layui-form-item">
					<label class="layui-form-label">统一设置</label>
					<div class="layui-input-inline">
						<input type="text" lay-verify="required|number" autocomplete="off" value="{:config('web.default_produce_num')}" name="default_produce_num" placeholder="请输入日产值,不可为空" autocomplete="off" class="layui-input">
					</div>
					<button type="submit" class="layui-btn layui-btn-normal" lay-submit="" lay-filter="*">保存</button>
				</div>
			</form>
			<hr>
			<h2>调整七天内日产值</h2>
			{foreach $production as $key=>$vo}
			<form class="layui-form" action="{:url('setProduction')}" method="post" data-reload="7" data-callback="reloadLocation" data-noshowmsg="1">
				<div class="layui-form-item">
					<label class="layui-form-label">{$vo['produce_date']}<input type="hidden" autocomplete="off"  name="produce_date" value="{$vo['produce_date']}"></label>
					<div class="layui-input-inline">
						<input type="text" maxlength="100" name="produce_num" autocomplete="off" lay-verify="required|number" value="{$vo['produce_num']}" placeholder="请输入日产值,不可为空" autocomplete="off" class="layui-input">
					</div>
					<button type="submit" class="layui-btn layui-btn-normal" lay-submit="" lay-filter="*">保存</button>
				</div>
			</form>
			{/foreach}
		</div>
	</div>
</div>
{/block}
{block name="js"}
<script src="/static/tool/jquery.min.js"></script>
<script src="/static/tool/jQuery.print.min.js"></script>
{/block}
{block name="script"}
<script>
	var lack_produce = {:json_encode($model['lack_produce'])} ;
	layui.use(['table', 'form', 'jquery','common','laydate','tableSelect'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;
		let laydate = layui.laydate;
		let layer = layui.layer;
		let element = layui.element;
		var tableSelect = layui.tableSelect;
		
		element.on('tab(bom-1)', function(data){
			if(data.index == 0){
				$('.select-component').show();
				$('.select-partn').hide();
			}else{
				$('.select-partn').show();
				$('.select-component').hide();
			}
		});
		
		$('.btn button').hide();
		$('.btn .act-1').show();
		$('.btn .select').hide();
  
		//一些事件触发
		element.on('tab(tab)', function(data){
			var n = $(this).data('select');
			var v = $(this).data('selectvalue');
			var t = $(this).data('type');
			$('.btn .select').hide();
			$('.btn button').hide();
			$('.btn .act-'+t).show();

			if(n != 'select-total' && n){
				$('.btn .'+n).show();
				$('.btn .'+n+' select').val(v);
				form.render('select');
			}
			/*
			if(n == ''){
				$('.btn').hide();
			}else if(n == 'select-total'){
				$('.btn').hide();
				$('.btn2').show();
			}else{
				$('.btn').show();
				$('.btn2').hide();
				$('.btn .'+n).show();
				$('.btn .'+n+' select').val(v);
				form.render('select');
			}*/
		});			
		
		
		laydate.render({ 
			elem: '#produce_date',
			type: 'date',
			min: '{:date('Y-m-d')}',
			trigger: 'click',
			done: function(value, date, endDate){
				location.replace('{:url('start')}?id={$id}&produce_date='+value);
			}
		});

		form.on('submit(view)', function(data) {	
			layer.open({
				title:'七天生产周期表',
				type: 1,
				area: ['700px', '80%'],
				content: $('#production-timeline').html()
			});
			return false;
		});
		form.on('submit(set)', function(data) {	
			layer.open({
				title:'设置日产量',
				type: 1,
				area: ['420px'],
				content: $('#production-form').html()
			});
			return false;
		});		
		
		form.on('submit(remove)', function(data) {	
			if($('.remove-div button').length <= 1){
				layer.msg('至少保留一个产品');return false;
			}
			var id = $(this).data('id');
			layer.confirm('确认移除？',function(){
				var arr = '{$id}'.split(",");	
				var ids = [];
				layui.each(arr, function (index, item) {
					if(item != id){
						ids.push(item);
					}
				})
				location.replace('{:url('start')}?id='+ids.join(',')+'&produce_date='+$('#produce_date').val());
			});	
			return false;
		});		
		
		window.reloadLocation = function(res){
			layer.alert(res.msg,{closeBtn:false},function(){
				location.reload();
			});	
		}
		form.on('submit(check)', function(data) {
			/*
			layer.confirm('确认重新排查？',function(){
				var load_index 	= layer.load(2);
				var arr = '{$id}'.split(",");				
				layui.each(arr, function (index, item) {
					$.ajax({
						url: '{:url('check')}?id=' + item,
						success: function (result) {
						
						},
						async: false
					});
				})
				location.reload()
			});	*/
			layerConfirm('确认重新排查？','{:url('check')}',{id:'{$id}'},function(){
				location.reload()
			})
			return false;
		});
		
		form.on('submit(start)', function(data) {
			if(!$('#produce_date').val()){
				layer.msg('请选择排产日期');return false;
			}
			layerConfirm('确认下达生产？','{:url('start')}',{id:'{$id}',produce_date:$('#produce_date').val()},function(){
				location.replace('{:url('view')}?id={$id}');
			})
			return false;
		});		
		
		form.on('submit(out)', function(data) {
			var material_ids = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				var item = $(this).val();
				if(material_ids.indexOf(item) == -1){
					material_ids.push(item);
				}
			})
			if(material_ids.length == 0){
				layer.msg('请选择物料');
				return false;
			}
			layerConfirm('确认申请领料？','{:url('out')}',{id:'{$id}',material_ids:material_ids},function(){
				//location.reload(true);
			})
			return false;
		});		
		
		form.on('submit(plan)', function(data) {
			var material_ids = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				var item = $(this).val();
				if(material_ids.indexOf(item) == -1){
					material_ids.push(item);
				}
			})
			if(material_ids.length == 0){
				layer.msg('请选择物料');
				return false;
			}
			layerConfirm('确认添加计划下达？','{:url('plan')}',{id:'{$id}',material_ids:material_ids},function(){
				//location.reload(true);
			})
			return false;
		});			
		
		form.on('submit(purchase)', function(data) {
			var material_ids = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				var item = $(this).val();
				if(material_ids.indexOf(item) == -1){
					material_ids.push(item);
				}
			})
			if(material_ids.length == 0){
				layer.msg('请选择物料');
				return false;
			}
			
			openLayer('采购申请','{:url('purchaseApply')}?id={$id}&material_ids='+material_ids.join(','),'90%','90%');
			
			//layerConfirm('确认添加采购申请？','{:url('purchaseApply')}',{id:'{$id}',material_ids:material_ids},function(){
				//location.reload(true);
			//})
			return false;
		});			
		
		
		$('.lack_num').click(function(){
			var id = $(this).data('id');		
			var html = '<div style="margin: 20px;"><table  class="layui-table"><thead><tr><th>序号</th><th>产品编码</th><th>欠缺数量</th></tr>';
			var i=1;
			layui.each(lack_produce[id], function (index, item) {
				if(item.lack_num>0){
					html += '<tr><td>'+(i)+'</td><td>'+item.produce_sn+'</td><td>'+item.lack_num+'</td></tr>';
					i++;
				}
				
			})
			html += '</table></div>';
			
			layer.open({
				type: 1, 
				title:$(this).data('sn')+'欠缺数量',
				area: ['500px', '400px'],
				content: html
			});
		})
		
		form.on('submit(print-tag)', function(data) {
			var id = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				id.push($(this).data('ids'));
			})
			if(id.length == 0){
				layer.msg('请选择物料');
				return false;
			}	
			toPrintPage(21,{id:id.join(',')})
			return false;
		});
		
		form.on('submit(print-product-tag)', function(data) {
			toPrintPage(27,{id:'{$id}'})
			return false;
		});	
		
		form.on('submit(print-schedule)', function(data) {
			toPrintPage(25,{id:'{$id}'})
			return false;
		});		
		
		form.on('submit(print-material)', function(data) {
			var ids = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				var item = $(this).data('ids');
				if(ids.indexOf(item) == -1){
					ids.push(item);
				}
			})
			if(ids.length == 0){
				layer.msg('请选择物料');
				return false;
			}
			toPrintPage($('#tab .layui-tab-title .layui-this').data('jmreport'),{id:ids.join(',')})
		});
		
		form.on('submit(print-material3)', function(data) {
			var ids = [];
			$('.layui-show .checkbox-filter:checked').each(function(){
				var item = $(this).data('ids');
				if(ids.indexOf(item) == -1){
					ids.push(item);
				}
			})
			if(ids.length == 0){
				layer.msg('请选择物料');
				return false;
			}
			toPrintPage(29,{id:ids.join(',')})
		});			
		
		
		form.on('submit(print-lack)', function(data) {
			toPrintPage($(data.elem).closest('ul').find('.layui-this').data('jmreport'),{id:'{$id}'})
		});
		
		form.on('select(bill_type)', function(data){
			$('.layui-show .checkbox-filter').prop('checked',false);
			$('#tab .layui-tab-title .layui-this').data('selectvalue',data.value);
			if(data.value){
				$('#tab .layui-tab-content .layui-show .layui-table tbody tr').hide();
				$('#tab .layui-tab-content .layui-show .layui-table .bill_type-'+data.value).show();
			}else{
				$('#tab .layui-tab-content .layui-show .layui-table tr').show();
			}
			form.render('checkbox');	
		});      
		
		form.on('select(produce_type)', function(data){
			$('#tab .layui-tab-title .layui-this').data('selectvalue',data.value);
			if(data.value !== ''){
				$('#tab .layui-tab-content .layui-show .layui-table tbody tr').hide();
				$('#tab .layui-tab-content .layui-show .layui-table .produce_type-'+data.value).show();
			}else{
				$('#tab .layui-tab-content .layui-show .layui-table tr').show();
			}
			$('.layui-show .checkbox-filter').prop('checked',false);
			form.render('checkbox');	
		});		
		
		$('.print').click(function(){
			$("#mtable").print();
		})
		
		
		tableSelect.render({
			elem: '#add_material',
			checkedKey: 'id',
			searchKey: 'keyword',
			searchPlaceholder: '物料名称/编码',
			table: {
				url: '{:url('Common/material')}',		
				cols: [[
					{type: 'radio' },
					{field: 'sn',title: '物料编码',align: 'left',unresize: false,width:300},
					{field: 'name',title: '物料名称',align: 'left',unresize: false,width:300},
					{field: 'type_desc',title: '类型',align: 'left',unresize: false},
				]]
			},
			done: function (elem, data) {
				if($('#add_material_tr'+data.data[0]['id']).length == 0){
					var len = $('#add_material_tbody tr').length + 1;
					var html = '<tr id="add_material_tr'+data.data[0]['id']+'">';
					html += '		<td>'+len+'</td>';	
					html += '		<td class="del">'+data.data[0]['sn']+'</td>';
					html += '		<td>'+data.data[0]['name']+'</td>';
					html += '		<td><div contenteditable="true">1</div></td>';
					html += '		<td>'+data.data[0]['unit']+'</td>';
					html += '		<td><div contenteditable="true"></div></td>';
					html += '	</tr>';
					$('#add_material_tbody').append(html);	
				}
			}
		})
		
		tableSelect.render({
			elem: '#delete_material',
			checkedKey: 'id',
			searchKey: 'keyword',
			searchPlaceholder: '物料名称/编码',
			table: {
				url: '{:url('Common/material')}',		
				cols: [[
					{type: 'radio' },
					{field: 'sn',title: '物料编码',align: 'left',unresize: false,width:300},
					{field: 'name',title: '物料名称',align: 'left',unresize: false,width:300},
					{field: 'type_desc',title: '类型',align: 'left',unresize: false},
				]]
			},
			done: function (elem, data) {
				if($('#delete_material_tr'+data.data[0]['id']).length == 0){
					var len = $('#delete_material_tbody tr').length + 1;
					var html = '<tr id="delete_material_tr'+data.data[0]['id']+'">';
					html += '		<td>'+len+'</td>';	
					html += '		<td class="del">'+data.data[0]['sn']+'</td>';
					html += '		<td>'+data.data[0]['name']+'</td>';
					html += '		<td><div contenteditable="true">1</div></td>';
					html += '		<td>'+data.data[0]['unit']+'</td>';
					html += '		<td><div contenteditable="true"></div></td>';
					html += '	</tr>';
					$('#delete_material_tbody').append(html);	
				}
			}
		})	
		
		
		$("#mtable tbody").on("mouseenter",".del", function(){
			layer.tips('点击物料编号可删除', $(this),{ tips: 3});
		});      
		
		$("#mtable tbody").on("click",".del", function(){
			var tr = $(this).closest('tr');
			var tbody = $(this).closest('tbody');
			layer.confirm('确认删除？', {icon: 3}, function(){
				tr.remove();
				layui.layer.closeAll();
				resetTableInd(tbody)
			});
		}); 
		
		function resetTableInd(tbody){
			var i = 1;
			$(tbody).find('tr').each(function(){
				$(this).find('td').eq(0).html(i);
				i++;
			})
		}
		
		form.on('checkbox(checkbox-filter1)', function(data){
			var bill_type = $('#bill_type_select').val()
			if(bill_type){
				$('.checkbox-filter1').prop('checked',false);
				if(data.elem.checked == true){
					$('.bill_type-'+bill_type+' .checkbox-filter1').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter1').prop('checked',data.elem.checked)
			}
			form.render('checkbox');
		});
		form.on('checkbox(checkbox-filter2)', function(data){
			var produce_type = $('#produce_type_select').val()
			if(produce_type){
				$('.checkbox-filter2').prop('checked',false);
				if(data.elem.checked == true){
					$('.produce_type-'+produce_type+' .checkbox-filter2').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter2').prop('checked',data.elem.checked)
			}
			form.render('checkbox');	
		});		
		form.on('checkbox(checkbox-filter3)', function(data){
			var bill_type = $('#bill_type_select').val()
			if(bill_type){
				$('.checkbox-filter3').prop('checked',false);
				if(data.elem.checked == true){
					$('.bill_type-'+bill_type+' .checkbox-filter3').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter3').prop('checked',data.elem.checked)
			}
			form.render('checkbox');
		});			
		form.on('checkbox(checkbox-filter4)', function(data){
			var produce_type = $('#produce_type_select').val()
			if(produce_type){
				$('.checkbox-filter4').prop('checked',false);
				if(data.elem.checked == true){
					$('.produce_type-'+produce_type+' .checkbox-filter4').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter4').prop('checked',data.elem.checked)
			}
			form.render('checkbox');	
		});			
		form.on('checkbox(checkbox-filter5)', function(data){
			var bill_type = $('#bill_type_select').val()
			if(bill_type){
				$('.checkbox-filter5').prop('checked',false);
				if(data.elem.checked == true){
					$('.bill_type-'+bill_type+' .checkbox-filter5').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter5').prop('checked',data.elem.checked)
			}
			form.render('checkbox');
		});			
		form.on('checkbox(checkbox-filter6)', function(data){
			var produce_type = $('#produce_type_select').val()
			if(produce_type){
				$('.checkbox-filter6').prop('checked',false);
				if(data.elem.checked == true){
					$('.produce_type-'+produce_type+' .checkbox-filter6').prop('checked',data.elem.checked)
				}
			}else{
				$('.checkbox-filter6').prop('checked',data.elem.checked)
			}
			form.render('checkbox');	
		});			
		
		
		$('.add-wage').each(function(){
			var order_produce_id = $(this).data('order_produce_id');
			var product_id = $(this).data('product_id');
			
			var tr = $(this).closest('tr');
			tableSelect.render({
				elem: '#'+$(this).attr('id'),
				checkedKey: 'id',
				searchKey: 'keyword',
				searchPlaceholder: '工序名称/编码',
				table: {
					url: '{:url('common/processWage')}?type=1&product_id='+product_id,		
					cols: [[
						{type: 'checkbox' },
						{field: 'sn',title: '工艺组编码',align: 'center',unresize: true,width:120},
						{field: 'name',title: '工艺组名称',align: 'center',unresize: true},
						{field: 'price',title: '报工单价',align: 'center',unresize: true},
					]]
				},
				done: function (elem, data) {
					var html = '';
					var process_id = [];
					
					$.each(data.data, function(index, item) {
						if(tr.find('#wage'+item.id).length == 0){
							item.order_produce_id = order_produce_id;
							html += getHtml(item);
							process_id.push(item.id);
						}
					});
					
					if(html){
						ajaxActionCall('{:url('erp.OrderProduceProcess/add')}',{order_produce_id:order_produce_id,process_id:process_id,product_id:product_id},function(){
							tr.find('.wage-con').append(html);
						})
					}
				}
			})
		
		})
		
		function getHtml(data){
			var html = '';
			html += '<div class="layui-col-xs3 wage" id="wage'+data.id+'">';
			html += '	<div class="layui-row">';
			html += '		<div class="layui-col-xs5">';
			html += '		<input type="hidden"  value="'+data.order_produce_id+'" class="order_produce_id">';
			html += '			<input type="hidden"  value="'+data.id+'" class="process_id">';
			html += '			<input type="hidden"  value="'+data.product_id+'" class="product_id">';
			html += '			<div class="name">'+data.name+'</div>';
			html += '		</div>';
			html += '		<div class="layui-col-xs3">';
			html += '			<input type="text"  value="'+data.price+'" lay-verify="required|number" placeholder="请输入" autocomplete="off" class="layui-input price">';
			html += '		</div>';
			html += '		<div class="layui-col-xs4">';
			html += '			<div class="layui-btn-group">';
			html += '				<button type="button" class="layui-btn "><i class="layui-icon layui-icon-edit"></i> </button>';
			html += '				<button type="button" class="layui-btn layui-bg-red "><i class="layui-icon layui-icon-delete"></i> </button>';
			html += '			</div>';
			html += '		</div>';
			html += '	</div>';
			html += '</div>';
			return html;
		}
		
		
		$(".wage-con").on("click",".layui-bg-red",function(){
			var obj = $(this).closest(".wage");
			var tr = $(this).closest("tr");
			layer.open({
				shade: false,
				content: '确认删除？',
				btn: ['确定', '取消'],
				yes: function (index) {
					
					ajaxActionCall('{:url('erp.OrderProduceProcess/remove')}',{order_produce_id:obj.find('.order_produce_id').val(),process_id:obj.find('.process_id').val()},function(){
						obj.remove();
						layer.closeAll();
						var ids = [];
						tr.find(".wage").each(function(){
							ids.push($(this).find('.process_id').val());
						})
						tr.find('.add-wage').attr('ts-selected',ids.join(','));	
					})

				}
			});
		});	
		
		
		$(".wage-con").on("click",".layui-icon-edit",function(){
			var obj = $(this).closest(".wage");
			var tr = $(this).closest("tr");
			ajaxActionCall('{:url('erp.OrderProduceProcess/edit')}',{order_produce_id:obj.find('.order_produce_id').val(),process_id:obj.find('.process_id').val(),price:obj.find('.price').val()},function(){
				
			})
		});		
		
	})
</script>
{/block}


