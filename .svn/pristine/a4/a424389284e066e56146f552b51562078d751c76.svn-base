{extend name="base" /}
{block name="body"}
<style>
.pear-btn .layui-icon-delete{font-size: 18px;float: right;}
.red{color:red;}
#production-timeline,#production-form{display:none;}
.production-timeline .count{color: rgb(51, 51, 51);margin-right:20px;}
.production-timeline ul li{color: rgb(153, 153, 153);}
.production-timeline .layui-text p{margin-top:0px;font-size:13px;}
.layui-tab-title .btn{float:right;position: relative;
line-height: 40px;min-width: 65px;padding: 0 15px;text-align: center;cursor: pointer;display: inline-block;vertical-align: middle;font-size: 14px;}
.lack_num {background:red;color:#fff;cursor: pointer;}

.btn .layui-select-title .layui-input {height: 28px;margin-top: -8px;}
.btn .layui-form-select dl dt,.btn .layui-form-select dl dd {line-height: 28px;}
.btn .layui-form-select dl {top: 28px;}
.btn .layui-select-title .layui-input {height: 32px;margin-top: -3px;}
.btn .layui-form-select dl dt,.btn .layui-form-select dl dd {line-height: 32px;}
.btn .layui-form-select dl {top: 32px;}
.btn.layui-select-title .layui-input {height: 38px;margin-top: 0;}
.btn .layui-form-select dl dt,.btn .layui-form-select dl dd {line-height: 38px;text-align: left;}
.btn .layui-form-select dl {top: 38px;}
#mtable>div{width:48%;display:inline-block;float:left;}
#mtable>div:last-child{float:right;}
#mtable th{min-width:40px;}
#mtable td{overflow:auto;}
.layui-tab-content{padding: 0px;}
.layui-tab-title .btn2{float:right;position: relative;line-height: 40px;min-width: 65px;padding: 0 15px;text-align: center;cursor: pointer;display: inline-block;vertical-align: middle;font-size: 14px;}

.wage{margin-bottom:5px;}
.wage .name{padding: 9px 0 !important;line-height: 20px;text-align: center;background: rgb(210, 227, 243);}
.wage button{padding: 0 8px;}
</style>
<form class="layui-form" action="" method="post" lay-filter="form-filter">
	<div class="mainBox">
		<div class="main-container">
			<blockquote class="layui-elem-quote">
				排产产品编码<span class="layui-badge" style="margin-left:10px;">注：排产可选周期最长 7天；</span>
				<div class="layui-form-item" style="float: right; width:715px;margin:0 !important;padding:0 !important; margin-top:-15px !important;">
					<div class="layui-form-item layui-inline">
						<input type="text" name="produce_date" id="produce_date" value="{$produce_date}" autocomplete="off" placeholder="日期" class="layui-input" style="width: 100px;">						
					</div>	
					<button type="button" class="pear-btn pear-btn-md pear-btn-success" lay-submit lay-filter="start"><i class="layui-icon layui-icon-ok-circle"></i>下达生产</button>
					<button type="button" class="pear-btn pear-btn-md pear-btn-danger"  lay-submit lay-filter="check"><i class="layui-icon layui-icon-refresh-3"></i>重新排查</button>
					<button type="button" class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="view"><i class="layui-icon layui-icon-date"></i>查看生产周期表</button>
					<button type="button" class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="set"><i class="layui-icon layui-icon-set-fill"></i>设置日产量</button>
					<button type="button" class="pear-btn pear-btn-warming  pear-btn-md" lay-submit lay-filter="print-product-tag">打印产品标签</button>
					<button type="button" class="pear-btn pear-btn-warming  pear-btn-md" lay-submit lay-filter="print-schedule">打印排产单</button>	
				</div>
			</blockquote>
			<div class="layui-form-item remove-div">
				{volist name="model['produce']" id="vo"}
				<button type="button" plain="" class="pear-btn pear-btn-primary  pear-btn-xs" lay-submit lay-filter="remove" data-id="{$vo['id']}">{$vo['produce_sn']}<i class="layui-icon layui-icon-delete"></i></button>
				{/volist}
			</div>	
			
			<div class="layui-form-item">当天产量值：<span class="red">{$production[0]['produce_num']}</span> 台；当天已排产总量：<span class="red">{:count($production[0]['produce'])}</span> 台；当前选中排产总量：<span class="red">{:count($model['produce'])}</span> 台</div>
			<div class="layui-tab  layui-tab-brief" lay-filter="tab" id="tab">
				<ul class="layui-tab-title">
					<li data-jmreport="22" data-select="select-total" data-type="1" data-selectvalue="" class="layui-this">总表-组件</li>
					<li data-jmreport="26" data-select="select-total" data-type="2" data-selectvalue="" >总表-零件</li>
					<li data-jmreport="22" data-select="select-component" data-type="3" data-selectvalue="">足料-组件</li>
					<li data-jmreport="26" data-select="select-partn" data-type="4" data-selectvalue="">足料-零件</li>
					<li data-jmreport="22" data-select="select-component" data-type="5" data-selectvalue="">欠料-组件</li>
					<li data-jmreport="26" data-select="select-partn" data-type="6" data-selectvalue="">欠料-零件</li>
					<li data-select="">工序工资</li>
					<li data-select="">打印更改配置方案</li>
					<div class="btn" >	
						<div class="layui-input-inline select-component select">
							<select lay-filter="bill_type" id="bill_type_select">
								<option value="">全部类别</option>
								{volist name="bill_type" id="vo"}
								<option value="{$vo['id']}">{$vo['name']}</option>
								{/volist}
							</select>
						</div>
						<div class="layui-input-inline select-partn select" style="display:none;">
							<select lay-filter="produce_type" id="produce_type_select">
								<option value="">全部生产物料类别</option>
								{volist name="produce_type" id="vo"}
								<option value="{$vo['id']}">{$vo['name']}</option>
								{/volist}
								<option value="0">未分类组</option>
							</select>
						</div>
						<button type="button" class="layui-btn layui-btn-xs layui-btn-success act-3 act-4" lay-submit lay-filter="out">申请领料</button>		
						<button type="button" class="layui-btn layui-btn-xs layui-bg-blue act-5" lay-submit lay-filter="plan">计划生产</button>	
						<button type="button" class="layui-btn layui-btn-xs layui-bg-blue act-6" lay-submit lay-filter="purchase">申请采购</button>	
						<button type="button" class="layui-btn layui-btn-warm layui-btn-xs act-3 act-4" lay-submit lay-filter="print-tag">打印标签</button>
						<button type="button" class="layui-btn layui-btn-warm layui-btn-xs act-3 act-4" lay-submit lay-filter="print-material">打印领料单</button>	
						<button type="button" class="layui-btn layui-btn-warm layui-btn-xs act-5 act-6" lay-submit lay-filter="print-material2">打印欠料单</button>	
						<button type="button" class="layui-btn layui-btn-warm layui-btn-xs act-1 act-2" lay-submit lay-filter="print-material3">打印总表</button>
						
					</div>
					
				</ul>	
				<!-- 总表-组件 -->
				
				<div class="layui-tab-content">
					<div class="layui-tab-item layui-show">
						<table class="layui-table component-table">
							<thead>
								<tr>
									<th><input type="checkbox"  title="序号" lay-filter="checkbox-filter1"></th>
									<th>物料编号</th>
									<th>物料名称</th>	
									<th>当前库存</th>								
									<th>单位</th>
																	
									<th>颜色</th>
									<th>备注</th>
								</tr> 
							</thead>
							<tbody>
								{php}$iii=1;{/php}
								{volist name="model['total_material']" id="vo"}
								{if $vo['type'] == 2}
								<tr >
									<td><input type="checkbox" name="material_ids[]" value="{$vo['id']}" data-ids="{$vo['id']}" title="{$iii}" class="checkbox-filter checkbox-filter1"> </td>
									<td>{$vo['sn']}</td>
									<td>{$vo['name']}</td>
									<td>{$vo['stock']}</td>
									<td>{$vo['unit']}</td>
									<td>{$vo['color']}</td>
									<td>{$vo['remark']}</td>
								</tr>
								{php}$iii++;{/php}
								{/if}
								{/volist}
							</tbody>
						</table>
					</div>
					<!-- 总表-零件 -->
					<div class="layui-tab-item">
						<table class="layui-table partn-table">
							<thead>
								<tr>
									<th><input type="checkbox"  title="序号" lay-filter="checkbox-filter2"></th>
									<th>物料编号</th>
									<th>物料名称</th>
									<th>当前库存</th>
									<th>单位</th>
									<th>生产物料类别</th>
									<th>材料</th>
									<th>表面</th>
									<th>颜色</th>
									<th>备注</th>
