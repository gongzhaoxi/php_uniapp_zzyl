{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
{if $model['status'] == 1}
.layui-upload-list .files_tbody button,.uload_files{display:none;}
{/if}
</style>
<form class="layui-form" action="" method="post">
	 <input type="hidden" name="id" value="{$model['id']}" >
	 <div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<label class="layui-form-label">审批人</label>
				<div class="layui-input-block">
					<select name="auditing_admin_id" lay-verify="required" lay-search="" {if $model['status'] == 1}disabled{/if}>
						{foreach $admins as $key=>$vo}
						<option value="{$vo['id']}" {if $model['auditing_admin_id'] == $vo['id']}selected{/if}>{$vo['nickname']}</option>
						{/foreach}
					</select>
				</div>
			</div>				
			<div class="layui-form-item">
				<label class="layui-form-label">接收人</label>
				<div class="layui-input-block">
					<select name="notice_admin_id" lay-verify="required" xm-select="notice_admin" xm-select-search {if $model['status'] == 1}disabled{/if}>
						{foreach $admins as $key=>$vo}
						<option value="{$vo['id']}" {if  in_array($vo['id'],$model['notice_admin_id']) }selected{/if}>{$vo['nickname']}</option>
						{/foreach}
					</select>
				</div>
			</div>			
			<div class="layui-form-item">
				<label class="layui-form-label">通知内容</label>
				<div class="layui-input-block">
					<textarea placeholder="请输入内容" lay-verify="required" name="content" class="layui-textarea" {if $model['status'] == 1}disabled{/if}>{$model['content']}</textarea>
				</div>
			</div>
			<div class="layui-form-item">
				<label class="layui-form-label">附件</label>
				<div class="layui-input-block">
					{:$form->files('file',$model['file'])}
				</div>
			</div>			
		</div>
	</div>       
	<div class="bottom">
		<div class="button-container">
			{if $model['status'] != 1}
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
			{/if}
		</div>
    </div>
</form>
{/block}
