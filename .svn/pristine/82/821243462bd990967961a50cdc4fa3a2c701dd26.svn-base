const { http } = uni.$u
export const apiList = (params, config = {}) => http.get('/process/list', Object.assign({params:params},config))
export const apiAdd = (params, config = {}) => http.post('/process/add', params, config)
export const apiFollow = (params, config = {}) => http.get('/process/follow', Object.assign({params:params},config))
export const apiFollowSave = (params, config = {}) => http.post('/process/followAdd', params, config)
export const apiErrorAdd = (params, config = {}) => http.post('/process/errorAdd', params, config)



