{extend name="base" /}
{block name="body"}
<style>
.layui-tab-content .layui-tab-content {
	padding: 15px;
}
</style>
<div class="mainBox">
	<div class="main-container">
		<blockquote class="layui-elem-quote">产品信息</blockquote>
		<form class="layui-form" action="" method="post" data-reload="2">
			<input type="hidden" value="{$model['id']}" name="id">
			<input type="hidden"value="{$model['product_id']}" id="product_id">
			<div class="layui-form-item">
				<div class="layui-row">
					<div class="layui-col-md3">
						<label class="layui-form-label">产品名称</label>			
						<div class="layui-form-mid layui-word-aux">{$model['product_name']}</div>
					</div>
					<div class="layui-col-md3">
						<label class="layui-form-label">型号</label>
						<div class="layui-form-mid layui-word-aux">{$model['product_model']}</div>
					</div>
					<div class="layui-col-md3">
						<label class="layui-form-label">款式</label>
						<div class="layui-form-mid layui-word-aux">{$model['product_specs']}</div>
					</div>		
					<div class="layui-col-md3">
						<label class="layui-form-label">颜色</label>
						<div class="layui-form-mid layui-word-aux">{$model['color']}</div>
					</div>					
				</div>
			</div>
			<div class="layui-form-item">
				<div class="layui-row">
					<div class="layui-col-md3">
						<label class="layui-form-label">数量</label>
						<div class="layui-form-mid layui-word-aux">{$model['product_num']}</div>
					</div>
					<div class="layui-col-md3">
						<label class="layui-form-label">单价</label>
						<div class="layui-form-mid layui-word-aux">{$model['product_price']}</div>
					</div>
					<div class="layui-col-md3">
						<label class="layui-form-label">总价</label>
						<div class="layui-form-mid layui-word-aux">{$model['total_price']}</div>
					</div>					
				</div>
			</div>	
		</form>
		<blockquote class="layui-elem-quote">配置信息</blockquote>
			<div class="layui-tab layui-tab-brief">
				<ul class="layui-tab-title">
					<li >换配</li>
					<li>加配</li>
					<li class="layui-this">销售增改方案</li>
					<li>特殊配置</li>
				</ul>
				<div class="layui-tab-content">
					<div class="layui-tab-item">
						<table class="layui-table">
							<colgroup>
								<col width="30%">
								<col width="30%">
								<col width="30%">
							</colgroup>
							<thead>
								<tr>
									<th>物料编号</th>
									<th>物料名称</th>
									<th>类型</th>
									<th>数量</th>
								</tr>
							</thead>
							<tbody >		
								{foreach $model->bom as $key=>$vo}
									{if $vo['type'] == 2}
									<tr>
										<td>{$vo['material']['sn']}</td>
										<td>{$vo['material']['name']}</td>
										<td>{$bill_type[$vo['bill_type']]['name']|default=''}</td>
										<td>{$vo['num']}</td>
									</tr>
									{/if}
								{/foreach}
							</tbody>
						</table>
					</div>
					<div class="layui-tab-item">
						<table class="layui-table">
							<colgroup>
								<col width="25%">
								<col width="45%">
								<col width="15%">
								<col width="15%">
							</colgroup>							
							<thead>
								<tr>
									<th>物料编号</th>
									<th>物料名称</th>
									<th>类型</th>
									<th>数量</th>
								</tr>
							</thead>
							<tbody >		
								{foreach $model->bom as $key=>$vo}
									{if $vo['type'] == 3 }
									<tr>
										<td>{$vo['material']['sn']}</td>
										<td>{$vo['material']['name']}</td>
										<td>{$bill_type[$vo['bill_type']]['name']|default=''}</td>
										<td>{$vo['num']}</td>
									</tr>
									{/if}
								{/foreach}
							</tbody>
						</table>
					</div>
					<div class="layui-tab-item  layui-show">
						<form class="layui-form" action="{:url('saveBom')}" method="post" data-reload="3">
							<input type="hidden" value="{$model['id']}" name="id">						
							<div class="layui-tab  layui-tab-card">
								<ul class="layui-tab-title">
									<li class="layui-this">换标配</li>
									<li>改配置</li>
									<li>加配置</li>
									<li><button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>修改配置</button></li>
								</ul>
								<div class="layui-tab-content">
									<div class="layui-tab-item layui-show">
										<button type="button" class="layui-btn layui-btn-normal layui-btn-sm add-replace" >增加</button>
										<table class="layui-table">
											<colgroup>
												<col width="15%">
												<col width="25%">
												<col width="15%">
												<col width="25%">
												<col width="10%">
												<col width="10%">
											</colgroup>
											<thead>
												<tr>
													<th colspan="2">标配物料信息</th>
													<th colspan="2">替换物料信息</th>
													<th rowspan="2">类型</th>
													<th rowspan="2">操作</th>
												</tr>
												<tr>
													<th>物料编号</th>
													<th>名称</th>
													<th>物料编号</th>
													<th>名称</th>
										
												</tr>
											</thead>
											<tbody id="replaceDiv">		
												
											</tbody>
										</table>
									</div>
									<div class="layui-tab-item">
										<button type="button" class="layui-btn layui-btn-normal layui-btn-sm change-add" >增加</button>
										<table class="layui-table">
											<thead>
												<tr>
													<th>方案分类</th>
													<th>方案</th>
													<th>操作</th>
												</tr>
											</thead>
											<tbody id="changeDiv">		
												
										
											</tbody>
										</table>
									</div>					
									<div class="layui-tab-item">
										<button type="button" class="layui-btn layui-btn-normal layui-btn-sm add-add" >增加</button>
										<table class="layui-table">
											<thead>
												<tr>
													<th>方案分类</th>
													<th>方案</th>
													<th>操作</th>
												</tr>
											</thead>
											<tbody id="addDiv">		
												
										
											</tbody>
										</table>
									</div>
								</div>
							</div>
						</form>
					</div>					
					<div class="layui-tab-item">
						<form class="layui-form" action="" method="post" data-reload="3">
							<input type="text" readonly id="related_material_name" lay-verify="required" ts-selected="" placeholder="增加物料" autocomplete="off" class="layui-input">
							<table class="layui-table">
								<colgroup>
									<col width="15%">
									<col width="30%">
									<col width="10%">
									<col width="15%">
									<col width="10%">
									<col width="10%">
								</colgroup>							
								<thead>
									<tr>
										
										<th>物料编号</th>
										<th>物料名称</th>
										<th>需求数量</th>
										<th>类型</th>
										<th>部件属性</th>
										<th>来源</th>
										<th>操作</th>
									</tr>
								</thead>
								<tbody id="addDiv22">		
									{foreach $model->bom as $key=>$vo}	
										<tr>
											<td>{$vo['material']['sn']}</td>
											<td>{$vo['material']['name']}</td>										
											<td><input type="text" value="{$vo['num']}" class="num layui-input" /></td>
											<td>
												<select name="bill_type" lay-verify="required" class="bill_type">
													{foreach $bill_type as $key2=>$vo2}
													<option {if $vo2['id'] == $vo['bill_type']}selected{/if} value="{$vo2['id']}">{$vo2['name']}</option>
													{/foreach}
												</select>
											</td>
											<td>
												{$vo['material']['type']==1?'零件':'部件'}
												<input type="hidden" value="{$vo['id']}" class="id" />
												<input type="hidden" value="{$vo['type']}" class="type" />
												<input type="hidden" value="{$vo['product_bom_id']}" class="product_bom_id" />
												<input type="hidden" value="{$vo['replace_product_bom_id']}" class="replace_product_bom_id" />												
												<input type="hidden" value="{$vo['material_id']}" class="material_id" />
											</td>
											<td>{$vo['type_desc']}</td>
											<td>
												<button type="button" onclick="deleteBom(this,{$vo['id']})" class="layui-btn  layui-btn-danger layui-btn-xs">删除</button>
												<button type="button" onclick="saveBom(this)" class="layui-btn layui-btn-xs">保存</button>
											</td>
										</tr>
									{/foreach}
								</tbody>
							</table>	
						</form>		
					</div>
				</div>
			</div>	
	</div>
</div>

{/block}
{block name="script"}
<script>
var bill_type = {:json_encode($bill_type)} ;
var category = {:json_encode($category)} ;
var bom = [];
var default_bom = {:json_encode($model['bom'])} ;
var project1 = [];
var project2 = [];
var category1 = [];
var category2 = [];
var default_replace_info = {:json_encode($model['replace_info'])} ;
var default_change_project = {:json_encode($model['change_project'])} ;
var default_add_project = {:json_encode($model['add_project'])} ;


layui.use(['tableSelect'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect,form = layui.form;
	
	tableSelect.render({
		elem: '#related_material_name',
		checkedKey: 'id',
		searchKey: 'keyword',
		searchPlaceholder: '物料名称/编码',
		table: {
			url: '{:url('Common/material')}',		
			cols: [[
				{type: 'radio' },
				{field: 'sn',title: '物料编码',align: 'left',unresize: false,width:300},
				{field: 'name',title: '物料名称',align: 'left',unresize: false,width:300},
				{field: 'type_desc',title: '类型',align: 'left',unresize: false},
			]]
		},
		done: function (elem, data) {
			var html = '<tr>';
			html += '		<td><input type="hidden" name="type" class="type" value="4" ><input type="hidden" name="material_id" class="material_id" value="'+data.data[0]['id']+'" >'+data.data[0]['sn']+'</td>';	
			html += '		<td>'+data.data[0]['name']+'</td>';
			html += '		<td><input type="text" name="num" value="1" lay-verify="required|nunmber"  placeholder="" autocomplete="off" class="layui-input num"></td>';
			html += '		<td>'+getBillTypeHtml('','','add_bom_bill_type')+'</td>';
			html += '		<td>'+data.data[0]['type_desc']+'</td>';
			html += '		<td>技术加配</td>';
			html += '		<td><button type="button" onclick="deleteBom(this,\'\')" class="layui-btn  layui-btn-danger layui-btn-xs">删除</button><button type="button" onclick="saveBom(this)" class="layui-btn layui-btn-xs">保存</button></td>';
			html += '	</tr>';
			$('#addDiv22').prepend(html);	
			
			//$('.mainBox').animate({ scrollTop: 9999999 }, 500);
			
			form.render();
		}
	})
	
	
	window.deleteBom = function(obj,id){
		if(id&&id>0){
			layerConfirm('确认删除？','{:url('removeBom')}',{'id':id},function(){
				location.reload();
			})
		}else{
			$(obj).closest('tr').remove();
		}
	}		
	
	window.saveBom = function(obj){
		var tr 		= $(obj).closest('tr');
		var type 	= tr.find('.type').val();
		var data 	= {};
		if(type == 2){
			data 	= {'type':type,'order_id':'{$model['order_id']}','order_product_id':'{$model['id']}','product_bom_id':tr.find('.product_bom_id').val(),'id':tr.find('.id').val(),'num':tr.find('.num').val(),'replace_product_bom_id':tr.find('.replace_product_bom_id').val(),'bill_type':tr.find('.bill_type').val()}
		}
		if(type == 1){
			data 	= {'type':type,'order_id':'{$model['order_id']}','order_product_id':'{$model['id']}','product_bom_id':tr.find('.product_bom_id').val(),'id':tr.find('.id').val(),'num':tr.find('.num').val(),'replace_product_bom_id':tr.find('.replace_product_bom_id').val(),'bill_type':tr.find('.bill_type').val()}
		}
		if(type == 3){
			data 	= {'type':type,'order_id':'{$model['order_id']}','order_product_id':'{$model['id']}','product_bom_id':tr.find('.product_bom_id').val(),'id':tr.find('.id').val(),'num':tr.find('.num').val(),'bill_type':tr.find('.bill_type').val()}
		}
		if(type == 4){
			data 	= {'type':type,'order_id':'{$model['order_id']}','order_product_id':'{$model['id']}','material_id':tr.find('.material_id').val(),'id':tr.find('.id').val(),'num':tr.find('.num').val(),'bill_type':tr.find('.bill_type').val()}
		}
		ajaxActionCall('{:url('technicianEdit')}',data,function(){
			location.reload();
		})
	}
	

	function getBillTypeHtml(bom_id,bom_bill_type,name){
		var html = '<select name="'+name+'['+bom_id+']" lay-verify="required">';
		layui.each(bill_type, function (index, item) {
			if(item.id == bom_bill_type){
				html += '<option selected value="'+item.id+'">'+item.name+'</option>';
			}else{
				html += '<option value="'+item.id+'">'+item.name+'</option>';
			}
		})
		html += '</select>';
		return html;
	}
	
	window.confirmReplace = function(obj){
		if($(obj).closest('.layui-form').find('option').length == 0){
			layui.layer.msg('无物料可换');return ;
		}
		var selected_option = $(obj).closest('.layui-form').find('option:selected');
		var data = {};
		data.id = selected_option.val();
		data.sn = selected_option.data('sn');
		data.name = selected_option.data('name');
		data.bill_type = selected_option.data('bill_type');
		var html = getReplaceHtml(data);
		
		$('#replaceDiv').append(html);	
		form.render();
		
		layui.layer.closeAll();
	}
	
	function getReplaceHtml(data){
		var id 	= data.id;
		var html = '<tr id="addTr'+id+'">';
		html += '		<td>'+data.sn+'<input type="hidden" value="'+id+'" name="replace_bom_id[]"  /></td>';
		html += '		<td>'+data.name+'</td>';
		
		html += '			<td><select lay-verify="required" name="replace_bom_value['+id+']"  lay-filter="replace_bom_value"  >';	
		var first_name = '';

		layui.each(bom, function (index, item) {
			if(item.data_type == 2 && item.material.status == 1 && item.bill_type == data.bill_type){
				if(data.value && data.value == item.id){
					first_name = item.material.name;
					html += 		'<option data-sn="'+item.material.sn+'" selected data-name="'+item.material.name+'"  value="'+item.id+'">'+item.material.sn+item.material.name+'</option>';
				}else{
					html += 		'<option data-sn="'+item.material.sn+'" data-name="'+item.material.name+'"  value="'+item.id+'">'+item.material.sn+item.material.name+'</option>';
				}
				first_name = first_name?first_name:item.material.name;
			}
		})
		html += '			</select></td>';	
		html += '		<td>'+first_name+'</td>';
		html += '		<td>'+getBillTypeHtml(id,data.bill_type,'replace_bom_bill_type')+'</td>';
		html += '		<td><button type="button" onclick="deleteReplace('+id+')" class="layui-btn  layui-btn-danger layui-btn-xs">删除</button></td>';
		html += '	</tr>';
		return html;
	}
	
	
	window.deleteReplace = function(id){
		$('#addTr'+id).remove();
	}
	
	$('.add-replace').click(function(){
		if(!$('#product_id').val()){
			layui.layer.msg('请先选择产品');return ;
		}
		var html = '<div class="layui-form form-container" style="margin:20px;">';		
		html += '		<div class="layui-form-item">';	
		html += '			<select lay-verify="required"  >';	
		layui.each(bom, function (index, item) {
			if(item.data_type == 1 && item.can_replace == 1 && item.material.status == 1 && $('#addTr'+item.id).length == 0){
				html += 		'<option data-sn="'+item.material.sn+'" data-cid="'+item.material.cid+'" data-name="'+item.material.name+'" data-bill_type="'+item.bill_type+'" value="'+item.id+'">'+item.material.sn+'/'+item.material.name+'</option>';
			}
		})
		html += '			</select>';	
		html += '		</div>';
		html += '		<div class="bottom"><div class="button-container"><button onclick="confirmReplace(this)" type="button" class="layui-btn">确认</button><button type="button" onclick="layui,layer.closeAll()" class="layui-btn layui-btn-primary">关闭</button></div></div>';
		html += '	</div>';

		layer.open({
			type: 1,
			title:'请选择要更换的标配物料信息',
			area: ['80%', '80%'], 
			closeBtn: 0,
			 shadeClose: true, 
			content: html
		});
		form.render();	
		return ;
	})
	
	
	
	window.confirmAdd = function(obj){
		if($(obj).closest('.layui-form').find('option').length == 0){
			layui.layer.msg('无物料可加');return ;
		}
		var selected_option = $(obj).closest('.layui-form').find('option:selected');
		var data = {};
		data.cid = selected_option.val();
		data.name = selected_option.html();
		var html = getAddHtml(data);
		$('#addDiv').append(html);	
		form.render();
		layui.layer.closeAll();
	}	
	
	function getAddHtml(data){
		var cid = data.cid;
		var html = '<tr class="cid'+cid+'">';
		html += '		<td>'+data.name+'</td>';
		html += '		<td><select lay-verify="required" name="add_project_id[]"  lay-filter="add_project_id"  >';	
		
		layui.each(project2, function (index, item) {
			if(item.cid == cid){
				if(data.value && data.value == item.id){
					html += 		'<option selected value="'+item.id+'">'+item.name+'</option>';
				}else{
					html += 		'<option value="'+item.id+'">'+item.name+'</option>';
				}	
			}
		})
		html += '			</select></td>';	
		html += '		<td><button type="button" onclick="deleteAdd(this)" class="layui-btn  layui-btn-danger layui-btn-xs">删除</button></td>';
		html += '	</tr>';
		return html;
	}
	
	
	$('.add-add').click(function(){
		if(!$('#product_id').val()){
			layui.layer.msg('请先选择产品');return ;
		}
		var html = '<div class="layui-form form-container" style="margin:20px;">';		
		html += '		<div class="layui-form-item">';	
		html += '			<select lay-verify="required"  >';	
		layui.each(category2, function (index, item) {
			if($('#addDiv .cid'+item).length == 0){
				html += 		'<option value="'+item+'">'+category[item]['name']+'</option>';
			}
		})
		html += '			</select>';	
		html += '		</div>';
		html += '		<div class="bottom"><div class="button-container"><button onclick="confirmAdd(this)" type="button" class="layui-btn">确认</button><button type="button" onclick="layui,layer.closeAll()" class="layui-btn layui-btn-primary">关闭</button></div></div>';
		html += '	</div>';

		layer.open({
			type: 1,
			title:'请选择方案分类',
			area: ['80%', '80%'], 
			closeBtn: 0,
			shadeClose: true, 
			content: html
		});
		form.render();	
		return ;		
	})
	
	window.deleteAdd = function(obj){
		$(obj).closest('tr').remove();
	}	
	

	window.confirmChange = function(obj){
		if($(obj).closest('.layui-form').find('option').length == 0){
			layui.layer.msg('无方案可加');return ;
		}
		var selected_option = $(obj).closest('.layui-form').find('option:selected');
		var data = {};
		data.cid = selected_option.val();
		data.name = selected_option.html();
		var html = getChangeHtml(data);
		$('#changeDiv').append(html);	
		form.render();
		layui.layer.closeAll();
	}	
	
	
	$('.change-add').click(function(){
		if(!$('#product_id').val()){
			layui.layer.msg('请先选择产品');return ;
		}
		var html = '<div class="layui-form form-container" style="margin:20px;">';		
		html += '		<div class="layui-form-item">';	
		html += '			<select lay-verify="required"  >';	
		layui.each(category1, function (index, item) {
			if($('#changeDiv .cid'+item).length == 0){
				html += 		'<option value="'+item+'">'+category[item]['name']+'</option>';
			}
		})
		html += '			</select>';	
		html += '		</div>';
		html += '		<div class="bottom"><div class="button-container"><button onclick="confirmChange(this)" type="button" class="layui-btn">确认</button><button type="button" onclick="layui,layer.closeAll()" class="layui-btn layui-btn-primary">关闭</button></div></div>';
		html += '	</div>';

		layer.open({
			type: 1,
			title:'请选择方案分类',
			area: ['80%', '80%'], 
			closeBtn: 0,
			shadeClose: true, 
			content: html
		});
		form.render();	
		return ;		
	})
	
	window.deleteChange = function(obj){
		$(obj).closest('tr').remove();
	}

	function getChangeHtml(data){
		var cid = data.cid;
		var html = '<tr class="cid'+cid+'">';
		html += '		<td>'+data.name+'</td>';
		html += '		<td><select lay-verify="required" name="change_project_id[]"  lay-filter="change_project_id"  >';	
		
		layui.each(project1, function (index, item) {
			if(item.cid == cid){
				if(data.value && data.value == item.id){
					html += 		'<option selected value="'+item.id+'">'+item.name+'</option>';
				}else{
					html += 		'<option value="'+item.id+'">'+item.name+'</option>';
				}	
			}
		})
		html += '			</select></td>';	
		html += '		<td><button type="button" onclick="deleteChange(this)" class="layui-btn  layui-btn-danger layui-btn-xs">删除</button></td>';
		html += '	</tr>';
		return html;
	}


	
	$.ajax({
		url:'{:url('product')}?id={$model['product_id']}&limit=1',
		dataType: 'json',
		success: function(data){	
			bom = data.data[0]['bom'];
			project1 = [];
			project2 = [];
			
			layui.each(data.data[0]['project'], function (index, item) {
				if(item.type == 1){
					project1.push(item);
					if(category1.indexOf(item.cid) == -1){
						category1.push(item.cid);
					}
				}else if(item.type == 2){
					project2.push(item);
					if(category2.indexOf(item.cid) == -1){
						category2.push(item.cid);
					}
				}
			})
			
			if(default_replace_info && default_replace_info.replace_bom_id){
				var html = '';
				layui.each(default_replace_info.replace_bom_id, function (idx, id) {
					layui.each(bom, function (index, item) {
						if(item.id == id){
							var data = {};
							data.id = item.id;
							data.sn = item.material.sn;
							data.name = item.material.name;
							data.value = default_replace_info.replace_bom_value[item.id];
							data.bill_type = default_replace_info.replace_bom_bill_type[item.id];
							html += getReplaceHtml(data);
						}
					})			
				})
				$('#replaceDiv').append(html);	
				
			}
			
			if(default_change_project && default_change_project.length > 0){			
				var html = '';
				layui.each(default_change_project, function (idx, id) {
					layui.each(project1, function (index, item) {
						if(item.id == id){
							var data = {};
							data.cid = item.cid;
							data.name = category[item.cid]['name'];
							data.value = item.id;
							html += getChangeHtml(data);
						}
					})				
				})	
			
				$('#changeDiv').append(html);	
			}
			
			if(default_add_project && default_add_project.length > 0){			
				var html = '';
				layui.each(default_add_project, function (idx, id) {
					layui.each(project2, function (index, item) {
						if(item.id == id){
							var data = {};
							data.cid = item.cid;
							data.name = category[item.cid]['name'];
							data.value = item.id;
							html += getAddHtml(data);
						}
					})
				
				})	
				$('#addDiv').append(html);	
			}			
			
			
			form.render();
		},
		error : function() {
			alert('失败。');
		}
	});		
	
	

	
	form.on('select(replace_bom_value)', function(data){
		$(data.elem).closest('tr').find('td').eq(3).html($(data.elem).find('option:selected').data('name'));
		form.render();		
	});		

	
	

});
</script>
{/block}