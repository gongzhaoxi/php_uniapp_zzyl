{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 160px;}
.layui-form-label {width: 130px;}
</style>
 <div class="mainBox">
	<div class="main-container">
		<form class="layui-form" action="" data-reload="2">
			<div style="margin-bottom:20px;">
				<button type="submit" class="layui-btn  layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-edit layui-font-12"></i>保存信息</button>
				<button type="button" class="layui-btn  layui-btn-warm layui-btn-sm print1" lay-submit="" lay-filter="print1"><i class="layui-icon layui-icon-print layui-font-12"></i>打印“国内”发货通知单</button>
				<button type="button" class="layui-btn  layui-btn-warm layui-btn-sm print2" lay-submit="" lay-filter="print2"><i class="layui-icon layui-icon-print layui-font-12"></i>打印“国外”发货通知单</button>
				<div class="layui-input-inline">本次收货地址/人</div>
				<div class="layui-input-inline">
					<input type="text" name="address" required  value="{$model['address']}" lay-verify="required" placeholder="请输入" autocomplete="off" class="layui-input">
				</div>
				<div class="layui-input-inline">本次发货日期</div>
				<div class="layui-input-inline">
					<input type="text" name="shipping_date" required value="" lay-verify="required" placeholder="请输入" autocomplete="off" class="layui-input date">
				</div>				
			</div>

			<table class="layui-table">
				<thead>
					<tr>
						<th>序号</th>
						<th>物料编码</th>
						<th>物料名称</th>
						<th>分类</th>
						<th>类别</th>
						<th>数量</th>
						<th>状态</th>
					</tr> 
				</thead>
				<tbody>
					{foreach $model->orderAftersale as $k1=>$v1}
					<tr>
						<td>
							{if $v1['can_notice_shipping']}
							<input type="checkbox" name="aftersale_id[]"  class="print_id" lay-skin="primary" value="{$v1['id']}" title="{$k1+1}">
							{elseif $v1['order_shipping_id']/}
							<input type="checkbox"  class="print_id"  lay-skin="primary" value="{$v1['id']}" title="{$k1+1}">
							{else /}
							{/if}
						</td>
						<td>{$v1['material_sn']}</td>
						<td>{$v1['material_name']}</td>
						<td>{$v1['material_category']}</td>
						<td>{$v1['material_type_desc']}</td>
						<td>{$v1['material_num']}</td>	
						<td>
							{if $v1['order_shipping_id']}
								{$v1['shipping']['shipping_status_desc']}
							{else /}
								未通知
							{/if}
						</td>
					</tr>
					{/foreach}
				</tbody>
			</table>
		</form>
	</div>
</div>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		form.on('checkbox(all)', function(data){
			$('.product_id_'+data.value).prop("checked",data.elem.checked);
			form.render('checkbox');
		});

		$('.print1').click(function(){
			var chk_value =[];//定义一个数组
			$('.print_id:checked').each(function(){
				chk_value.push($(this).val());
			});

			if(chk_value.length == 0){
				layer.msg('请选择物料');return false;
			}
			toPrintPage(43,{order_id:{$model['id']},'detail_id':chk_value.join(',')})
			return false;
		
		})


		$('.print2').click(function(){
			var chk_value =[];//定义一个数组
			$('.print_id:checked').each(function(){
				chk_value.push($(this).val());
			});

			if(chk_value.length == 0){
				layer.msg('请选择物料');return false;
			}
			toPrintPage(44,{order_id:{$model['id']},'detail_id':chk_value.join(',')})
			return false;
		})
		
	})
</script>
{/block}
