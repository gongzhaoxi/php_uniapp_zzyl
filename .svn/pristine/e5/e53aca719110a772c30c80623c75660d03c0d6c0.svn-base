{extend name="base" /}
{block name="body"}
<style>
.t_aling_l{text-align: left !important;}
.t_aling_r{text-align: right !important;}
.session1_1{text-align: center;}
.session2 table,.layui-table td,.layui-table th{border-color: #333;color: #000; text-align: center;}
.content{font-weight:600;line-height:30px;font-size:14px;}
.m_top_i_eleven{ margin: 0; margin-top: -11px !important;}
.m_top_i_one{ margin: 0; margin-top: -1px !important;}
.input_no_bro{border: none;}
/* .layui-form-radio{float: left;} */
.layui-form-radio>*{font-size:12px !important ;}
input.height25{ height: 25px !important;}
.font_w_b{font-weight: bold;}.
.l{float: left;}
.r{float: right;}
/* .mainBox{padding-bottom:5px !important;} */
.div_bor_b{border-bottom: 1px solid #000;}
.floer{width: 100%; height:40px; line-height: 40px;text-align: center; overflow: hidden;}
.padding_o{padding: 0 !important;}
.padding_tblr,.padding_tblr td{padding:2px;}
.padding_tb_o, .padding_tb_o td{padding-top: 0 !important;padding-bottom: 0 !important;}
.layui-form-radio{ margin: 0 !important;}
.padding_ab{padding:2px;}
.layui-form-radio:hover>*, .layui-form-radioed, .layui-form-radioed>i{ color: #000;}
.font_s8{-webkit-text-size-adjust: none;font-size:11px;}
.layui-table th{ padding: 0 !important;}
.session3>div>table>tbody>tr>td{padding: 0 !important;}
.session6>div>table>tbody>tr>td .layui-form-radio{line-height: 25px !important; padding-rihgt: 5 !important;}
.session7>div>table>tbody>tr>td .layui-form-radio{line-height: 25px !important; padding-rihgt: 5 !important;}
.session7>div>table>tbody>tr>td .layui-form-checked[lay-skin=primary]>i{border-color: #333 !important;color: #000 !important;background-color:#FFF !important; }
.session7>div>table>tbody>tr>td>div.layui-form-checkbox[lay-skin=primary]>div{padding-right: 0 !important;}
.session7 label{float: left;}
.sign-input {display: inline;width: auto;height: auto;}
.session2 .layui-table td,.session2 .layui-input{padding: 0px !important;}
.session2 .ccssaa td input.input_no_bro{padding-left: 3px !important; }
.bottom {
  position: fixed;
}
.floer {
  margin-bottom: 50px;
}

@media print {
	.no-print {
		display: none;
	}
	.layui-input,.layui-textarea{
		border:none;
	}
	.floer {
	  margin-bottom: 0px;
	}	
}
.page{page-break-before: always;}
</style>
<form class="layui-form" action="" method="post" data-reload="7" data-callback="cb" onkeydown="if(event.keyCode === 13) return false;">
	<input type="hidden" name="id" value="{$produce['id']}" >
	<input type="hidden" name="produce_sn" value="{$produce['produce_sn']}" >
	<input type="hidden" name="process_id" value="{$process['id']}" >
	{php}
	function getUserFieldValue($filed){
		if(!empty($produce['report'][$filed])){
			return $produce['report'][$filed];
		}
		if(!empty($userInfo['name'])){
			return $userInfo['name'];
		}
		return '';
	}
	{/php}
	<div class="">
		<div class="main-container">
			{if !empty($bg) || $page == 1}
			<div class="page" id="page1">
				<div class="session1">
					<div class="layui-row session1_1">
						<img src="/static/index/images/logo_product.png" style="width: 100px; margin: 0 auto;"/>
						<h2>产品档案<br/>生产过程及检验记录</h2>
					</div>
					<table class="layui-table session1_1">
						<colgroup>
							<col width="200">
							<col />
						</colgroup>
						<tr>
							<td><strong>产品序列号</strong></td>
							<td><strong>{$produce['produce_finish_sn']|default=''}</strong></td>
						</tr>
						<tr>
							<td ><strong>产品名称</strong></td>
							<td><strong>牙科综合治疗机</strong></td>
						</tr>
						<tr>
							<td><strong>型号</strong></td>
							<td><strong>{$produce['order_product']['product_model']|default=''}</strong></td>
						</tr>
						<tr>
							<td><strong>产品档案内容</strong></td>
							<td><strong>生产记录、重要物资、过程检验<br/>出厂检验、使用量具、产品放行、UDI标签</strong></td>
						</tr>
						<tr>
							<td><strong>完工日期（生产日期）</strong></td>
							<td><strong>{if !empty($all_process[4]['confirm_date'])}{:date('Y年m月d日',strtotime($all_process[4]['confirm_date']))}{/if}</strong></td>
						</tr>
					</table>
					<table class="layui-table session1_1">
						<colgroup>
							<col width="80">
							<col />
							<col width="80">
							<col />
						</colgroup>
						<tr>
							<td>列号</td>
							<td>档案名称</td>
							<td>列号</td>
							<td>档案名称</td>
						</tr>
						<tr>
							<td>1</td>
							<td>整机随工单及组件随工单</td>
							<td>4</td>
							<td>使用量具（工具）清单</td>
						</tr>
						<tr>
							<td>2</td>
							<td>生产过程检验报告</td>
							<td>5</td>
							<td>产品放行确认表</td>
						</tr>
						<tr>
							<td>3</td>
							<td>产品出厂检验报告</td>
							<td>6</td>
							<td>UDI标签</td>
