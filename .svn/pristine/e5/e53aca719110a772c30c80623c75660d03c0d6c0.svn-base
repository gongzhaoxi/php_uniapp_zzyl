					<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*">保存</button>
					{if empty($bg)}
						{if $page > 1}<a class="layui-btn layui-btn-sm" href="{:url('')}?produce_sn={$produce['produce_sn']}&id={$produce['id']}&process_id={$process['id']}&page={$page-1}" >上一页</a>{/if}
						{if $page < 8}<a class="layui-btn layui-btn-sm" href="{:url('')}?produce_sn={$produce['produce_sn']}&id={$produce['id']}&process_id={$process['id']}&page={$page+1}" >下一页</a>{/if}
					{else}
						<a class="layui-btn layui-btn-sm bg-pre" href="javascript:;" >上一页</a>
						<a class="layui-btn layui-btn-sm bg-next" href="javascript:;" >下一页</a>
					{/if}
				</div>
			</div>
		</div>
	</div>
</form>

<div class="layui-form-item layui-hide" >
	<select id="warehouse_id_select">
		{if !empty($warehouse)}
		{foreach $warehouse as $vo}
		<option value="{$vo['id']}">{$vo['name']}</option>
		{/foreach}
		{/if}
	</select>
</div>

<script src="/static/tool/jquery.min.js"></script>
{/block}
{block name="script"}
<script>
var is_end = {$process['is_end']};
var cur_page = {$page};
var cur_date = '{:date('Y年m月d日')}';
layui.use(['form', 'jquery'], function() {
	let form = layui.form;
	let $ = layui.jquery;
	window.cb = function(info,data){
		if($(data.elem).data('form_url')){
			parent.location.reload();
		}
	}
	$('.rework-add').click(function(){
		openLayer('检验报告','{:url('reworkAdd')}?order_produce_id={$produce['id']}','80%','90%');
	})
	$('.follow-edit').click(function(){
		openLayer('随工单列表','{:url('followEdit')}?order_produce_id={$produce['id']}','80%','90%');
	})
	
	$('.udi').click(function(){
		openLayer('UDI标签上传','{:url('udi')}?id={$produce['id']}','80%','90%');
	})	
	
	$('.bg-pre').click(function(){
		if(cur_page > 1){
			cur_page = cur_page - 1;
			location = '#page'+cur_page;
		}
	})
	
	$('.bg-next').click(function(){
		if(cur_page < 8){
			cur_page = cur_page + 1;
			location = '#page'+cur_page;
		}
	})

	form.on('submit(finish)', function (data) {
		if(is_end == 1){
			layui.layer.open({
				type: 1,
				area: ['500px', '300px'],
				title: '入库仓库',
				content: '<form class="layui-form layui-padding-3" lay-filter="test"><select name="warehouse_id" id="warehouse_id">'+$('#warehouse_id_select').html()+'</select> <div style="margin-top:20px;" class="layui-form-item"><button class="layui-btn layui-btn-fluid confirm" type="button">确认</button></div></form>',
				success: function (layero) {
					form.render(layero.find('.layui-form select'));
					layero.find('.confirm').click(function(){
						var warehouse_id = layero.find('#warehouse_id').val();
						if(warehouse_id){
							data.field.warehouse_id = warehouse_id;
							formSubmit(data)
						}else{
							layui.layer.msg('请选择入库仓库');
						}
					})
				},
			  });
		}else{
			formSubmit(data)
		}
		return false;
	});
	

	$("body").on("click",".sign-btn",function(){
		$(this).parent().append('<input type="text" name="data['+$(this).data('field')+']" value="{$userInfo['name']|default=''}" lay-verify="required" placeholder="" autocomplete="off" class="layui-input input_no_bro sign-input" >');
		if($(this).data('date')){
			$('#'+$(this).data('date')).val(cur_date);
		}
		
		$(this).remove();
	});	
	
	$('.print').click(function(){
		window.print();
	})


})
</script>
{/block}