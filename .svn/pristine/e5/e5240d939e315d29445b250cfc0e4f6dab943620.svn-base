<!doctype html>
<html class="no-js">
<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="description" content="">
<meta name="keywords" content="">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{:config('web.title')}</title>
<!-- Set render engine for 360 browser -->
<meta name="renderer" content="webkit">
<!-- No Baidu Siteapp-->
<meta http-equiv="Cache-Control" content="no-siteapp"/>
<!-- Add to homescreen for Chrome on Android -->
<meta name="mobile-web-app-capable" content="yes">
<!-- Add to homescreen for Safari on iOS -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="apple-mobile-web-app-title" content="Amaze UI"/>
<link rel="stylesheet" href="/static/component/layui/css/layui.css" />
<link rel="stylesheet" href="/static/amazeui/css/amazeui.min.css">
<link rel="stylesheet" href="/static/amazeui/css/app.css">
<!--[if (gte IE 9)|!(IE)]><!-->
<script src="/static/tool/jquery.min.js"></script>
<!--<![endif]-->
<!--[if lte IE 8 ]>
<script src="http://libs.baidu.com/jquery/1.11.3/jquery.min.js"></script>
<script src="http://cdn.staticfile.org/modernizr/2.8.3/modernizr.js"></script>
<script src="/static/amazeui/js/amazeui.ie8polyfill.min.js"></script>
<![endif]-->
<script src="/static/amazeui/js/amazeui.min.js"></script>
<script src="/static/component/layui/layui.js"></script>
{block name="css"}{/block}
</head>
<body>
<header data-am-widget="header"  class="am-header am-header-default  am-header-fixed">
	<div class="am-header-left am-header-nav">
		<a href="#left-link" class="am-btn">
			<i class="am-header-icon am-icon-close"></i>
		</a>
	</div>
	<h1 class="am-header-title">
		{:config('web.sys_name')}
	</h1>
	<div class="am-header-right am-header-nav logout">
		<a href="#user-link" class="am-btn am-btn-secondary">
			<i class="am-header-icon am-icon-user"></i>
		</a>
		<a href="#cart-link" >
			{:session('admin.username')}
		</a>
	</div>
</header>
{block name="body"}{/block}
<div data-am-widget="navbar" class="am-navbar am-cf am-navbar-default " id="">
	<ul class="am-navbar-nav am-cf am-avg-sm-4">
		<li >
            <a href="{:url('h5.ErpOrder/list')}">
                <span class="am-navbar-label">订单查询</span>
            </a>
		</li>
		<li>
			<a href="{:url('h5.ErpOrder/salesman')}">
                <span class="am-navbar-label">订单审批</span>
            </a>
		</li>
		<li>
			<a href="{:url('h5.OrderShipping/list')}">
				<span class="am-navbar-label">发货审批</span>
			</a>
		</li>
	</ul>
</div>
<script>
layui.use([ 'jquery', 'layer'], function() {
	$('.logout').click(function(){
		layui.layer.open({
			shade: 0.3,
			content: '确定退出登录吗?',
			btn: ['确定', '取消'],
			yes: function (index) {
				layui.layer.close(index);
				$.ajax({
					url: '{:url('login/logout')}',
					type:"POST",
					dataType:"json",
					success: function(res) {
						if (res.code==200) {
							layui.layer.msg(res.msg, {
								icon: 1
							});
							setTimeout(function() {
								location.href = '{:url('login/index')}';
							}, 333)
						}
					}
				});
			}
		});
	})
});
</script>
</body>
{block name="js"}{/block}
{block name="script"}{/block}
</html>