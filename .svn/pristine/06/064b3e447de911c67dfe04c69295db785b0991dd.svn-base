{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
.layui-col-md4{margin-bottom:10px;}
.layui-table td, .layui-table th {padding: 9px 5px;}
</style>
<form class="layui-form" action="" method="post" data-reload="7" data-callback="submitCallBack">
	<input type="hidden"  name="order_id" id="order_id"  value="">
	<input type="hidden"  name="material_type" id="material_type"  value="">
	<input type="hidden"  name="type" id="type"  value="back_warehouse">
	<input type="hidden"  name="stock_date" value="{:date('Y-m-d')}" >
	<input type="hidden" maxlength="255" name="remark" >
	<div class="mainBox">
		<div class="main-container">
			<table class="layui-table">
				<thead>
					<tr>
						<th >物料编码</th>
						<th>物料名称</th>
						<th style="width:100px;">工位仓位</th>
						<th style="width:80px;">库存数量</th>
						<th style="width:90px;">退回数量</th>
						<th style="width:100px;">备注</th>
						<th style="width: 60px;">操作</th>
					</tr> 
				</thead>
				<tbody id="tbody">
					
				</tbody>
			</table>
		</div>
	</div>
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
		</div>
	</div>
</form>
{/block}
{block name="script"}
<script>
var list = {:json_encode($data)};

layui.use(['tableSelect','form','select'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect,form = layui.form;
	var select = layui.select;
	
	window.submitCallBack = function (res){
		parent.location.reload();
	}
	
	window.deleteMaterial = function(_id){
		$('#material_'+_id).remove();
	}
	
	$("body").on("change",".stock_num",function(){
		var value 	= $(this).val();
		var old 	= $(this).data('old');
		//value 		= value.replace(/[^\d]/g,"");
		if(!(/^([1-9][0-9]*)$/.test(value)) || value <= 0){ 
			layer.msg('请输入大于0的正整数');
			$(this).val(old);
			return ;
		}
		$(this).data('old',value);
	});


	layui.each(list, function (index, vo) {
		addMaterial(vo);
	})

	function addMaterial(item){
		var stock_num = '';
		var html = '<tr id="material_'+item.id+'"><input type="hidden"  name="material['+item.id+'][id]" value="'+item.id+'" class="material_id" >';
		html += '	<td>'+item.sn+'</td>';
		html += '	<td>'+item.name+'</td>';
		html += '	<td>'+item.warehouse_name+'</td>';
		html += '	<td>'+item.stock+'</td>';
		html += '	<td><input type="text" data-old="'+stock_num+'"  name="material['+item.id+'][stock_num]" value="'+stock_num+'"  data-key="stock_num" class="layui-input stock_num" lay-verify="required|number" placeholder="请输入数量"></td>';
		html += '	<td><input type="text"  name="material['+item.id+'][remark]" value="" class="layui-input remark" data-key="remark" placeholder=""></td>';
		html += '	<td><button type="button" onclick="deleteMaterial('+item.id+')" class="layui-btn layui-btn-xs layui-btn-danger">删除</button></td>';		
		html += '</tr>';
		$('#tbody').append(html);	
	}
	
	$(".layui-table").on("keydown",".layui-input",function(){
		if (event.keyCode == 40) {
			$(this).closest('tr').next().find('.'+$(this).data('key')).focus();
		}else if (event.keyCode == 38) {
			$(this).closest('tr').prev().find('.'+$(this).data('key')).focus();
		}else if (event.keyCode == 13 || event.keyCode == 39) {
			//右一个
			$(this).closest('td').next().find('.layui-input').focus();
		}else if (event.keyCode == 37) {
			//左一个
			$(this).closest('td').prev().find('.layui-input').focus();
		}
	});
	
});
</script>
{/block}