{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
.layui-col-md4{margin-bottom:10px;}
.layui-table td, .layui-table th {padding: 9px 5px;}
</style>
<form class="layui-form" action="" method="post" data-reload="3" data-callback="submitCallBack">
	<input type="hidden"  name="order_id" id="order_id"  value="">
	<input type="hidden"  name="material_type" id="material_type"  value="1">
	<input type="hidden"  name="approval_id" id="approval_id"  value="{$model['id']}">
	<div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<div class="layui-row">
					<div class="layui-col-md4">
						<label class="layui-form-label">退回日期</label>
						<div class="layui-input-block">
							<input type="text"  readonly name="stock_date" value="{$model['data']['stock_date']}" lay-verify="required" placeholder="请选择,不可为空" autocomplete="off" class="layui-input date">
						</div>	
					</div>
					<div class="layui-col-md4">
						<label class="layui-form-label">备注</label>
						<div class="layui-input-block">
							<input type="text" maxlength="255" name="remark" value="{$model['data']['remark']}" placeholder="请输入" autocomplete="off" class="layui-input remark">
						</div>	
					</div>	
					<div class="layui-col-md4">
						<label class="layui-form-label">质检</label>
						<div class="layui-input-block">
							<input type="radio" name="need_check" value="1" {if $model['data']['need_check'] == 1}checked{/if} title="需质检">
							<input type="radio" name="need_check" value="0" {if $model['data']['need_check'] == 0}checked{/if} title="不需质检">
						</div>	
					</div>
				</div>
			</div>			
			<blockquote class="layui-elem-quote">相关物料信息</blockquote>
			<div class="layui-row layui-col-space10">
				<div class="layui-col-md12">
					<input type="text"  id="select_material" readonly ts-selected="{:implode(',',array_column($model['data']['material'],'id'))}"  placeholder="请选择,不可为空" autocomplete="off" class="layui-input">
				</div>
			</div>
			<table class="layui-table">
				<thead>
					<tr>
						<th style="width: 135px;">物料编码</th>
						<th>物料名称</th>
						<th style="width: 240px;">入库批次号</th>
						<th style="width:90px;">退回数量</th>
						<th style="width:200px;">退回原因</th>
						<th style="width: 60px;">操作</th>
					</tr> 
				</thead>
				<tbody id="tbody">
	
				</tbody>
			</table>
		</div>

	</div>
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
		</div>
	</div>
</form>
{/block}
{block name="script"}
<script>

var m_data = [];
{if !empty($model['data']['material'])}

m_data = {:json_encode($model['data']['material'])};

{/if}

layui.use(['tableSelect','form','select'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect,form = layui.form;
	var select = layui.select;
	
	tableSelect.render({
		elem: '#select_material',
		checkedKey: 'id',
		searchKey: 'keyword',
		searchPlaceholder: '物料编码/物料名称',
		table: {
			url: '{:url('listGroupByMaterial')}?warehouse_type=3',	
			limit:100,
			limits:[100,200,300,400,500],			
			cols: [[
				{type: 'checkbox' },
				{field: 'sn',title: '物料编码',align: 'center',unresize: false,width: 300},
				{field: 'name',title: '物料名称',align: 'center',unresize: false,width: 300},
				//{field: 'stock',title: '现有库存',align: 'center',unresize: false,width: 120},
			]]
		},
		done: function (elem, data) {
			layui.each(data.data, function (index, item) {
				if($('#material_'+item.material_id).length>0){
					//layer.msg('物料已添加');	
					//$('#material_'+item.material_id).find('.stock_num').focus();
				}else if(item && item.material_id && item.name){
					addMaterial(item);
				}
			})
		}
	})
	
	window.submitCallBack = function (res){
		location.replace('{:url('edit')}?id='+res.data.id);
	}
	
	window.deleteMaterial = function(_id){
		$('#material_'+_id).remove();
	}
	
	$("body").on("change",".stock_num",function(){
		var value 	= $(this).val();
		var old 	= $(this).data('old');
		//value 		= value.replace(/[^\d]/g,"");
		if(!(/^([1-9][0-9]*)$/.test(value)) || value <= 0){ 
			layer.msg('请输入大于0的正整数');
			$(this).val(old);
			return ;
		}
		value = parseInt(value);
		var material_id = $(this).closest('tr').find('.material_id').val();
		var material_key = $(this).closest('tr').data('key');
		var ids = select.value('material_'+material_key, 'val'); 
		console.log(ids);
		var num = 0 ;
		$(this).closest('tr').find('.enter_material_id option').each(function(){
			var v = ($(this).val()).toString();
			if(ids.indexOf(v) != -1){
				num = num + parseInt($(this).data('num'));
			}
		})
		if(num > 0 && value > num){
			layer.msg('最多出库数量'+num);
			$(this).val(old);
			return ;
		}
		$(this).data('old',value);
	});

	function addMaterial(item){
		var stock_num = item.stock_num?item.stock_num:1;
		var remark = item.remark?item.remark:1;
		var enter_material_id = item.enter_material_id?(item.enter_material_id.split(",")):[];
		
		var material_key = item.material_id;
		
		
		var html = '<tr id="material_'+item.material_id+'" data-key="'+material_key+'"><input type="hidden"  name="material['+material_key+'][id]" value="'+item.material_id+'" class="material_id" ><input type="hidden"  name="material['+material_key+'][sn]" value="'+item.sn+'" class="sn" >';
		html += '	<td>'+item.sn+'</td>';
		html += '	<td>'+item.name+'</td>';

		html += '	<td><select name="material['+material_key+'][enter_material_id]" class="enter_material_id" xm-select="material_'+material_key+'" required lay-verify="required" xm-select-checkbox>';
		if(item.enter.length > 0){
			layui.each(item.enter, function (index2, item2) {
				if(enter_material_id.length > 0){
					html += '<option '+(enter_material_id.indexOf(item2.enter_material_id) != -1?'selected':'')+' data-num="'+item2.num+'" value="'+item2.enter_material_id+'" >'+item2.enter_order_sn+'('+item2.num+')</option>';
				}else{
					html += '<option '+(index2==0?'selected':'')+' data-num="'+item2.num+'" value="'+item2.enter_material_id+'" >'+item2.enter_order_sn+'('+item2.num+')</option>';
				}
			})
		}
		
		html += '	</select></td>';
		html += '	<td><input type="text" data-old="1"  name="material['+material_key+'][stock_num]" value="'+stock_num+'"  data-key="stock_num" class="layui-input stock_num" lay-verify="required|number" placeholder="请输入数量"></td>';
		html += '	<td><input type="text"  name="material['+material_key+'][remark]" value="'+remark+'" class="layui-input remark" data-key="remark" placeholder=""></td>';
		html += '	<td><button type="button" onclick="deleteMaterial('+item.material_id+')" class="layui-btn layui-btn-xs layui-btn-danger">删除</button></td>';
		html += '</tr>';
		$('#tbody').prepend(html);	
		$('#material_'+item.material_id).find('.stock_num').focus();
		form.render();
		select.render('material_'+material_key+'');
		
		select.on('material_'+material_key, function(id, vals, item, isAdd, isDisabled){
			//console.log(vals);
			var ids = [];
			$.each(vals,function(idx,vo){
				ids.push(vo.value);
			})
			var max_num = 0;
		
			$('#'+id+' .enter_material_id option').each(function(){
				if(ids.indexOf($(this).val().toString()) != -1){
					max_num = $(this).data('num');
				}
			})
			max_num = parseInt(max_num);
			var stock_num = $('#'+id+' .stock_num').val();
			
			if(max_num > 0 && stock_num && max_num < parseInt(stock_num)){
				$('#'+id+' .stock_num').val(max_num);
			}
		},true);
	}
	
	
	$(".layui-table").on("keydown",".layui-input",function(){
		if (event.keyCode == 40) {
			$(this).closest('tr').next().find('.'+$(this).data('key')).focus();
		}else if (event.keyCode == 38) {
			$(this).closest('tr').prev().find('.'+$(this).data('key')).focus();
		}else if (event.keyCode == 13 || event.keyCode == 39) {
			//右一个
			$(this).closest('td').next().find('.layui-input').focus();
		}else if (event.keyCode == 37) {
			//左一个
			$(this).closest('td').prev().find('.layui-input').focus();
		}
	});

	
	if(m_data){
		var dd = {};
		var ids = [];
		$.each(m_data,function(idx,item){
			dd[item.id] = {};
			dd[item.id]['enter_material_id'] = item.enter_material_id;
			dd[item.id]['stock_num'] = item.stock_num;
			dd[item.id]['remark'] = item.remark;
			ids.push(item.id);
		})
		//console.log(ids);
		//console.log(dd);		
		$.ajax({
			type: 'GET',
			url:'{:url('listGroupByMaterial')}?warehouse_type=3&material_ids='+ids.join(','),
			dataType: 'json',
			success: function(res){
				$.each(res.data,function(idx,item){
					if($('#material_'+item.material_id).length == 0){
						item.enter_material_id = dd[item.material_id]['enter_material_id'];
						item.stock_num = dd[item.material_id]['stock_num'];
						item.remark = dd[item.material_id]['remark'];
						addMaterial(item);
					}
				})
				return false;		     
			},
			error : function() {
				alert('失败。');
			}
		});
	}
});
</script>
{/block}