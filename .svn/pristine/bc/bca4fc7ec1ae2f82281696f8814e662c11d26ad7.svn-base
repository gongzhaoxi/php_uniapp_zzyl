{extend name="base" /}
{block name="body"}
<style>
.layui-form-label {width: 150px;}
.layui-input-block {margin-left: 180px;}
.layui-form-item .layui-input-inline{width:380px;}
</style>
<div class="layui-row layui-col-space15">
    <div class="layui-col-md12">
        <div class="layui-card">
            <form class="layui-form edit-form" method="post" action="">
				<div class="layui-tab layui-tab-brief" lay-filter="TabBrief">
					<ul class="layui-tab-title">
						<li class="layui-this">系统设置</li>
						<li >网站设置</li>
						<li>邮箱设置</li>
						<li>上传设置</li>
						<li>积木报表</li>
						<li>平板信息</li>
					</ul>
					<div class="layui-tab-content">
						<div class="layui-tab-item layui-show">
							<div class="layui-form-item">
								<label class="layui-form-label">登录验证码</label>
								<div class="layui-input-block">
									{if $data['login_captcha'] == 1}
										<input type="radio" name="login_captcha" value="1" title="开启" checked>
										<input type="radio" name="login_captcha" value="0" title="关闭">
									{else}
										<input type="radio" name="login_captcha" value="1" title="开启">
										<input type="radio" name="login_captcha" value="0" title="关闭" checked>
									{/if}
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">系统名称</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="sys_name" value="{$data['sys_name']??''}" type="text"/>
								</div>
							</div>	
							<div class="layui-form-item">
								<label class="layui-form-label">系统LOGO</label>
								<div class="layui-input-block">
									{:$form->optPhoto('sys_logo',$data['sys_logo']??'')}
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">欢迎页主标题</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="welcome_title" value="{$data['welcome_title']??''}" type="text"/>
								</div>
							</div>	
							<div class="layui-form-item">
								<label class="layui-form-label">欢迎页副标题</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="welcome_desc" value="{$data['welcome_desc']??''}" type="text"/>
								</div>
							</div>	
							<div class="layui-form-item">
								<label class="layui-form-label">欢迎页图</label>
								<div class="layui-input-block">
									{:$form->optPhoto('welcome_photo',$data['welcome_photo']??'')}
								</div>
							</div>	
							<div class="layui-form-item">
								<label class="layui-form-label">数字屏幕标题</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="board_title" value="{$data['board_title']??''}" type="text"/>
								</div>
							</div>	
							
						</div>
						<div class="layui-tab-item">
							<div class="layui-form-item">
								<label class="layui-form-label">
									网站标题
								</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="title" value="{$data['title']??''}" type="text"/>
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">
									网站关键词
								</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input"  name="key" value="{$data['key']??''}" type="text"/>
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">
									网站描述
								</label>
								<div class="layui-input-block">
									<textarea name="desc" class="layui-textarea">{$data['desc']??''}</textarea>
								</div>
							</div>
						</div>
						<div class="layui-tab-item">
							<div class="layui-form-item">
								<label class="layui-form-label">邮箱账号</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input" name="smtp-user" value="{$data['smtp-user']??''}" type="text"/>
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">邮箱密匙</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input"  name="smtp-pass" value="{$data['smtp-pass']??''}" type="text"/>
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">邮箱端口</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input"  name="smtp-port" value="{$data['smtp-port']??''}" type="text"/>
								</div>
							</div>
							<div class="layui-form-item">
								<label class="layui-form-label">邮箱服务器</label>
								<div class="layui-input-block">
									<input autocomplete="off" class="layui-input"  name="smtp-host" value="{$data['smtp-host']??''}" type="text"/>
								</div>
							</div>
						</div>
						<div class="layui-tab-item">
							<div class="layui-form-item">
								<label class="layui-form-label">上传大小限制</label>
								<div class="layui-input-inline">
									<input type="text" name="upload_size" value="{$data['upload_size']|default='1024'}"  lay-verify="required" autocomplete="off" class="layui-input">
								</div>
								<div class="layui-form-mid layui-word-aux">单位：KB</div>
							</div>		
							<div class="layui-form-item">
								<label class="layui-form-label">上传格式限制</label>
								<div class="layui-input-inline">
									<input type="text" name="upload_ext" value="{$data['upload_ext']|default='jpg,png,gif,jpeg,ico,doc,docx,xls,xlsx,ppt,pptx,pdf,wps,txt,rar,zip,bmp'}"  lay-verify="required" autocomplete="off" class="layui-input">
								</div>
								<div class="layui-form-mid layui-word-aux">多个格式请用英文逗号（,）隔开</div>
							</div>							
							<div class="layui-form-item">
                                <label class="layui-form-label">存储方式</label>
                                <div class="layui-input-block">
                                <input type="radio" name="file-type" value="1" title="本地" {if condition="$data['file-type'] eq 1"} checked {/if} lay-filter="type">
                                <input type="radio" name="file-type" value="2" title="阿里云" {if condition="$data['file-type'] eq 2"} checked {/if} lay-filter="type">
                                <input type="radio" name="file-type" value="3" title="七牛云" {if condition="$data['file-type'] eq 3"} checked {/if} lay-filter="type">
                                </div>
                            </div>
                            <div class="layui-form-item" id="oss" {if condition="$data['file-type'] neq 2"} style="display: none;" {/if}>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">Oss地址</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="file-endpoint"  value="{$data['file-endpoint']??''}"  placeholder="请输入Oss地址" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">空间名称</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="file-OssName"   value="{$data['file-OssName']??''}" placeholder="请输入空间名称" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">KeyId</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="file-accessKeyId"   value="{$data['file-accessKeyId']??''}" placeholder="请输入KeyId" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">KeySecret</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="file-accessKeySecret"   value="{$data['file-accessKeySecret']??''}"  placeholder="请输入KeySecret" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                            </div>
                            <div class="layui-form-item" id="qiniu" {if condition="$data['file-type'] neq 3"} style="display: none;" {/if}>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">空间域名</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="qiniu-Domain" value="{$data['qiniu-Domain']??''}"  placeholder="请输入绑定空间域名" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">BUCKET</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="qiniu-Bucket" value="{$data['qiniu-Bucket']??''}" placeholder="请输入空间BUCKET" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">AK</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="qiniu-AK" value="{$data['qiniu-AK']??''}" placeholder="请输入AK" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                                <div class="layui-form-item">
                                    <label class="layui-form-label">SK</label>
                                    <div class="layui-input-block">
                                        <input type="text" name="qiniu-SK" value="{$data['qiniu-SK']??''}"  placeholder="请输入SK" autocomplete="off" class="layui-input">
                                    </div>
                                </div>
                            </div>
                        </div>
						<div class="layui-tab-item">
							<div class="layui-card">
								<div class="layui-card-body">
									<table class="layui-table">
										<thead>
											<tr>
												<th>ID</th>
												<th>名称</th>
												<th>链接</th>
												<th>参数</th>
											</tr> 
										</thead>
										<tbody>
											<tr>
												<td>1</td>
												<td>仓库物料入库单</td>
												<td><input type="text" name="jmreport[1]" value="{$data['jmreport'][1]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id</td>
											</tr>
											<tr>
												<td>2</td>
												<td>仓库物料次品退货单</td>
												<td><input type="text" name="jmreport[2]" value="{$data['jmreport'][2]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id</td>
											</tr>
											<tr>
												<td>3</td>
												<td>仓库物料出仓单</td>
												<td><input type="text" name="jmreport[3]" value="{$data['jmreport'][3]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id；detail_ids，值如1,2,3,4，对应erp_material_out_material的id</td>
											</tr>	
											<tr>
												<td>8</td>
												<td>仓库物料出仓单A4</td>
												<td><input type="text" name="jmreport[8]" value="{$data['jmreport'][8]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id；detail_ids，值如1,2,3,4，对应erp_material_out_material的id</td>
											</tr>
											<tr>
												<td>4</td>
												<td>仓库物料盘点单</td>
												<td><input type="text" name="jmreport[4]" value="{$data['jmreport'][4]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id</td>
											</tr>
											<tr>
												<td>5</td>
												<td>仓库报废出库单</td>
												<td><input type="text" name="jmreport[5]" value="{$data['jmreport'][5]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>order_sn，值如BF20240525001，对应erp_material_scrap_out的order_sn</td>
											</tr>
											<tr>
												<td>6</td>
												<td>仓库入库品质单</td>
												<td><input type="text" name="jmreport[6]" value="{$data['jmreport'][6]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_material_stock的id;detail_ids，值如1,2,3,4，对应erp_material_enter_material的id</td>
											</tr>
											<tr>
												<td>7</td>
												<td>仓库领料汇总</td>
												<td><input type="text" name="jmreport[7]" value="{$data['jmreport'][7]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_material_stock的id</td>
											</tr>	
											<tr>
												<td>9</td>
												<td>调拨出库单</td>
												<td><input type="text" name="jmreport[9]" value="{$data['jmreport'][9]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_print，(data为erp_material_allocate_material的id)</td>
											</tr>
											
											<tr>
												<td>11</td>
												<td>销售打印确认单</td>
												<td><input type="text" name="jmreport[11]" value="{$data['jmreport'][11]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_order的id</td>
											</tr>
											<tr>
												<td>12</td>
												<td>销售打印订货单</td>
												<td><input type="text" name="jmreport[12]" value="{$data['jmreport'][12]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_order的id</td>
											</tr>
											<tr>
												<td>13</td>
												<td>打印“国内”包装标签</td>
												<td><input type="text" name="jmreport[13]" value="{$data['jmreport'][13]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_order的id</td>
											</tr>	
											<tr>
												<td>14</td>
												<td>销售打印“国外”包装标签</td>
												<td><input type="text" name="jmreport[14]" value="{$data['jmreport'][14]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_order的id</td>
											</tr>
											<tr>
												<td>15</td>
												<td>销售打印价格确认单</td>
												<td><input type="text" name="jmreport[15]" value="{$data['jmreport'][15]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_order的id</td>
											</tr>
											<tr>
												<td>21</td>
												<td>计划打印标签</td>
												<td><input type="text" name="jmreport[21]" value="{$data['jmreport'][21]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce_bom的id</td>
											</tr>
											<tr>
												<td>22</td>
												<td>计划打印领料单(部件)</td>
												<td><input type="text" name="jmreport[22]" value="{$data['jmreport'][22]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce_bom的id</td>
											</tr>	
											<tr>
												<td>26</td>
												<td>计划打印领料单(零件)</td>
												<td><input type="text" name="jmreport[26]" value="{$data['jmreport'][26]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce_bom的id</td>
											</tr>											
											<tr>
												<td>23</td>
												<td>计划打印需求单(部件)</td>
												<td><input type="text" name="jmreport[23]" value="{$data['jmreport'][23]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce的id</td>
											</tr>	
											<tr>
												<td>24</td>
												<td>计划打印需求单(零件)</td>
												<td><input type="text" name="jmreport[24]" value="{$data['jmreport'][24]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce的id</td>
											</tr>
											<tr>
												<td>25</td>
												<td>计划打印排产单</td>
												<td><input type="text" name="jmreport[25]" value="{$data['jmreport'][25]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce的id</td>
											</tr>		
											<tr>
												<td>27</td>
												<td>计划打印产品标签</td>
												<td><input type="text" name="jmreport[27]" value="{$data['jmreport'][27]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce的id</td>
											</tr>	
											<tr>
												<td>28</td>
												<td>计划打印欠料单</td>
												<td><input type="text" name="jmreport[28]" value="{$data['jmreport'][28]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_order_produce的id</td>
											</tr>
											<tr>
												<td>29</td>
												<td>计划打印总表</td>
												<td><input type="text" name="jmreport[29]" value="{$data['jmreport'][29]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1，对应erp_print，(data为erp_material的id)</td>
											</tr>
											<tr>
												<td>290</td>
												<td>已排产订单 - 打印排产单</td>
												<td><input type="text" name="jmreport[290]" value="{$data['jmreport'][290]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，对应erp_print的data_key，(data_id为erp_order_produce的id)</td>
											</tr>
											
											<tr>
												<td>31</td>
												<td>下达部件库存打印领料单</td>
												<td><input type="text" name="jmreport[31]" value="{$data['jmreport'][31]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_material_plan的id</td>
											</tr>											
											<tr>
												<td>32</td>
												<td>下达部件库存打印需求单</td>
												<td><input type="text" name="jmreport[32]" value="{$data['jmreport'][32]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_material_plan的id</td>
											</tr>
											<tr>
												<td>33</td>
												<td>下达部件库存打印排产单</td>
												<td><input type="text" name="jmreport[33]" value="{$data['jmreport'][33]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>id，值如1,2,3，对应erp_material_plan的id</td>
											</tr>											
											<tr>
												<td>41</td>
												<td>销售打印“国内”发货通知单</td>
												<td><input type="text" name="jmreport[41]" value="{$data['jmreport'][41]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>order_id，值如1，对应erp_order的id；order_produce_id值如1,2,3，对应erp_order_produce的id</td>
											</tr>											
											<tr>
												<td>42</td>
												<td>销售打印“国外”发货通知单</td>
												<td><input type="text" name="jmreport[42]" value="{$data['jmreport'][42]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>order_id，值如1，对应erp_order的id；order_produce_id值如1,2,3，对应erp_order_produce的id</td>
											</tr>
											<tr>
												<td>43</td>
												<td>销售打印售后“国内”发货通知单</td>
												<td><input type="text" name="jmreport[43]" value="{$data['jmreport'][43]??''}"  placeholder="" autocomplete="off" class="layui-input"></td>
												<td>order_id，值如1，对应erp_order的id；detail_id值如1,2,3，对应erp_order_aftersale的id</td>
											</tr>											
											<tr>
												<td>44</td>
												<td>销售打印售后“国外”发货通知单</td>
