{/block}
{block name="script"}
<script>
layui.use(['form', 'jquery', 'uploads'], function() {
	let form = layui.form;
	let $ = layui.jquery;

	form.on('radio(type)', function(data){
		if(data.value==1){
			$("#oss").hide();
			$("#qiniu").hide();
		}
		if(data.value==2){
			$("#oss").show();
			$("#qiniu").hide();
		}
		if(data.value==3){
			$("#qiniu").show();
			$("#oss").hide();
		}
	});  
})
</script>
{/block}
