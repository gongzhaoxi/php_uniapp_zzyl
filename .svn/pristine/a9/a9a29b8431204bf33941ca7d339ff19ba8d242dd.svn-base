{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
</style>
<form class="layui-form" action="" method="post">
	 <input type="hidden" name="id" value="{$model['id']}" >
	 <div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<label class="layui-form-label">随工单完成时间</label>
				<div class="layui-input-block">
					<input type="text" readonly name="confirm_date" value="{$model['confirm_date']}"  lay-verify="required" placeholder="请输入随工单完成时间,不可为空" autocomplete="off" class="layui-input date">
				</div>
			</div>
			<div class="layui-form-item">
				<label class="layui-form-label">报工单价</label>
				<div class="layui-input-block">
					<input type="text"  name="price" value="{$model['price']}"  lay-verify="required|number" placeholder="请输入报工单价,不可为空" autocomplete="off" class="layui-input">
				</div>
			</div>		
			<input type="hidden" id="username" name="username" value="{$model['username']}">		
			<div class="layui-form-item">
				<label class="layui-form-label">完成人</label>
				<div class="layui-input-block">
					<select name="user_id" lay-verify="required" lay-filter="user_id">
						<option  value="">请选择</option>
						{foreach $users as $key=>$vo}
						<option {if $model['user_id'] == $vo['id']}selected{/if} value="{$vo['id']}">{$vo['name']}</option>
						{/foreach}
					</select>
				</div>
			</div>				
		</div>
	</div>       
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
		</div>
    </div>
</form>
{/block}
{block name="script"}
<script>
layui.use(function(){
	var form = layui.form;
	var $ = layui.jquery;
	form.on('select(user_id)', function(data){
		$('#username').val($(data.elem).find('option:selected').text())
	});
});
</script>
{/block}