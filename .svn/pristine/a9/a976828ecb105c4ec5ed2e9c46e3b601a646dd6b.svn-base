{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
</style>
<form class="layui-form" action="" method="post" data-reload="7" data-callback="submitCallBack">
	<div class="mainBox">
		<div class="main-container">
			<blockquote class="layui-elem-quote">
				物料信息
				<button type="button" style="float:right;" class="layui-btn layui-btn-normal layui-btn-sm check"<i class="layui-icon layui-icon-ok"></i>物料排查</button>
			</blockquote>
			<input type="text" value="" ts-selected="" value="" lay-verify="required" id="material_codes"   autocomplete="off" class="layui-input" placeholder="请选择">
			<table class="layui-table">
				<thead>
					<tr>
						<th>物料编码</th>
						<th>物料名称</th>
						<th>现有库存量</th>
						<th>近3月需求量</th>
						<th>需排产量</th>
						<th>所需零件</th>
						<th>操作</th>
					</tr> 
				</thead>
				<tbody id="tbody">
	
				</tbody>
			</table>
		</div>
	</div>
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
		</div>
	</div>
</form>
{/block}
{block name="script"}
<script>
var material_ids = [];
layui.use(['tableSelect'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect;

	window.submitCallBack = function (res){
		location.replace('{:url('view')}?id='+res.data.id);
	}
	
	window.deleteMaterial = function(_id){
		var ids = [];
		var codes = [];
		
		layui.each(material_ids, function (ind, id) {
			if(_id == id){
				$('#material_'+id).remove();	
			}else{
				ids.push(id);
				codes.push($('#material_'+id+' td').eq(0).text());
			}
		})
		material_ids = ids;
	
		$('#material_codes').attr('ts-selected',material_ids.join(','));
		$('#material_codes').val(codes.join(','));
	}
	
	$('.check').click(function(){
		if($('#tbody tr').length == 0){
			layui.layer.msg('请选择物料');return false;
		}
		
		layui.each($('#tbody tr'), function (index, item) {
			var tr = $(item);
			var material_id	= tr.find('.material_id').val();
			var num  		= tr.find('.num').val();
			
			$.ajax({
				url: '{:url('viewMaterialBom')}?material_id='+material_id+'&num='+num,
				success: function (result) {
					
					for (var i=0;i<result.data.bom.length;i++){
						
						if(parseInt(result.data.bom[i].lack_num)>0){
							tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  layui-btn-danger view-bom" >缺料</button>');
						}else{
							tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  view-bom" >足料</button>');
						}
						break;
					}
					
					
	
				},
				async: false
			});
		})
		
	})
	
	
	$("body").on("click",".view-bom",function(){
		var tr = $(this).closest("tr");
		var material_id	= tr.find('.material_id').val();
		var num  		= tr.find('.num').val();
		//openLayer('零件--BOM清单','{:url('viewMaterialBom')}?material_id='+material_id+'&num='+num,'90%','90%');
		
		layer.open({
			type: 2,
			area: ['90%','90%'],
			fix: false, //不固定
			maxmin: true,
			shade:0.4,
			title: '零件--BOM清单',
			scrollbar: false,
			content:  '{:url('viewMaterialBom')}?material_id='+material_id+'&num='+num,
			cancel: function () {
				
			},
			success: function(layero, index){
				var iframeWindow = window['layui-layer-iframe'+ index]
				if(iframeWindow.is_lack){
					tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  layui-btn-danger view-bom" >缺料</button>');
				}else{
					tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  view-bom" >足料</button>');
				}
			},
			end: function() {
				
			},
		});
		
	});	
	
	tableSelect.render({
		elem: '#material_codes',
		checkedKey: 'id',
		searchKey: 'keyword',
		searchPlaceholder: '物料编号/物料名称',
		table: {
			url: '{:url('material')}',
				
			cols: [[
				{ type: 'checkbox' },
				{field: 'sn',title: '物料编码',align: 'center',unresize: false,width: 200},
				{field: 'name',title: '物料名称',align: 'left',unresize: false,width: 300},
				{field: 'stock',title: '现有库存',align: 'center',unresize: false,width: 100},
			]]
		},
		done: function (elem, data) {
			var html = '';
			var codes = [];
			var ids  = [];
			layui.each(data.data, function (index, item) {
				if(material_ids.indexOf(item.id) == -1){
					material_ids.push(item.id)
					var stock_num = 1;
					if($('#material_'+item.id).length){
						stock_num = $('#material_'+item.id+' .stock_num').val();
					}
					html += '<tr id="material_'+item.id+'"><input type="hidden" class="material_id" name="material['+item.id+'][id]" value="'+item.id+'" >';
					html += '	<td>'+item.sn+'</td>';
					html += '	<td>'+item.name+'</td>';
					html += '	<td>'+item.stock+'</td>';
					html += '	<td>'+item.num+'</td>';
					html += '	<td><input type="text"  name="material['+item.id+'][num]" value="'+stock_num+'" class="layui-input num" lay-verify="required|number" placeholder="请输入数量"></td>';
					html += '	<td class="view-bom-but"><button type="button" class="layui-btn layui-btn-xs  layui-btn-primary view-bom" >待排查</button></td>';
					html += '	<td><button type="button" onclick="deleteMaterial('+item.id+')" class="layui-btn layui-btn-xs layui-btn-danger">删除</button></td>';
					html += '</tr>';
				}
				codes.push(item.sn);
				ids.push(item.id);
			})
			
			var _material_ids = [];
			
			layui.each(material_ids, function (ind, id) {
				if(ids.indexOf(id) == -1){
					$('#material_'+id).remove();	
				}else{
					_material_ids.push(id);
				}
			})
			material_ids = _material_ids;
			
			$('#tbody').append(html);	
			$('#material_codes').val(codes.join(','));
		}
	})
});
</script>
{/block}