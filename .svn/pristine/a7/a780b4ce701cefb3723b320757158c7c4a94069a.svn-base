{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<form class="layui-form" action="">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="发起人" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="content" placeholder="通知内容" class="layui-input">	
				</div>
				<div class="layui-form-item layui-inline">
					<input type="text" name="create_time" placeholder="发起通知的日期" class="layui-input rangedate">	
				</div>
				<!--				
				<div class="layui-form-item layui-inline">
					<select name="status" >
						<option value="">状态</option>
						{foreach $status as $key=>$vo}
						<option value="{$key}">{$vo}</option>
						{/foreach}
					</select>
				</div>	-->
				<div class="layui-form-item layui-inline">
					<select name="action" >
						<option value="">类型</option>
						<option value="1">我创建的</option>
						<option value="2">我审批的</option>
					</select>
				</div>				
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
</script>
<script type="text/html" id="options">
	<div class="layui-btn-group">
	{{#  if(d.status == 0 && d.auditing_admin_id == '{$_admin['id']}' ){ }}
		<button class="pear-btn pear-btn-success pear-btn-xs" lay-event="pass">审批</button>
		<button class="pear-btn pear-btn-warming pear-btn-xs" lay-event="reject">反审</button>
	{{#  } }}	
	{{#  if(d.status != 1 && d.admin_id == '{$_admin['id']}' ){ }}
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit">查看</button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove">删除</button>
	{{#  }else if(d.status == 1){ }}
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit">查看</button>
	{{#  } }}
	</div>
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('list')}',
			page: true,
			cols: [[
				{field: 'create_time',title: '发送日期',align: 'center',width: {:get_col_width('create_time',170)}},
				{field: 'admin',title: '发起人',align: 'center',width: {:get_col_width('admin',120)}, templet: function(d){return d.admin?d.admin.nickname:'';}},
				{field: 'content',title: '通知内容',align: 'center',width: {:get_col_width('content')}},
				{field: 'auditing_admin',title: '审批人',align: 'center',width: {:get_col_width('auditing_admin',120)}, templet: function(d){return d.auditing_admin?d.auditing_admin.nickname:'';}},
				{field: 'notice_admin',title: '通知人员',align: 'center',width: {:get_col_width('notice_admin')}, templet: function(d){return d.notice_admin?d.notice_admin.join(','):'';}},
				{field: 'notice_admin_count',title: '通知人数',align: 'center',width: {:get_col_width('notice_admin_count',100)}, templet: function(d){return d.notice_admin.length}},
				{field: 'viewed_admin',title: '已阅人员',align: 'center',width: {:get_col_width('viewed_admin')}, templet: function(d){return d.notice_admin?d.viewed_admin.join(','):'';}},
				{field: 'viewed_admin_count',title: '已阅人数',align: 'center',width: {:get_col_width('viewed_admin_count',100)}, templet: function(d){return d.viewed_admin.length}},
				{field: 'status_desc',title: '状态',align: 'center',width: {:get_col_width('status_desc',100)}},
				{title: '操作',toolbar: '#options',align: 'center',width: 180,unresize:true}
			]],
			cellMinWidth: 100,
			//skin: 'line',
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('tool(dataTable)', function(obj) {
			console.log(obj);
			if (obj.event === 'remove') {
				layerConfirm('确定要删除?','{:url('remove')}',{ids:[obj.data['id']]},function(res){
					obj.del();
				})
			}else if (obj.event === 'edit') {
				openLayer('修改','{:url('edit')}?id='+obj.data['id'],'80%','90%');
			}else if (obj.event === 'pass') {
				layerConfirm('确定审批?','{:url('pass')}',{id:obj.data['id']},function(res){
					table.reload('dataTable');
				})
			}else if (obj.event === 'reject') {
				layerConfirm('确定反审?','{:url('reject')}',{id:obj.data['id']},function(res){
					table.reload('dataTable');
				})
			}
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增客户','{:url('add')}','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		
	})
</script>
{/block}


