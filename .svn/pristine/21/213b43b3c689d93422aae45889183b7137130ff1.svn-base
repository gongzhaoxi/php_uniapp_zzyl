{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
</style>
<form class="layui-form" action="{:url('view')}" method="post" >
	<input type="hidden"  name="id" value="{$id}" >
	<div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<label class="layui-form-label">下达日期</label>
				<div class="layui-input-block">
					<input type="text" maxlength="100" name="start_date" value="{:date('Y-m-d')}"  lay-verify="required" placeholder="请选择" autocomplete="off" class="layui-input date">
				</div>
			</div>
			<div class="layui-form-item">
				<label class="layui-form-label"></label>
				<div class="layui-input-block">
					<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>确认下达</button>
					<button type="button" class="layui-btn layui-btn-warm layui-btn-sm print1"><i class="layui-icon layui-icon-print"></i>打印领料单</button>
					<button type="button" class="layui-btn layui-btn-warm layui-btn-sm print2"><i class="layui-icon layui-icon-print"></i>打印需求单</button>
					<button type="button" class="layui-btn layui-btn-warm layui-btn-sm print3"><i class="layui-icon layui-icon-print"></i>打印排产单</button>
				</div>
			</div>
			<blockquote class="layui-elem-quote">物料信息</blockquote>
			<table class="layui-table">
				<thead>
					<tr>
						<th>物料编码</th>
						<th>物料名称</th>
						<th>现有库存量</th>
						<th>近3月需求量</th>
						<th>需排产量</th>
						<th>所需零件</th>
					</tr> 
				</thead>
				<tbody id="tbody">
					{volist name="list" id="vo"}
					<tr>
						<td>{$vo['material']['sn']}<input type="hidden" class="material_id" value="{$vo['material_id']}" ></td>
						<td>{$vo['material']['name']}</td>
						<td>{$vo['material']['stock']}</td>
						<td>{$vo['newly_num']}</td>
						<td>{$vo['num']}<input type="hidden" class="num" value="{$vo['num']}" ></td>
						<td class="view-bom-but"><button type="button" class="layui-btn layui-btn-xs view-bom" >查看</button></td>
					</tr>
					{/volist}
				</tbody>
			</table>
		</div>
	</div>
</form>
{/block}
{block name="script"}
<script>
var material_ids = [];
layui.use(['tableSelect'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect;
	
	$("body").on("click",".view-bom",function(){
		var material_id	= $(this).closest("tr").find('.material_id').val();
		var num  		= $(this).closest("tr").find('.num').val();
		openLayer('零件--BOM清单','{:url('viewMaterialBom')}?material_id='+material_id+'&num='+num,'90%','90%');
	});	
	
	$('.print1').click(function(){
		toPrintPage(31,{id:'{$id}'})
	})
	$('.print2').click(function(){
		toPrintPage(32,{id:'{$id}'})
	})	
	$('.print3').click(function(){
		toPrintPage(33,{id:'{$id}'})
	})	
	
	layui.each($('#tbody tr'), function (index, item) {
		var tr = $(item);
		var material_id	= tr.find('.material_id').val();
		var num  		= tr.find('.num').val();
		$.ajax({
			url: '{:url('viewMaterialBom')}?material_id='+material_id+'&num='+num,
			success: function (result) {				
				for (var i=0;i<result.data.bom.length;i++){					
					if(parseInt(result.data.bom[i].lack_num)>0){
						tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  layui-btn-danger view-bom" >缺料</button>');
					}else{
						tr.find('.view-bom-but').html('<button type="button" class="layui-btn layui-btn-xs  view-bom" >足料</button>');
					}
					break;
				}
			},
			async: false
		});
	})
	
});
</script>
{/block}