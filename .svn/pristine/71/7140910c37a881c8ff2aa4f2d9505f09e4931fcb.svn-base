{extend name="base" /}
{block name="body"}
<div class="layui-row layui-col-space10">
	<div class="layui-col-md12">
		<div class="layui-card">
			<div class="layui-card-body">
				<form class="layui-form" action="">
					<div class="layui-form-item">
						<label class="layui-form-label">字典名称</label>
						<div class="layui-input-inline">
							<input type="text" name="typeName" placeholder="" class="layui-input">
						</div>
						<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="dict-type-query"><i class="layui-icon layui-icon-search"></i>查询</button>
						<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
					</div>
				</form>
			</div>
		</div>
	</div>
	<div class="layui-col-md6">
		<div class="layui-card">
			<div class="layui-card-body">
				<table id="dict-type-table" lay-filter="dict-type-table"></table>
			</div>
		</div>
	</div>
	<div class="layui-col-md6">
		<div class="layui-card">
			<div class="layui-card-body">
				<svg class="empty" style="margin-top: 50px;margin-left: 220px;margin-bottom: 80px;" width="184" height="152"
				 viewBox="0 0 184 152" xmlns="http://www.w3.org/2000/svg">
					<g fill="none" fillRule="evenodd">
						<g transform="translate(24 31.67)">
							<ellipse fillOpacity=".8" fill="#F5F5F7" cx="67.797" cy="106.89" rx="67.797" ry="12.668"></ellipse>
							<path d="M122.034 69.674L98.109 40.229c-1.148-1.386-2.826-2.225-4.593-2.225h-51.44c-1.766 0-3.444.839-4.592 2.225L13.56 69.674v15.383h108.475V69.674z"
							 fill="#AEB8C2"></path>
							<path d="M101.537 86.214L80.63 61.102c-1.001-1.207-2.507-1.867-4.048-1.867H31.724c-1.54 0-3.047.66-4.048 1.867L6.769 86.214v13.792h94.768V86.214z"
							 fill="url(#linearGradient-1)" transform="translate(13.56)"></path>
							<path d="M33.83 0h67.933a4 4 0 0 1 4 4v93.344a4 4 0 0 1-4 4H33.83a4 4 0 0 1-4-4V4a4 4 0 0 1 4-4z" fill="#F5F5F7"></path>
							<path d="M42.678 9.953h50.237a2 2 0 0 1 2 2V36.91a2 2 0 0 1-2 2H42.678a2 2 0 0 1-2-2V11.953a2 2 0 0 1 2-2zM42.94 49.767h49.713a2.262 2.262 0 1 1 0 4.524H42.94a2.262 2.262 0 0 1 0-4.524zM42.94 61.53h49.713a2.262 2.262 0 1 1 0 4.525H42.94a2.262 2.262 0 0 1 0-4.525zM121.813 105.032c-.775 3.071-3.497 5.36-6.735 5.36H20.515c-3.238 0-5.96-2.29-6.734-5.36a7.309 7.309 0 0 1-.222-1.79V69.675h26.318c2.907 0 5.25 2.448 5.25 5.42v.04c0 2.971 2.37 5.37 5.277 5.37h34.785c2.907 0 5.277-2.421 5.277-5.393V75.1c0-2.972 2.343-5.426 5.25-5.426h26.318v33.569c0 .617-.077 1.216-.221 1.789z"
							 fill="#DCE0E6"></path>
						</g>
						<path d="M149.121 33.292l-6.83 2.65a1 1 0 0 1-1.317-1.23l1.937-6.207c-2.589-2.944-4.109-6.534-4.109-10.408C138.802 8.102 148.92 0 161.402 0 173.881 0 184 8.102 184 18.097c0 9.995-10.118 18.097-22.599 18.097-4.528 0-8.744-1.066-12.28-2.902z"
						 fill="#DCE0E6"></path>
						<g transform="translate(149.65 15.383)" fill="#FFF">
							<ellipse cx="20.654" cy="3.167" rx="2.849" ry="2.815"></ellipse>
							<path d="M5.698 5.63H0L2.898.704zM9.259.704h4.985V5.63H9.259z"></path>
						</g>
					</g>
				</svg>
				<table id="dict-data-table" lay-filter="dict-data-table"></table>
			</div>
		</div>
	</div>
</div>
<script type="text/html" id="dict-type-toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除</button>
	<button class="pear-btn pear-btn-sm" lay-event="recycle"><i class="layui-icon layui-icon-close-fill"></i>回收站</button>
</script>
<script type="text/html" id="dict-type-bar">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-warming pear-btn-xs" lay-event="data"><i class="layui-icon layui-icon-transfer"></i></button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>
</script>

<script type="text/html" id="dict-data-toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-success pear-btn-sm" lay-event="import"><i class="layui-icon layui-icon-upload"></i>导入</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除</button>
	<button class="pear-btn pear-btn-sm" lay-event="recycle"><i class="layui-icon layui-icon-close-fill"></i>回收站</button>
</script>
<script type="text/html" id="dict-data-bar">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>
</script>

{/block}
{block name="script"}
	<script>
		layui.use(['table', 'form', 'jquery'], function() {
			let table = layui.table;
			let form = layui.form;
			let $ = layui.jquery;
			let type_id;

			table.render({
				elem: '#dict-type-table',
				url: "{:url('list')}",
				page: true,
				cols: [[
					{type: 'checkbox'},
					{title: '字典名称',field: 'name',align: 'center',width: 120},
					{title: '字典类型',field: 'type',align: 'center'},
					{title: '字典状态',field: 'status_desc',align: 'center'},
					{title: '操作',toolbar: '#dict-type-bar',align: 'center',width: 180}
				]],
				skin: 'line',
				height: 'full-170',
				toolbar: '#dict-type-toolbar',
				defaultToolbar: [{
					title: '刷新',
					layEvent: 'refresh',
					icon: 'layui-icon-refresh',
				}, 'filter', 'exports']
			});

			window.renderData = function(id) {
				type_id = id;
				$(".empty").hide();

				table.render({
					elem: '#dict-data-table',
					url: "{:url('dict.data/list')}?type_id="+type_id,
					page: true,
					height: 'full-170',
					cols: [[
						{type: 'checkbox'},
						{title: '数据名称',field: 'name',align: 'center',width: 120},
						{title: '数据值',field: 'value',align: 'center'},
						{title: '排序',field: 'sort',align: 'center'},
						{title: '状态',field: 'status_desc',align: 'center'},
						{title: '操作',toolbar: '#dict-data-bar',align: 'center',width: 180}
					]],
					skin: 'line',
					toolbar: '#dict-data-toolbar',
					defaultToolbar: []
				});
			}

			table.on('tool(dict-type-table)', function(obj) {
				if (obj.event === 'remove') {
					layerConfirm('确定要删除该字典类型?','{:url('remove')}',{id:obj.data['id']},function(res){
						location.reload();
					})
				} else if (obj.event === 'edit') {
					openLayer('修改字典类型','{:url('edit')}?id='+obj.data['id'],'80%','90%');
				} else if (obj.event === 'data') {
					window.renderData(obj.data['id'])
				}
			});

			table.on('toolbar(dict-type-table)', function(obj) {
				if (obj.event === 'add') {
					openLayer('新增字典类型','{:url('add')}','80%','90%');
				} else if (obj.event === 'refresh') {
					table.reload('dict-type-table');
				} else if (obj.event === 'batchRemove') {
					tableAction(obj.config.id,'确定要删除这些字典类型','{:url('batchRemove')}');
				} else if (obj.event === 'recycle') {
					openLayer('回收站','{:url('recycle')}','80%','90%',function () {
						table.reload('dict-type-table');
					});
				}
			});

			form.on('submit(dict-type-query)', function(data) {
				table.reload('dict-type-table', {
					where: data.field,
					page:{curr: 1}
				})
				return false;
			});

			table.on('tool(dict-data-table)', function(obj) {
				if (obj.event === 'remove') {
					layerConfirm('确定要删除该字典数据?','{:url('dict.data/remove')}',{id:obj.data['id']},function(res){
						obj.del();
					})
				} else if (obj.event === 'edit') {
					openLayer('修改字典数据','{:url('dict.data/edit')}?id='+obj.data['id'],'80%','90%');
				}
			});

			table.on('toolbar(dict-data-table)', function(obj) {
				if (obj.event === 'add') {
					openLayer('新增字典数据','{:url('dict.data/add')}?type_id='+type_id,'80%','90%');
				} else if (obj.event === 'refresh') {
					table.reload('dict-data-table');
				} else if (obj.event === 'batchRemove') {
					tableAction(obj.config.id,'确定要删除这些字典数据','{:url('dict.data/batchRemove')}');
				} else if (obj.event === 'recycle') {
					openLayer('回收站','{:url('dict.data/recycle')}?type_id='+type_id,'80%','90%',function () {
						table.reload('dict-data-table');
					});
				}else if (obj.event === 'import') {
					openLayer('导入','{:url('dict.data/import')}?type_id='+type_id,'90%','90%');
				}
			});

			form.on('submit(dict-data-query)', function(data) {
				data.field.type_id = type_id;
				table.reload('dict-data-table', {
					where: data.field,
					page:{curr: 1}
				})
				return false;
			});

		})
	</script>
{/block}