{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<form class="layui-form" action="">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="仓位名称" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="sn" placeholder="仓位编码" class="layui-input">	
				</div>	
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-md" lay-event="batchRecovery"><i class="layui-icon layui-icon-refresh"></i>恢复数据</button>
	<button class="pear-btn pear-btn-danger pear-btn-md" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>彻底删除</button>
</script>
{/block}
{block name="script"}
<script>
layui.use(['table', 'form', 'jquery','common'], function() {
	let table = layui.table;
	let form = layui.form;
	let $ = layui.jquery;

	table.render({
		elem: '#dataTable',
		url: '{:url('recycle')}',
		page: true,
		cols: [[
			{type: 'checkbox'},
			{field: 'id',title: 'ID', sort: true, align: 'center',unresize: true,width: 100},
			{field: 'sn',title: '仓位编码',align: 'center',unresize: true,},
			{field: 'name',title: '仓位名称',align: 'center',unresize: true,},
			{field: 'type_desc',title: '用途',align: 'center',unresize: true,width: 120},
			{field: 'remark',title: '仓位说明/备注',align: 'center',unresize: true,},
			{field: 'create_time',title: '创建时间',unresize: true,align: 'center',width: 170}, 
			{field: 'delete_time',title: '删除时间',unresize: true,align: 'center',width: 170}
		]],			
		cellMinWidth: 100,
		skin: 'line',
		toolbar: '#toolbar',
		defaultToolbar: [{
			title: '刷新',
			layEvent: 'refresh',
			icon: 'layui-icon-refresh',
		}, 'filter']
	});

	table.on('toolbar(dataTable)', function(obj) {
		if (obj.event === 'batchRemove') {
			tableAction(obj.config.id,'确定要删除这些客户?','{:url('batchRecycle')}');
		}else if (obj.event === 'batchRecovery') {
			tableAction(obj.config.id,'确定要恢复这些客户?','{:url('batchRecycle')}?type=1');
		}else if (obj.event === 'refresh') {
			table.reload('dataTable');
		} 
	});

	form.on('submit(query)', function(data) {
		table.reload('dataTable', {
			where: data.field,
			page:{curr: 1}
		})
		return false;
	});
})
</script>
{/block}
