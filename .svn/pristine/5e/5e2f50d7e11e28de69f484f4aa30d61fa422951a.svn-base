{extend name="base" /}
{block name="body"}
<style>
	html, body {
		margin: 0;
		padding: 0;
		background-color: #0a0e27;
		color: #fff;
		font-family: 'Microsoft YaHei', Arial, sans-serif;
		height: 100%;
	}
	.dashboard-container {
		padding:0 20px;
		max-width: 1920px;
		margin: 0 auto;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
	}
	.header {
		display: flex;
		justify-content: center;
		align-items: center;
		margin-bottom: 30px;
		position: relative;
	}
	.header h1 {
		font-size: 28px;
		color: #000;
		margin: 0;
		padding: 5px 60px;
		background-color: rgba(255, 255, 255, 0.7);
		clip-path: polygon(0% 0%, 100% 0%, 100% 0%, 95% 100%, 5% 100%);
	}
	.time-display {
		font-size: 16px;
		color: #ccc;
		position: absolute;
		right: 0;
	}
	.grid-item {
		background-color: rgba(10, 14, 39, 0.8);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: 8px;
		padding: 15px;
		box-shadow: 0 0 15px rgba(0, 212, 255, 0.1);
		margin-bottom: 15px;
		display: flex;
		flex-direction: column;
		box-sizing: border-box;height: 100%;
	}
	.grid-item h3 {
		font-size: 16px;
		color: #ffffff;
		margin-bottom: 15px;
		border-bottom: 1px solid rgba(0, 212, 255, 0.2);
		padding-bottom: 5px;
	}
	.machine-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.machine-list li {
		padding: 5px 0;
		border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
		color: #00d4ff;
	}
	.machine-list li:last-child {
		border-bottom: none;
	}
	.process-flow {
		display: flex;
		flex-wrap: wrap;
		gap: 5px 1%;
	}
	.process-step {
		background-color: #2c3e50;
		color: #fff;
		padding: 5px 1%;
		border-radius: 4px;
		font-size: 12px;
		width: 30%;
		text-align: center;
		white-space: nowrap; /* 防止文本换行 */
		  overflow: hidden; /* 隐藏溢出的文本 */
		  text-overflow: ellipsis; /* 显示省略号来代表被修剪的文本 */
	}

	.process-flow .process-step:nth-child(even) {
		background-color:#E4BE3C;
		color: #000;
	}
	.process-flow .process-step:nth-child(odd) {
		background-color:#FA7876;
		color: #000;
	}



	.order-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 12px;
	}
	.order-table th,
	.order-table td {
		padding: 8px;
		text-align: left;
		border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
	}
	.order-table th {
		background-color: rgba(0, 212, 255, 0.1);
		color: #00d4ff;
	}
	.chart-container {
		height: 250px;
		margin-top: 10px;
	}
	.percentage-display {
		text-align: center;

		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.percentage-value {
		font-size: 36px;
		font-weight: bold;
		color: #00ff88;
	}
	.percentage-label {
		font-size: 14px;
		color: #ccc;
		margin-top: 5px;
	}
	.content-wrapper {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 20px;
		overflow-y: auto;
		overflow-x: hidden;
	}
	.layui-row {
		display: flex;
		min-height: 300px;
	}
	.layui-layer-content{
		color:#000;
	}
</style>
<div class="dashboard-container top1">
	<!-- 页面头部 -->
	{include file="board/top" /}
	<!-- 主体内容 -->
	<div class="content-wrapper">
		<!-- 第一行：特产订单机器总数 + 工艺生产流程 + 周来料检验合格率 + 周入库量对比 -->
		<div class="layui-row  layui-col-space15">
		<!-- 左侧：特产订单机器总数 -->
		<div class="layui-col-md3">
			<div class="grid-item">
				<h3>待产订单机器总数：<span style="color: #FF0000; font-weight: bold;">{$wait_order_produce_count} 台</span></h3>
				<ul class="machine-list waitOrderProduce">
					{volist name="wait_order_produce_top10" id="vo"}
					<li>{$vo['product_model']}{$vo['product_specs']} <span style="float: right;">{$vo['count']}</span></li>
					{/volist}
				</ul>
			</div>
		</div>
		<!-- 中间：工艺生产流程 -->
		<div class="layui-col-md3">
			<div class="grid-item">
				<h3>工艺生产流程</h3>
				<div class="process-flow todayOrderProduce">
					{foreach $process as $k=>$vo}
					<div class="process-step">{$k+1}.{$vo['name']}</div>
					{/foreach}
				</div>
			</div>
		</div>

		<!-- 右侧：周来料检验合格率 -->
		<div class="layui-col-md3">
			<div class="grid-item materiaQuality">
				<h3>周来料检验合格率</h3>
				<div class="chart-container" id="qualityChart"></div>
			</div>
		</div>

		<!-- 右侧：周入库量对比 -->
		<div class="layui-col-md3">
			<div class="grid-item todayProductStock">
				<h3>周入库量对比</h3>
				<div class="chart-container" id="storageChart"></div>
			</div>
		</div>
	</div>

	<!-- 第二行：今日未完成 + 今日完成工序 + 周生产量对比 + 生产工序合格率 -->
	<div class="layui-row  layui-col-space15">
		<!-- 左侧：今日未完成 -->
		<div class="layui-col-md3">
			<div class="grid-item">
				<h3>今日未完成：<span style="color: #FF0000; font-weight: bold;">{:$today_produce_no_finish->total()} 台</span></h3>
				<table class="order-table todayProduceNoFinish">
					{volist name="today_produce_no_finish" id="vo"}
					<tr>
						<td>{$vo['product_model']}{$vo['product_specs']}</td>
						<td>{$vo['customer_name']}</td>
					</tr>
					{/volist}
				</table>
			</div>
		</div>

		<!-- 中间：今日完成工序 -->
		<div class="layui-col-md3">
			<div class="grid-item">
				<h3>今日完成工序：<span style="color: #FF0000; font-weight: bold;">{:$today_finish_process->total()} 项</span></h3>
				<table class="order-table todayProduceProcess">
					{volist name="today_finish_process" id="vo"}
					<tr>
						<td>{:date('H:i',strtotime($vo['confirm_date']))}</td>
						<td>{$vo['customer_name']}</td>
						<td>{$vo['process_name']}</td>
					</tr>
					{/volist}
				</table>
			</div>
		</div>
		<!-- 右侧：生产工序合格率 -->
		<div class="layui-col-md3">
			<div class="grid-item" style="height: 49%;margin-bottom: 2%;">
				<h3>周生产工序合格率：<span style="color: #FF0000; font-weight: bold;">{$week_order_produce_process_rate}%</span></h3>
				<div class="percentage-display weekProduceProcessPassRate" id="weeklyQualityChart">
				</div>
			</div>
			<div class="grid-item" style="height: 49%;">
				<h3>月生产工序合格率：<span style="color: #FF0000; font-weight: bold;">{$month_order_produce_process_rate}%</span></h3>
				<div class="percentage-display monthProduceProcessPassRate" id="monthQualityChart">
				</div>
			</div>
		</div>
		<!-- 右侧：周生产量对比 -->
		<div class="layui-col-md3">
			<div class="grid-item weekProduceStock">
				<h3>周生产量对比</h3>
				<div class="chart-container" id="productionChart"></div>
			</div>
			
		</div>
	</div>
</div>
{/block}
{block name="js"}
<script src="/static/tool/echarts.min.js"></script>
{/block}
{block name="script"}
        <script>
            // 使用layui的echarts模块绘制图表
            layui.use(['echarts'], function() {
                const echarts = layui.echarts;
				const $ = layui.jquery;
				
				$('.waitOrderProduce').click(function(){
					openLayer('待排产订单列表','{:url('waitOrderProduce')}','90%','90%');
				})
				
				$('.todayOrderProduce').click(function(){
					openLayer('当日生产进度列表','{:url('todayOrderProduce')}','90%','90%');
				})	

				$('.materiaQuality').click(function(){
					openLayer('来料合格率列表','{:url('materiaQuality')}','90%','90%');
				})
				
				$('.todayProductStock').click(function(){
					openLayer('当日生产入库列表','{:url('todayProductStock')}','90%','90%');
				})	
				
				$('.todayProduceNoFinish').click(function(){
					openLayer('当日排产计划列表','{:url('todayProduceNoFinish')}','90%','90%');
				})	
				
				$('.todayProduceProcess').click(function(){
					openLayer('当日生产进度列表','{:url('todayProduceProcess')}','90%','90%');
				})		

				$('.weekProduceProcessPassRate').click(function(){
					openLayer('当日生产进度列表','{:url('weekProduceProcessPassRate')}','90%','90%');
				})
				
				$('.monthProduceProcessPassRate').click(function(){
					openLayer('当日生产进度列表','{:url('monthProduceProcessPassRate')}','90%','90%');
				})	
				
				$('.weekProduceStock').click(function(){
					openLayer('生产机型统计列表','{:url('weekProduceStock')}','90%','90%');
				})
				
						
				showTime();
				function showTime() {
					let show_day = new Array(
						"星期日",
						"星期一",
						"星期二",
						"星期三",
						"星期四",
						"星期五",
						"星期六",
						
					);
					let time = new Date();
					let year = time.getFullYear();
					let month = time.getMonth() + 1;
					let date = time.getDate();
					let day = time.getDay();
					let hour = time.getHours();
					let minutes = time.getMinutes();
					let second = time.getSeconds();
					month < 10 ? (month = "0" + month) : month;
					// month = month + 1;
					hour < 10 ? (hour = "0" + hour) : hour;
					minutes < 10 ? (minutes = "0" + minutes) : minutes;
					second < 10 ? (second = "0" + second) : second;
					let now_time =
					// "当前时间：" +
					year +
					"-" +
					month +
					"-" +
					date +
					"" +
					" " +
					show_day[day] +
					" " +
					hour +
					":" +
					minutes +
					":" +
					second;
					
					$('#currentTime').html(now_time);
				};
				
				setInterval(function (){
					showTime();	
				},1000)					
				
                // 周来料检验合格率图表
                const qualityChart = echarts.init(document.getElementById('qualityChart'));
                const qualityOption = {
                    tooltip: {
                        trigger: 'axis',
                        axisPointer: {
                            type: 'shadow'
                        }
                    },
                    grid: {
                        left: '3%',
                        right: '4%',
                        bottom: '3%',
                        containLabel: true
                    },
                    xAxis: {
                        type: 'category',
                        data: {:json_encode($week_materia_quality['xAxis'])},
                        axisLine: {
                            lineStyle: {
                                color: '#ccc'
                            }
                        },
                        axisLabel: {
                            color: '#ccc',
                            fontSize: 10
                        }
                    },
                    yAxis: {
                        type: 'value',
                        axisLine: {
                            lineStyle: {
                                color: '#ccc'
                            }
                        },
                        axisLabel: {
                            color: '#ccc',
                            fontSize: 10
                        },
                        splitLine: {
                            lineStyle: {
                                color: 'rgba(255, 255, 255, 0.1)'
                            }
                        }
                    },
                    series: [{
                        data: {:json_encode($week_materia_quality['series'])},
                        type: 'line',
                        smooth: true,
                        lineStyle: {
                            color: '#00ff88',
                            width: 2
                        },
                        itemStyle: {
                            color: '#00ff88'
                        },
                        areaStyle: {
                            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                                { offset: 0, color: 'rgba(0, 255, 136, 0.3)' },
                                { offset: 1, color: 'rgba(0, 255, 136, 0.1)' }
                            ])
                        }
                    }]
                };
                qualityChart.setOption(qualityOption);

                // 周入库量对比图表
                const storageChart = echarts.init(document.getElementById('storageChart'));
                const storageOption = {
                    tooltip: {
                        trigger: 'axis',
                        axisPointer: {
                            type: 'shadow'
                        }
                    },
                    grid: {
                        left: '3%',
                        right: '4%',
                        bottom: '3%',
                        containLabel: true
                    },
                    xAxis: {
                        type: 'category',
                        data: {:json_encode($week_product_stock['xAxis'])},
                        axisLine: {
                            lineStyle: {
                                color: '#ccc'
                            }
                        },
                        axisLabel: {
                            color: '#ccc',
                            fontSize: 10
                        }
                    },
                    yAxis: {
                        type: 'value',
                        axisLine: {
                            lineStyle: {
                                color: '#ccc'
                            }
                        },
                        axisLabel: {
                            color: '#ccc',
                            fontSize: 10
                        },
                        splitLine: {
                            lineStyle: {
                                color: 'rgba(255, 255, 255, 0.1)'
                            }
                        }
                    },
                    series: [{
                        data: {:json_encode($week_product_stock['series'])},
                        type: 'bar',
                        itemStyle: {
                            color: '#ff7e5f'
                        }
                    }]
                };
                storageChart.setOption(storageOption);


				var weeklyQualityOption = {
					xAxis: {
						type: 'category',
						data: ['不合格数', '合格数']
					},
					yAxis: {
						type: 'value'
					},
					series: [
						{
							label: {
								show: true,
								position: 'top'
							},
							data: [
								{
									value:{$week_order_produce_error_count},
									itemStyle: {color: '#FF0000'}
								},
								{
									value: {$week_order_produce_process_count},
									itemStyle: {color: '#25D6F2'}
								},								
							],
							type: 'bar'
						}
					]
				};
				
				var weeklyQualityChart = echarts.init(document.getElementById('weeklyQualityChart'), 'dark');	
				weeklyQualityChart.setOption(weeklyQualityOption);




				var monthQualityOption = {
					xAxis: {
						type: 'category',
						data: ['不合格数', '合格数']
					},
					yAxis: {
						type: 'value'
					},
					series: [
						{
							label: {
								show: true,
								position: 'top'
							},
							data: [
								{
									value:{$month_order_produce_error_count},
									itemStyle: {color: '#FF0000'}
								},
								{
									value: {$month_order_produce_process_count},
									itemStyle: {color: '#25D6F2'}
								},								
							],
							type: 'bar'
						}
					]
				};
				
				var monthQualityChart = echarts.init(document.getElementById('monthQualityChart'), 'dark');	
				monthQualityChart.setOption(monthQualityOption);

				var productionOption = {
					grid: {
						left: '10',
						right: '10',
						bottom: '30',
						top:0,
						containLabel: true
					},
					xAxis: {
						type: 'value',
						name: '元',
						axisLabel: {
							formatter: function(value) {
								return value;
							}
						}
					},
					yAxis: {
						type: 'category',
						inverse: true,
						data: {:json_encode($week_product_stock['xAxis'])},
					},
					
					series: [
						{
							name: 'City Alpha',
							type: 'bar',
							label:{
								show:true,
								formatter: '{c}',
								textStyle:{
									'color':'#ffffff'
								}
							},
							data: {:json_encode($week_product_stock['series'])},
						},
					]
				};
				var productionChart = echarts.init(document.getElementById('productionChart'), 'dark');	
				productionChart.setOption(productionOption);


                // 响应式处理
                window.addEventListener('resize', function() {
                    qualityChart.resize();
                    storageChart.resize();
                    productionChart.resize();
                });
            });
        </script>
{/block}