{extend name="base" /}
{block name="body"}
<div class="layui-card">
	<div class="layui-card-body">
		<div class="layui-tab layui-tab-brief">
			<ul class="layui-tab-title">
				<a href="{:url('list')}?data_type=1"><li {if $data_type == 1}class="layui-this"{/if}>零件指导书</li></a>
				<a href="{:url('list')}?data_type=2"><li {if $data_type == 2}class="layui-this"{/if}>部件指导书</li></a>
				<a href="{:url('list')}?data_type=3"><li {if $data_type == 3}class="layui-this"{/if}>出厂指导书</li></a>
			</ul>
		</div>		
		<form class="layui-form" action="">
			<div class="layui-form-item">
				<div class="layui-form-item layui-inline">
					<input type="text" name="name" placeholder="名称" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="code" placeholder="编码" class="layui-input">	
				</div>				
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-danger pear-btn-sm" lay-event="batchRemove"><i class="layui-icon layui-icon-delete"></i>删除</button>
</script>
<script type="text/html" id="options">
	<button class="pear-btn pear-btn-primary pear-btn-xs" lay-event="edit"><i class="layui-icon layui-icon-edit"></i></button>
	<button class="pear-btn pear-btn-danger pear-btn-xs" lay-event="remove"><i class="layui-icon layui-icon-delete"></i></button>
</script>
<script type="text/html" id="attachment">
	{{#  if(d.is_image){ }}
		<a onclick="layerPhotos(this)" data-href="{{ d.attachment }}" target="_blank" >文件查看</a>
	{{#  }else{ }}
		<a onclick="openLayer('{{ d.name }}','{{ d.attachment }}','90%','90%')" target="_blank" >文件查看</a>
	{{#  } }}
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('list')}?data_type={$data_type}',
			page: true,
			limit:90,
			height:'full-210',
			cols: [[
				{type: 'checkbox'},
				{field: 'code',title: '编码',align: 'center',width: {:get_col_width('code')}, hide: getTableFieldIsHide('dataTable','code')},
				{field: 'name',title: '名称',align: 'center',width: {:get_col_width('name')}, hide: getTableFieldIsHide('dataTable','name')},
				{if $data_type != 3}{field: 'material_category',title: '类型',align: 'center',width: {:get_col_width('material_category')}, hide: getTableFieldIsHide('dataTable','material_category')},{/if}	
				{field: 'version',title: '版本',align: 'center',width: {:get_col_width('version')}, hide: getTableFieldIsHide('dataTable','version')},
				{field: 'create_time',title: '创建时间',align: 'center',width: {:get_col_width('create_time',170)}, hide: getTableFieldIsHide('dataTable','create_time')},
				{field: 'status_desc',title: '状态',align: 'center',width: {:get_col_width('status_desc',100)}, hide: getTableFieldIsHide('dataTable','status_desc')},
				{field: 'attachment',title: '文件',align: 'center',width: {:get_col_width('attachment',100)},templet: '#attachment', hide: getTableFieldIsHide('dataTable','attachment')},
				{title: '操作',toolbar: '#options',align: 'center',width: 130,unresize:true}
			]],
			cellMinWidth: 100,
			//skin: 'line',
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'remove') {
				layerConfirm('确定要删除该指导书?','{:url('remove')}',{ids:[obj.data['id']]},function(res){
					obj.del();
				})
			} else if (obj.event === 'edit') {
				openLayer('修改指导书','{:url('edit')}?data_type={$data_type}&id='+obj.data['id'],'80%','90%');
			}
		});

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增指导书','{:url('add')}?data_type={$data_type}','80%','90%');
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			} else if (obj.event === 'batchRemove') {
				tableAction(obj.config.id,'确定要删除这些指导书','{:url('remove')}');
			}else if (obj.event === 'import') {
				openLayer('导入','{:url('import')}','90%','90%');
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
	
				}
			});
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
		
	})
</script>
{/block}


