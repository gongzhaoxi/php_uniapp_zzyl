layui.use(['form','upload','laydate','table','jquery','element','util','tinymce','tag','select'], function() {
	var form = layui.form;
	var layer = layui.layer;
	var laydate = layui.laydate;
	var upload = layui.upload;
	var table = layui.table;
	var $ = layui.jquery;
	var element = layui.element;
	var util = layui.util;
	var tinymce = layui.tinymce;
	var tag = layui.tag;
	let select = layui.select;
	
	$('.tinymce_editor').each(function(){
		var id = $(this).attr('id');
		var upload_url = $(this).data('url');
		tinymce.render({
			selector: '#'+id,
			height: 400,
			convert_urls : false,
			setup: function(editor){ 
				editor.on('change',function(){ editor.save(); });
			},
			images_upload_handler : function(blobInfo, succFun, failFun) {           
				var formData = new FormData();
				formData.append('file', blobInfo.blob());
				formData.append('path','image');
				var ajaxOpt = {
					url: upload_url,
					dataType: 'json',
					type: 'POST',
					data: formData,
					processData: false,
					contentType: false,
					success: function (res) {
						if (res.code == 200) {
							succFun(res.data.thumb);
						} else {
							failFun(res.msg);
						}
					},
					error: function (res) {
						failFun("网络错误：" + res.status);
					}
				};
				$.ajax(ajaxOpt);
			}
		});				
	})
	
	/**
	 * 通用表单提交(AJAX方式)
	 */
	form.on('submit(*)', function (data) {
		formSubmit(data);
		return false;
	});	
	
	window.formSubmit = function(data){
		//console.log(data.field) 
		var fields = data.field;
		if($(data.elem).data('act')){
			fields.act = $(data.elem).data('act');
		}else{
			//var fields = $(data.form).serialize();
			//data:JSON.stringify(data.field),
		}
		var url 		= $(data.form).attr('action');
		if($(data.elem).data('form_url')){
			url 		= $(data.elem).data('form_url');
		}

		var msg 		= $(data.form).data('msg');
		var reload 		= $(data.form).data('reload');
		var back_url	= $(data.form).data('back_url');	
		var callback	= $(data.form).data('callback');
		var table_id 	= $(data.form).data('table');
		var noshowmsg 	= $(data.form).data('noshowmsg');

		if($(data.elem).data('reload')){
			reload 		= $(data.elem).data('reload');
		}

		var method_type	= $(data.form).attr('method')?$(data.form).attr('method'):'post';
		if(msg && confirm(msg) == false){
			return false;
		}
		
		$(data.elem).attr('disabled',true).addClass('layui-btn-disabled');
		
		var load_index 	= layer.load(2);		
		$.ajax({
			url: url,
			type: method_type,
			dataType:'json',
			data: fields,
			timeout: 300000,
			error: function(jqXHR, error, errorThrown) {
				layer.alert('请求错误:'+error, function () {
					$(data.elem).removeAttr('disabled').removeClass('layui-btn-disabled');
					layer.closeAll();
				});
			},
			success: function (res) {
				layer.close(load_index);
				
				setTimeout(function(){
					$(data.elem).removeAttr('disabled').removeClass('layui-btn-disabled');
				}, 1500);
				
				//判断有没有权限
				if (res && res.code == 999) {
					layer.msg(res.msg, {
						icon: 5,
						time: 2000,
					})
					return false;
				} else if (res.code == 200) {
					if(noshowmsg == 1){
						window.successReload(reload,back_url,table_id,callback,res,data)
					}else{
						layer.msg(res.msg,{icon:1,time:1000}, function () {
							window.successReload(reload,back_url,table_id,callback,res,data)
						});
					}	
				} else {
					layer.msg(res.msg,{icon:2,time:1000});
				}
			}
		});
		return false;	
	}
	
	
	
	window.successReload = function(reload,back_url,table_id,callback,info,data) {
		table_id = table_id?table_id:'dataTable';
		if(reload == 2) {
			setTimeout(function () {location.reload();}, 1000);
		}else if(reload == 3) {
			setTimeout(function () {parent.location.reload();}, 1000);
		}else if(reload == 4) {
			setTimeout(function () {parent.layer.close(parent.layer.index);	}, 1000);
		}else if(reload == 5 && back_url) {
			setTimeout(function () {location.replace(back_url);	}, 1000);
		}else if(reload == 6) {
			parent.layui.table.reload(table_id);
			setTimeout(function () {location.reload(true);}, 1000);
		}else if(reload == 7 && callback) {
			setTimeout(function () { window[callback](info,data);  }, 1000);
		}else if(reload == 8) {
			parent.layui.table.reload(table_id);
			setTimeout(function () {location.reload(true);}, 1000);
		}else{
			parent.layer.close(parent.layer.getFrameIndex(window.name));//关闭当前页
			parent.layui.table.reload(table_id);
		}
	}
	
	//弹出窗设置 自己设置弹出百分比
	window.screen = function() {
		if (typeof width !== 'number' || width === 0) {
			width = $(window).width() * 0.8;
		}
		if (typeof height !== 'number' || height === 0) {
			height = $(window).height() - 20;
		}
		return [width + 'px', height + 'px'];
	}	
	
	window.ajaxActionCall = function(url,data,callback,showMsg=true,dataType,ajaxType){
		if(!dataType){
			dataType = 'json';
		}
		if(!ajaxType){
			ajaxType = 'POST';
		}
		var load_index = layer.load(2);
		$.ajax({
			type: ajaxType,
			url:url,
			data: data,
			dataType: dataType,
			success: function(res){
				layer.close(load_index);
				//判断有没有权限
				if(res && res.code==999){
					layer.msg(res.msg, {
						icon: 5,
						time: 2000, 
					})
					return false;
				}else if (res.code==200) {					
					if(showMsg == true){
						layer.msg(res.msg, {
							icon: 1,
							time: 1000
						}, function() {
							callback && callback(res);
						});
					}else{
						callback && callback(res);
					}
				} else {
					layer.msg(res.msg, {
						icon: 2,
						time: 1000
					});
				}
				return false;		     
			},
			error : function() {
				alert('失败。');
			}
		});
	}
	window.layerConfirm = function(msg,url,data,callback,showMsg=true,cancelCall){
		if(msg){
			/*
			layer.open({
				shade: [0.3],
				content: msg,
				btn: ['确定', '取消'],
				yes: function (index) {
					layer.close(index);
					ajaxActionCall(url,data,callback,showMsg);
				},
				cancel: function(index, layero, that){
					cancelCall && cancelCall();
					layer.close(index);
				}
			});*/
			var flag = false;
			layer.confirm(msg, {
				btn: ['确定', '取消']
			}, function(index){
				if (!flag){
					flag = !flag;
					setTimeout(function(){
						ajaxActionCall(url,data,callback,showMsg);
					}, 300);
				}
				layer.close(index);
			}, function(){
				cancelCall && cancelCall();
			});			
			
			
		}else{
			ajaxActionCall(url,data,callback,showMsg);
		}
	}
	
	
	form.verify({
		amount: function(value, item){
			if(!/^[1-9]\d*(?:\.\d{1,2}|\d*)$/.test(value)){
				return '格式错误';
			}
		},
		checkbox: function(value, item){	
			var max = $(item).data('max');
			var min = $(item).data('min');
			var msg = $(item).data('msg');
			var num = $("input[name='"+$(item).attr('name')+"']:checked").length;
			if(min == 0){
				
			}else{
				if(parseInt(num) == 0){
					return typeof(msg) != "undefined"?msg:'请选择';
				}			
				if(typeof(min) != "undefined" && parseInt(min) > parseInt(num)){
					return typeof(msg) != "undefined"?msg:'请至少选择'+min+'个';
				}
			}
			if(max == 0){
			
			}else{
				if(typeof(max) != "undefined" && parseInt(num) > parseInt(max)){
					return typeof(msg) != "undefined"?msg:'最多只能选择'+max+'个';
				}
			}
		}
	});      	
	
