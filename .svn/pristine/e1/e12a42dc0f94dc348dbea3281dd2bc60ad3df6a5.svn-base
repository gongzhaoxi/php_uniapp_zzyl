	$("body").on("click",".opt_photo",function(){
		var btn = $(this);
		layer.open({
			type: 2,
			maxmin: true,
			title: "图库选择",
			shade: 0.1,
			area: screen(),
			content:btn.data('url'),
			success:function (layero,index) {
				var iframe = window["layui-layer-iframe" + index];
				iframe.child(function(data){
					if(btn.data('type') == 'radio'){
						btn.parent().find('.priview').html('');
						btn.parent().find('.priview').append('<li class="item_img"><img onclick="layerPhotos(this)" data-href="' + data[0].link + '"  src="' +data[0].link + '" class="img" ><input type="hidden" name="'+btn.data('name')+'" value="' + data[0].href + '" /></li>');
					}else{
						for(var i = 0;i < data.length;i++){
							btn.parent().find('.priview').append('<li class="item_img"><div class="operate"><i class="toleft layui-icon layui-icon-left"></i><i class="toright layui-icon layui-icon-right"></i><i class="close layui-icon layui-icon-close"></i></div><img onclick="layerPhotos(this)" data-href="' + data[i].link + '"  src="' +data[i].link + '" class="img" ><input type="hidden" name="'+btn.data('name')+'[]" value="' + data[i].href + '" /></li>');
						}
					}
					
					layer.close(index);
				})
			}
		});
	});	


	window.renderAttachment = function(elem){
		$(elem).each(function(){
			upload.render({
				elem: this,
				before: function(obj) {
					layer.msg('文件上传中...', {
						icon: 16,
						shade: 0.01,
						time: 0
					})
				},
				done: function(res, index, upload){
					layer.close(layer.msg());//关闭上传提示窗口
					layer.msg(res.msg);
					if(res.code == 200) {
						var item = this.item;
						$(item).parent().find('input[type=hidden]').val(res.data.file.id);
					}
				} ,
			});
		})
	}
	
	window.renderAttachment('.uload_attachment');

	window.layerPhotos = function(str,id){
		if(typeof(str) == 'object'){
			str = $(str).attr('data-href');
		}
		if(str){
			var tmp 	= str.split(",");
			var data	= [];
			for(var i = 0;i < tmp.length;i++){
				data[i]	= {"src": tmp[i],"thumb": tmp[i]};
			}
			if(typeof(window.top.layer) != "undefined") {
				window.top.layer.photos({
					photos: {
						"title": "", 
						"id": id, 
						"start": 0, 
						"data": data
					},
					anim: 5 
				});
			}else{
				layer.photos({
					shade: 0,
					photos: {
						"title": "", 
						"id": id, 
						"start": 0, 
						"data": data
					},
					anim: 5 
				});
			}	
		}
	}

	window.openLayer = function(title,url,w,h,endCallBack){
		if(w && h){
			if (title == null || title == '') {
				title=false;
			};
			if (url == null || url == '') {
				url="/404.html";
			};
			if (w == null || w == '') {
				w = '800px';
			};
			if (h == null || h == '') {
				h = ($(window).height() - 50) + 'px';
			};
			layer.open({
				type: 2,
				area: [w,h],
				fix: false, //不固定
				maxmin: true,
				shade:0.4,
				title: title,
				scrollbar: false,
				content: url,
				cancel: function () {
					//cancelCallBack && cancelCallBack();
				},
				end: function() {
					endCallBack && endCallBack();
				},
				success: function(layero, index){
					$('#layui-layer'+index+' .layui-layer-setwin .layui-icon-close').remove();
					$('#layui-layer'+index+' .layui-layer-setwin').append('<span class="layui-icon layui-icon-close layui-layer-close layui-layer-close1"></span>');
					$('#layui-layer'+index+' .layui-layer-close').off('click').on('click', function(){
						layer.confirm('确认关闭?', function(confirm_index){
							layer.close(confirm_index);
							layer.close(index);
						}); 
					});				
				}
			});
		}else{
			var index = layer.open({
				type: 2,
				area: ['100%','100%'],
				title: title,
				content: url
			});
		}
	}

	window.tableAction = function(table_id,msg,url,reload=1,callback){
		msg = msg?msg:'确定执行此操作？';
		var checkStatus = table.checkStatus(table_id);
		if(checkStatus.data.length == 0){
			layer.msg('请选择要操作的内容');
			return false;
		}
		var ids = [];
		for(var i in checkStatus.data) {
			ids.push(checkStatus.data[i].id);
		}
		layer.open({
			shade: false,
			content: msg,
			btn: ['确定', '取消'],
			yes: function (index) {
				$.ajax({
					url: url,
					dataType:'json',
					data: {ids:ids},
					type:'POST',
					success: function (info) {
						layer.msg(info.msg,function(){
							if(info.code === 200) {
								if(reload == 2) {
									location.reload(true);
								}else if(reload == 3) {
									parent.location.reload(true);
								}else if(reload == 4) {
									parent.layer.close(parent.layer.index);
								}else if(reload == 5) {
									parent.layui.table.reload(table_id);
									location.reload(true);
								}else if(callback) {
									window[callback](info);
								}else{
									layui.table.reload(table_id);
								}
							}
						});
					}
				});
				layer.close(index);
			}
		});
	}


	window.toPrintPage = function(type,data){
		//type
		//1为仓库物料入库单，2为仓库物料次品退货单，3为仓库物料出库单，4为仓库物料盘点单，data为{id:1}对应erp_material_stock的id
		//11为销售打印确认单，12为销售打印订货单，13为打印“国内”包装标签，14为销售打印“国外”包装标签，15打印价格确认单，data为{id:1}对应erp_order的id
		//21为计划打印标签，22为计划打印领料单，23为计划打印需求单，data为{id:'1,2,3'}对应erp_order_produce的id
		//31为下达部件库存打印领料单，32为下达部件库存打印需求单，33为下达部件库存打印排产单，data为{id:'1,2,3'}对应erp_material_plan的id
		//41销售打印“国内”发货通知单，42销售打印“国外”发货通知单data为{order_id:1,order_produce_id:'1,2,3'}
		//51打印产品出仓（发货）单data为{id:'1,2,3'}对应结构erp_order_shipping的id
		
		if(jmreport[type]){
			
			if(type == 22 || type == 26 || type == 8 || type == 3 || type == 29 || type == 9 || type == 70 || type == 72  || type == 74 || type == 82){
				
				$.ajax({                         
					url:print_add_url,
					dataType: 'json',
					type: 'POST',
					data: {data:data.id},
					success:function(res){
						console.log(res);
						window.top.openLayer('打印',jmreport[type]+'?id='+res.id,'80%','80%');
					}
				});
				
				/*
				window.top.layui.layer.open({
					type: 2
					,title: '打印'
					,content: '/blank.html'
					,area: ['80%','80%']
					,success: function(layero, index){
						var body = layero.find('iframe').contents().find('body');
						var $form = $('<form method="post"></form>');
						$form.attr('action', jmreport[type]);
						//$form.css({'display': 'none',});
						for (var k in data) {
							if($.isArray(data[k])){
								$form.append($('<input type="hidden" name="'+k+'" value="'+data[k].join(',')+'">'));
							}else{
								$form.append($('<input type="hidden" name="'+k+'" value="'+data[k]+'">'));
							}
						}
						$form.appendTo(body);
						$form.submit();		
					}
				});*/
			}else{
				window.top.openLayer('打印',jmreport[type]+'?'+jsonToUrlParam(data),'80%','80%');
			}
			
		}
	}

	function jsonToUrlParam(json) {
		return Object.keys(json).map(key => key + '=' + json[key]).join('&');
	}


	window.exportData = function(url,param={},limit=''){
		var load_index 	= layer.load(2, {shade: [0.3,'#000']});
		var key = '';
		limit = limit?limit:10000;
		param.export_act=1;
		if(url.indexOf('?') == -1){
			url = url + '?';
		}
		ajaxActionCall(url,param,function(res){
			key = res.data.key;
			if(res.code == 200){
				var count = parseInt(res.data.count);
				var page_num = Math.ceil(count/limit);
				if(count > limit){
					param.export_act=2;
					param.limit=limit;
					param.key=key;
					for(var page=1;page<=page_num;page++){					
						param.page=page;					
						var res = $.ajax({
							type: "get",
							url: url+jsonToUrlParam(param),
							cache: false,
							async: false,
							dataType:'json',
						});								
					}
					param.export_act=3;
					var res = $.ajax({
						type: "get",
						url: url+jsonToUrlParam(param),
						cache: false,
						async: false,
						dataType:'json',
					});	
					layer.close(load_index);	
					const link = document.createElement("a");
					link.href = res.responseJSON.path;
					link.click();
				}else{
					param.export_act='';
					layer.close(load_index);	
					location = url+jsonToUrlParam(param);
				}
			}
		},false)	
	}


	/**
	 * 通用表单批量处理（审核、取消审核、删除）
	 */
