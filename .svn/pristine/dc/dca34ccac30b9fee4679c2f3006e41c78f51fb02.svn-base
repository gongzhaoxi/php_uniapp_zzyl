<?php
declare (strict_types = 1);
namespace app\admin\controller\erp;
use app\admin\logic\{MaterialEnterMaterialReportlLogic,ErpSupplierLogic,ErpMaterialEnterMaterialLogic};
use app\common\util\Excel;
use app\common\util\FileUtil;
use app\common\util\ZipUtils;
class MaterialEnterMaterialReport extends \app\admin\controller\Base
{
    // 列表
    public function list(){
        if ($this->request->isAjax()) {
			return $this->getJson(MaterialEnterMaterialReportlLogic::getList($this->request->param(),$this->request->param('limit')));
        }
        return $this->fetch('',['supplier'=>ErpSupplierLogic::getAll()]);
	}

	//导出
    public function export($export_act=0){
		ini_set("memory_limit","-1");
		ini_set('max_execution_time', '60');
		$key 			= preg_replace( '/[\W]/', '', $this->request->param('key',''));
		if($export_act == 1){
			return $this->getJson(MaterialEnterMaterialReportlLogic::getCount($this->request->param(),$this->request->param('limit',10000)));
		}else if($export_act == 2 && $key){
			$page 		= $this->request->param('page');
			$data 		= MaterialEnterMaterialReportlLogic::getExport($this->request->param(),$this->request->param('limit',10000));
			$dir 		= './download/'.$key.'/';
			$fileUtil 	= new FileUtil();
			$fileUtil->createDir($dir);
			Excel::go("进货检验报告", $data['column'], $data['setWidh'], $data['list'], $data['keys'],$page,$data['image_fields'],$dir);
			return $this->getJson();
		}else if($export_act == 3 && $key && is_dir('./download/'.$key)){
			ZipUtils::zip('./download/'.$key,'./download/'.$key.'.zip');
			return json(['path'=>'/download/'.$key.'.zip']);
		}else{
			$data 		= MaterialEnterMaterialReportlLogic::getExport($this->request->param(),$this->request->param('limit',10000));
			Excel::go('进货检验报告', $data['column'], $data['setWidh'], $data['list'], $data['keys'],"进货检验报告",$data['image_fields']);
			exit;
		}
    }
	
    // 检验报告
    public function download(){
		$model = ErpMaterialEnterMaterialLogic::getOne($this->request->param('id/d'));
		if(empty($model['report']) || $model['report']['status'] == 1){
			return '报告未完成';
		}
		return $this->fetch('index@erp_material_enter_material/report',['model' => $model,'download' => 1,'hidden' => 1]);
    }	
	
}
