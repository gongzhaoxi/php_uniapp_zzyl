{extend name="base" /}
{block name="body"}
<style>
.layui-input-block {margin-left: 150px;}
.layui-form-label {width: 120px;}
</style>
<form class="layui-form" action="" method="post" data-reload="3">
	<input type="hidden" name="id" value="{$model['id']}" >
	<div class="mainBox">
		<div class="main-container">
			<div class="layui-form-item">
				<div class="layui-row">
					<div class="layui-col-md4">
						<label class="layui-form-label">物料编码</label>
						<div class="layui-input-block">
							<input type="hidden" name="material_id" id="material_id">
							<input type="text" name="material_sn" id="material_sn" value="{$model['material_sn']}" readonly lay-verify="required" ts-selected=""  placeholder="请选择,不可为空" autocomplete="off" class="layui-input">
						</div>
					</div>
					<div class="layui-col-md4">
						<label class="layui-form-label">物料名称</label>
						<div class="layui-input-block">
							<input type="text" name="material_name" id="material_name" value="{$model['material_name']}" readonly lay-verify="required"   placeholder="" autocomplete="off" class="layui-input">
						</div>
					</div>
					<div class="layui-col-md4">
						<label class="layui-form-label">物料分类</label>
						<div class="layui-input-block">
							<input type="text" name="material_category" id="material_category" value="{$model['material_category']}" readonly  placeholder="" autocomplete="off" class="layui-input">
						</div>
					</div>				
				</div>
			</div>
			<div class="layui-form-item">
				<div class="layui-row">
					<div class="layui-col-md4">
						<label class="layui-form-label">数量</label>
						<div class="layui-input-block">
							<input type="text" name="material_num"  id="material_num" lay-verify="required|number"  value="{$model['material_num']}"  placeholder="" autocomplete="off" class="layui-input cal_price">
						</div>
					</div>	
					<div class="layui-col-md4">
						<label class="layui-form-label">备注</label>
						<div class="layui-input-block">
							<input type="text" name="remark"  value="{$model['remark']}" placeholder="" autocomplete="off" class="layui-input">
						</div>
					</div>						
				</div>
			</div>
		</div>
	</div>
	<div class="bottom">
		<div class="button-container">
			<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm" lay-submit="" lay-filter="*"><i class="layui-icon layui-icon-ok"></i>提交</button>
		</div>
	</div>
</form>
{/block}
{block name="script"}
<script>

layui.use(['tableSelect'], function () {
	var $ = layui.jquery;
	var tableSelect = layui.tableSelect,form = layui.form;
	
});
</script>
{/block}