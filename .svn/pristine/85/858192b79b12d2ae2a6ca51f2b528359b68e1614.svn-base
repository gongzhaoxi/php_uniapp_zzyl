{extend name="base" /}
{block name="body"}
<style>
.tool-button{}
</style>
<div class="layui-card" style="margin-bottom: 1px;">
	<div class="layui-card-body" >
		<form class="layui-form" action=""  id="searchForm"  lay-filter="searchForm">
			<div class="layui-form-item" style="margin-bottom: 5px;">			
				<div class="layui-form-item layui-inline">
					<input type="text" name="customer_name" placeholder="客户名称/订货单位" class="layui-input">					
				</div>	
				<div class="layui-form-item layui-inline">
					<input type="text" name="order_sn" placeholder="销售合同号" class="layui-input">	
				</div>	
				<div class="layui-form-item layui-inline" style="width:190px;">
					<input type="text" name="create_time" placeholder="下单日期" class="layui-input rangedate">	
				</div>	
				<div class="layui-form-item layui-inline" style="width:190px;">
					<input type="text" name="delivery_time" placeholder="交货日期" class="layui-input rangedate">	
				</div>	
				<div class="layui-form-item layui-inline" style="width:120px;">
					<select name="region_type">
						<option value="">订单属性</option>
						{foreach $region_type as $key=>$vo}
						<option value="{$key}">{$vo}</option>
						{/foreach}
					</select>			
				</div>	
				<div class="layui-form-item layui-inline" style="width:120px;">
					<select name="shipping_status">
						<option value="">发货状态</option>
						{foreach $shipping_status as $key=>$vo}
						<option value="{$key}">{$vo}</option>
						{/foreach}
					</select>			
				</div>				
				<div class="layui-form-item layui-inline">
					<button class="pear-btn pear-btn-md pear-btn-primary" lay-submit lay-filter="query"><i class="layui-icon layui-icon-search"></i>查询</button>
					<button type="reset" class="pear-btn pear-btn-md"><i class="layui-icon layui-icon-refresh"></i>重置</button>					
				</div>
			</div>
		</form>
	</div>
</div>
<div class="layui-card">
	<div class="layui-card-body">		
		<div class=" order_status">
			<a href="{:url('list')}?order_status=0" class="layui-btn  layui-btn-primary">全部</a>
			{foreach $order_status as $key=>$vo}
			<a href="{:url('list')}{$vo['value']}" class="layui-btn  layui-btn-primary" id="order_status_{$key}">{$vo['name']}<i class="layui-icon">({$vo['count']})</i></a>
			{/foreach}
		</div>
		<table id="dataTable" lay-filter="dataTable"></table>
	</div>
</div>
<script type="text/html" id="toolbar">
	<button class="pear-btn pear-btn-primary pear-btn-sm" lay-event="add"><i class="layui-icon layui-icon-add-1"></i>新增</button>
	<button class="pear-btn pear-btn-sm pear-btn-success" lay-event="export"><i class="layui-icon layui-icon-download-circle"></i>导出</button>
	<!--<button class="pear-btn pear-btn-sm" lay-event="recycle"><i class="layui-icon  layui-icon-close-fill"></i>回收站</button>-->
</script>
<script type="text/html" id="options">
	<div class="layui-btn-group">
		<button class="layui-btn layui-btn-normal layui-btn-xs" lay-event="view">查看</button>
		{{#  if(d.can_remove){ }}<button class="layui-btn layui-btn-danger layui-btn-xs" lay-event="remove">删除</button>{{#  } }}
	</div>
</script>
{/block}
{block name="script"}
<script>
	layui.use(['table', 'form', 'jquery','common'], function() {
		let table = layui.table;
		let form = layui.form;
		let $ = layui.jquery;

		table.render({
			elem: '#dataTable',
			url: '{:url('list')}?order_status={$query['order_status']|default=''}&salesman_approve={$query['salesman_approve']|default=''}',
			page: true,
			limit:90,
			height:'full-190',
			cols: [[
				{field: 'region_type_desc',title: '订单性质',align: 'center',unresize: false,width: {:get_col_width('region_type_desc',100)}, hide: getTableFieldIsHide('dataTable','region_type_desc')},
				{field: 'customer_name',title: '客户名称/订货单位',align: 'center',unresize: false,width: {:get_col_width('customer_name')}, hide: getTableFieldIsHide('dataTable','customer_name')},
				{field: 'order_sn',title: '售后单号',align: 'center',unresize: false,width: {:get_col_width('order_sn',140)}, hide: getTableFieldIsHide('dataTable','order_sn')},
				{field: 'sale_order_sn',title: '关联销售单号',align: 'center',unresize: false,width: {:get_col_width('sale_order_sn',140)}, hide: getTableFieldIsHide('dataTable','sale_order_sn')},
				{field: 'address',title: '收货地址/国家',align: 'center',unresize: false,width: {:get_col_width('address',200)}, hide: getTableFieldIsHide('dataTable','address')},
				{field: 'order_product_num',title: '数量',align: 'center',unresize: false,width: {:get_col_width('order_product_num',120)}, hide: getTableFieldIsHide('dataTable','order_product_num')},
				{field: 'salesman_name',title: '销售员',align: 'center',unresize: false,width: {:get_col_width('salesman_name',100)}, hide: getTableFieldIsHide('dataTable','salesman_name')},
				{field: 'create_date',title: '下单日期',align: 'center',unresize: false,width: {:get_col_width('create_date',120)}, hide: getTableFieldIsHide('dataTable','create_date')},
				{field: 'delivery_time',title: '交货日期',align: 'center',unresize: false,width: {:get_col_width('delivery_time',120)}, hide: getTableFieldIsHide('dataTable','delivery_time')},
				{field: 'order_status_desc',title: '订单状态',align: 'center',unresize: false,width: {:get_col_width('order_status_desc',100)}, hide: getTableFieldIsHide('dataTable','order_status_desc')},
				{field: 'shipping_status_desc',title: '发货状态',align: 'center',unresize: false,width: {:get_col_width('shipping_status_desc',100)}, hide: getTableFieldIsHide('dataTable','shipping_status_desc')},
				{title: '操作',toolbar: '#options',align: 'center',unresize: true,width: 140,fixed: 'right'}
			]],
			cellMinWidth: 100,
			toolbar: '#toolbar',
			defaultToolbar: [{
				title: '刷新',
				layEvent: 'refresh',
				icon: 'layui-icon-refresh',
			}, 'filter']
		});

		table.on('sort(dataTable)', function(obj){
			table.reload('dataTable', {
				initSort: obj,
				where: {
					sort: obj.field,
					order: obj.type
				}
			},true);
		});

		table.on('tool(dataTable)', function(obj) {
			if (obj.event === 'remove') {
				layerConfirm('确定要删除该售后单?','{:url('remove')}',{ids:[obj.data['id']]},function(res){
					table.reload('dataTable');
					getOrderStat();
				})
			}else if (obj.event === 'cancel') {
				layerConfirm('确定要取消该售后单?','{:url('cancel')}',{ids:[obj.data['id']]},function(res){
					table.reload('dataTable');
					getOrderStat();
				})
			}else if (obj.event === 'view') {
				openLayer('查看订单','{:url('view')}?id='+obj.data['id'],'100%','100%',function(){
					table.reload('dataTable');
					getOrderStat();
				});
			}
		});

		function getOrderStat(){
			ajaxActionCall('{:url('common/orderStat')}?type=2',{},function(res){
				$.each(res.data,function (index,val) {
					$('#order_status_'+index+' .layui-icon').html('('+val.count+')');
				});			
			},false)
		}

		table.on('toolbar(dataTable)', function(obj) {
			if (obj.event === 'add') {
				openLayer('新增售后单','{:url('add')}','90%','90%',function(){
					getOrderStat();
				});
			}else if (obj.event === 'refresh') {
				table.reload('dataTable');
			}else if (obj.event === 'recycle') {
				openLayer('回收站','{:url('recycle')}?data_type=2','90%','90%',function () {
					table.reload('dataTable');
					getOrderStat();
				});
			}else if (obj.event === 'export') {
				var data = form.val('searchForm');
				exportData('{:url('export')}',data);
			}
		});

		form.on('submit(query)', function(data) {
			table.reload('dataTable', {
				where: data.field,
				page:{curr: 1}
			})
			return false;
		});	
		
		let _href = (window.location.href).toLowerCase() ;
		$('.order_status a').each(function(index){
			if($(this).attr('href') && _href.indexOf($(this).attr('href').toLowerCase()) != -1){
				$(this).addClass('pear-btn-warming');
			}
		})
		if($('.order_status .pear-btn-warming').length == 0){
			$('.order_status a').eq(0).addClass('pear-btn-warming');
		}
		
		table.on('colResized(dataTable)', function(obj){
			$.ajax({
				type : "post",
				url : "{:url('Common/setColWidth')}",
				data: {field:obj.col.field,width:obj.col.width,path:'{:request()->baseUrl()}'},
				success : function(data) {
					
				}
			});
		});
		table.on('colToggled(dataTable)', function(obj){
			setTableFieldIsHide(obj.config.id,obj.col.field,obj.col.hide);
		});
	})
</script>
{/block}


