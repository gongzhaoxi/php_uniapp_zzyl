{extend name="base" /}
{block name="body"}
<style>
.layui-table td, .layui-table th {padding: 9px 0px;}
.item {min-height: 170px;}
.item .layui-row{background: rgb(242, 242, 242);padding:20px;height:232px;}
.item .layui-row .layui-form-label{width: 60px;}
.item .layui-row .layui-input-block {margin-left: 90px;}
.item .layui-row .layui-form-item {margin-bottom: 10px !important;margin-top: 0px !important;}
.layui-table td{border-color: #000 !important; color: #000 !important;}
.bottom {
    position: fixed;
}
@media print {
	.no-print {
		display: none;
	}
	.layui-input,.layui-textarea{
		border:none;
	}
	.floer {
	  margin-bottom: 0px;
	}	
}
</style>
<form class="layui-form" action="{:url('processFinish')}" method="post">
	<input type="hidden" name="produce_sn" value="{$produce['produce_sn']}" >
	<input type="hidden" name="process_id" value="{$process['id']|default=''}" >
	<div class="">
		<div class="main-container">
			<table class="layui-table" >
				<colgroup>
					<col width="15%">
					<col>
					<col width="10%">
					<col width="10%">
					<col width="15%">
					<col width="15%">
					<col width="15%">
				</colgroup>
				<tbody>
					<tr>
						<td colspan="7" align="center">
							<h3>部件随工单</h3>
						</td>
					</tr>
					<tr>
						<td colspan="7">
							ZA4-S01-001  A/3
						</td>
					</tr>	
					<tr>
						<td align="center">订单号</td>
						<td align="center">
							{$produce['order']['order_sn']}
						</td>
						<td align="center" colspan="2">生产单号：</td>
						<td align="center">
							{$produce['order_sn']}
						</td>						
						<td align="center">型 号</td>
						<td align="center">
							{$produce['order_product']['product_model']}({$produce['order_product']['product_specs']})
						</td>						
					</tr>
					<tr>
						<td align="center">客户名称：</td>
						<td align="center">
							{$produce['order']['customer_name']}
						</td>
						<td align="center" colspan="2">生产日期：</td>
						<td align="center">
							{$produce['produce_date']}
						</td>						
						<td align="center">产品序列号</td>
						<td align="center">
							{$produce['produce_finish_sn']}
						</td>						
					</tr>					
					<tr>
						<td align="center">生产地点</td>
						<td colspan="6" align="center">
							置安公司牙科综合治疗机生产车间
						</td>
					</tr>
					<tr>
						<td align="center">生产依据</td>
						<td colspan="6" align="center">
							本公司发布的《牙椅综合治疗机生产作业指导书》
						</td>
					</tr>	
					{foreach $component as $vo}
					<tr>
						<td align="center">部件编号</td>
						<td align="center">
							{$vo['sn']}
						</td>
						<td align="center" colspan="2">部件名称：</td>
						<td align="center">
							{$vo['name']}
						</td>						
						<td align="center">数量</td>
						<td align="center">
							{$vo['num']}
						</td>						
					</tr>
					{/foreach}						
					<tr>
						<td colspan="7" align="center">
							<h3>相关零部件</h3>
						</td>
					</tr>					
					<tr>
						<td align="center">物料编号</td>
						<td align="center">名     称</td>
						<td align="center">数量</td>						
						<td align="center">单位</td>
						<td align="center">物料批号/编号</td>	
						<td align="center">领料单/调拨</td>	
						<td align="center">备注</td>	
					</tr>					
					{foreach $partn as $vo}
					<tr>
						<td align="center">{$vo['sn']}</td>
						<td align="center">{$vo['name']}</td>						
						<td align="center">{$vo['num']}</td>	
						<td align="center">{$vo['unit']}</td>	
						<td align="center">{$vo['enter_order_sn']}</td>	
						<td align="center">{$vo['order_sn']}</td>	
						<td align="center">{$vo['remark']|default='/'}</td>	
					</tr>
					{/foreach}
					<tr>
						<td align="center">安装员</td>
						<td align="center">{$follow['username']|default=''}</td>
						<td align="center" colspan="2">巡检员：</td>						
						<td align="center">{$follow['inspect_username']|default=''}</td>
						<td align="center">完工日期</td>	
						<td align="center">{if !empty($follow['inspect_date'])}{:date('Y年m月d日',strtotime($follow['inspect_date']))}{/if}</td>		
					</tr>
					<tr>
						<td colspan="7" align="center">
							<h3>相关零部件-更换记录</h3>
						</td>
					</tr>
					<tr>
						<td align="center">物料编号</td>
						<td align="center">名     称</td>
						<td align="center">数量</td>						
						<td align="center">单位</td>
						<td align="center">物料批号/编号</td>	
						<td align="center">领料单/调拨</td>	
						<td align="center">备注</td>	
					</tr>
					<tr>
						<td align="center">/</td>
						<td align="center">/</td>
						<td align="center">/</td>						
						<td align="center">/</td>
						<td align="center">/</td>	
						<td align="center">/</td>	
						<td align="center">/</td>	
					</tr>
					<tr>
						<td align="center">安装员</td>
						<td align="center">/</td>
						<td align="center" colspan="2">巡检员：</td>						
						<td align="center">/</td>
						<td align="center">完工日期</td>	
						<td align="center">/</td>		
					</tr>					
				</tbody>
			</table>
	
		</div>
	</div>
	
	<div class="bottom no-print">
		<div class="button-container" style="right: 5%;width: 90%;">
			<div class="layui-row">
				<div class="layui-col-xs12" style="text-align:right;">
					<button type="button" class="layui-btn layui-bg-orange layui-btn-sm  print" style="float: left; margin-top: 10px;">打印</button>
					{if empty($bg)}
					{if $produce_process['confirm_date'] && in_array(9,request()->userInfo['permission'])}
					<button type="submit" class="layui-btn layui-btn-sm inspect" data-form_url="{:url('processInspect')}" lay-submit="" lay-filter="*">完成</button>
					{else if $produce_process['user_id'] == 0}
					<button type="submit" class="layui-btn layui-btn-normal layui-btn-sm finish" lay-submit="" lay-filter="finish">上报完工</button>
					{/if}
					{/if}
				</div>
			</div>
		</div>
	</div>
	
</form>
<div class="layui-form-item layui-hide" >
	<select id="warehouse_id_select">
		{if !empty($warehouse)}
		{foreach $warehouse as $vo}
		<option value="{$vo['id']}">{$vo['name']}</option>
		{/foreach}
		{/if}
	</select>
</div>
{/block}
{block name="script"}
<script>
var is_end = '{$process['is_end']|default=''}';
layui.use(['form', 'jquery'], function() {
	let form = layui.form;
	let $ = layui.jquery;
		
	form.on('submit(finish)', function (data) {
		if(is_end == 1){
			layui.layer.open({
				type: 1,
				area: ['500px', '300px'],
				title: '入库仓库',
				content: '<form class="layui-form layui-padding-3" lay-filter="test"><select name="warehouse_id" id="warehouse_id">'+$('#warehouse_id_select').html()+'</select> <div style="margin-top:20px;" class="layui-form-item"><button class="layui-btn layui-btn-fluid confirm" type="button">确认</button></div></form>',
				success: function (layero) {
					form.render(layero.find('.layui-form select'));
					layero.find('.confirm').click(function(){
						var warehouse_id = layero.find('#warehouse_id').val();
						if(warehouse_id){
							data.field.warehouse_id = warehouse_id;
							formSubmit(data)
						}else{
							layui.layer.msg('请选择入库仓库');
						}
					})
				},
			  });
		}else{
			formSubmit(data)
		}
		return false;
	});
	
	$('.print').click(function(){
		window.print();
	})
		
})
</script>
{/block}